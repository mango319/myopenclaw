{"type":"message","id":"43d852ce","parentId":"9d9f8663","timestamp":"2026-03-10T08:11:43.990Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"用户让我写一个Python转录脚本。之前我已经写过了，但用户可能没有看到或者想要一个更完整的版本。\n\n让我写一个更完善的脚本，包括：\n1. 更详细的错误处理\n2. 音频格式转换（m4a转wav）\n3. 模型选择选项\n4. 进度显示\n\n用户的音频文件是：C:\\Users\\Administrator\\.openclaw\\qqbot\\downloads\\合伙企业会议_1773129780541.m4a","thinkingSignature":"reasoning_content"},{"type":"text","text":"好的，胖子！让我给你写一个更完善的Python转录脚本，支持音频格式转换："},{"type":"toolCall","id":"call_ab9c2de7bace460790477d8a","name":"write","arguments":{"path":"C:\\Users\\Administrator\\.openclaw\\workspace\\transcribe_audio.py","content":"# 音频转录脚本 (完善版)\n# 支持格式转换、模型选择、详细进度显示\n\nimport whisper\nimport os\nimport sys\nimport subprocess\n\ndef check_dependencies():\n    \"\"\"检查依赖\"\"\"\n    try:\n        import whisper\n        print('✓ OpenAI Whisper 已安装')\n        return True\n    except ImportError:\n        print('✗ OpenAI Whisper 未安装')\n        print('请运行: pip install openai-whisper')\n        return False\n\ndef convert_audio(input_file, output_format='wav'):\n    \"\"\"\n    转换音频格式\n    支持的输入格式: .m4a, .mp3, .ogg, .flac\n    支持的输出格式: .wav (推荐Whisper使用)\n    \"\"\"\n    base_name = os.path.splitext(input_file)[0]\n    output_file = f'{base_name}.{output_format}'\n    \n    # 使用 ffmpeg 转换\n    try:\n        print(f'正在转换音频格式...')\n        print(f'  输入: {input_file}')\n        print(f'  输出: {output_file}')\n        \n        # 检查 ffmpeg\n        ffmpeg_check = subprocess.run(['ffmpeg', '-version'], \n                                      capture_output=True, \n                                      stderr=subprocess.DEVNULL)\n        \n        if ffmpeg_check.returncode != 0:\n            print('⚠ ffmpeg 未安装')\n            print('请从 https://ffmpeg.org/download.html 下载安装')\n            return None\n        \n        # 执行转换\n        cmd = [\n            'ffmpeg', '-i', input_file,\n            '-acodec', 'pcm_s16le',  # 16-bit PCM\n            '-ac', '1',  # 单声道\n            '-y',  # 覆盖\n            output_file\n        ]\n        \n        result = subprocess.run(cmd, capture_output=True, text=True)\n        \n        if result.returncode == 0:\n            print(f'✓ 转换成功: {output_file}')\n            return output_file\n        else:\n            print(f'✗ 转换失败: {result.stderr}')\n            return None\n            \n    except Exception as e:\n        print(f'✗ 转换错误: {e}')\n        return None\n\ndef transcribe_audio(audio_file, model_size='base', language='zh'):\n    \"\"\"\n    转录音频文件为文字\n    \n    参数:\n        audio_file: 音频文件路径\n        model_size: 模型大小 (tiny/base/small/medium/large/turbo)\n                   turbo 最快，base 推荐\n        language: 语言代码 (zh=中文)\n    \"\"\"\n    \n    print('')\n    print('='*50)\n    print('开始转录')\n    print('='*50)\n    print(f'模型: {model_size}')\n    print(f'语言: {language}')\n    print(f'文件: {audio_file}')\n    print(f'大小: {os.path.getsize(audio_file)/1024/1024:.2f} MB')\n    print('='*50)\n    print('')\n    \n    # 检查文件是否存在\n    if not os.path.exists(audio_file):\n        print(f'✗ 文件不存在: {audio_file}')\n        return None\n    \n    try:\n        # 加载模型\n        print(f'正在加载 Whisper 模型 ({model_size})...')\n        print('提示: 首次运行会自动下载模型，请耐心等待...')\n        model = whisper.load_model(model_size)\n        print('✓ 模型加载完成')\n        print('')\n        \n        # 执行转录\n        print('正在转录，这可能需要几分钟，请耐心等待...')\n        print('进度提示: 处理时间取决于音频长度和计算机性能')\n        print('')\n        \n        result = model.transcribe(\n            audio_file,\n            language=language,\n            fp16=False,  # 使用32位浮点精度\n            verbose=True   # 显示详细进度\n        )\n        \n        print('')\n        print('='*50)\n        print('转录完成')\n        print('='*50)\n        print('')\n        \n        # 输出完整文本\n        print('【完整文本】')\n        print(result['text'])\n        print('')\n        \n        # 输出分段信息（带时间戳）\n        print('【分段信息】')\n        for i, segment in enumerate(result['segments'], 1):\n            start_time = f\"{segment['start']:.2f}\"\n            end_time = f\"{segment['end']:.2f}\"\n            text = segment['text']\n            \n            # 转换秒数为可读格式\n            start_min = int(segment['start'] // 60)\n            start_sec = int(segment['start'] % 60)\n            end_min = int(segment['end'] // 60)\n            end_sec = int(segment['end'] % 60)\n            \n            print(f\"[{start_min:02d}:{start_sec:02d} - {end_min:02d}:{end_sec:02d}] {text}\")\n            \n            if i % 5 == 0:\n                print('')  # 每5段空一行\n        \n        print('')\n        print('✓ 转录完成!')\n        \n        return result['text']\n        \n    except Exception as e:\n        print(f'')\n        print('✗ 转录失败')\n        print(f'错误: {e}')\n        print('')\n        print('可能的解决方案:')\n        print('1. 确保音频文件格式正确')\n        print('2. 尝试转换音频为 WAV 格式')\n        print('3. 检查音频文件是否损坏')\n        print('4. 尝试使用更小的模型 (tiny)')\n        import traceback\n        traceback.print_exc()\n        return None\n\ndef save_to_file(text, output_file='transcription.txt'):\n    \"\"\"保存转录文本到文件\"\"\"\n    try:\n        with open(output_file, 'w', encoding='utf-8') as f:\n            f.write(text)\n        print(f'✓ 文本已保存到: {output_file}')\n        print(f'  文件位置: {os.path.abspath(output_file)}')\n    except Exception as e:\n        print(f'✗ 保存文件失败: {e}')\n\ndef main():\n    \"\"\"主函数\"\"\"\n    \n    print('='*50)\n    print('音频转录工具 (Whisper)')\n    print('='*50)\n    print('')\n    \n    # 检查依赖\n    if not check_dependencies():\n        sys.exit(1)\n    \n    print('')\n    print('='*50)\n    print('使用说明')\n    print('='*50)\n    print('用法:')\n    print('  python transcribe_audio.py <音频文件>')\n    print('  python transcribe_audio.py <音频文件> --model tiny')\n    print('  python transcribe_audio.py <音频文件> --language en')\n    print('')\n    print('支持的模型:')\n    print('  tiny   - 最快 (39M)，适合长音频')\n    print('  base   - 快 (74M)，推荐 ⭐')\n    print('  small  - 较快 (244M)')\n    print('  medium - 中等 (769M)')\n    print('  large  - 慢 (1550M)，最准确')\n    print('  turbo  - 平衡 (809M)')\n    print('')\n    print('支持的语言:')\n    print('  zh (中文), en (英文), ja (日文), ko (韩文)')\n    print('  ...共支持 99 种语言')\n    print('')\n    \n    if len(sys.argv) < 2:\n        print('✗ 请提供音频文件路径')\n        print('示例:')\n        print('  python transcribe_audio.py meeting.m4a')\n        print('  python transcribe_audio.py meeting.mp3')\n        sys.exit(1)\n    \n    audio_file = sys.argv[1]\n    \n    # 解析命令行参数\n    model_size = 'base'  # 默认模型\n    language = 'zh'  # 默认中文\n    convert_first = False  # 是否先转换\n    \n    for i in range(2, len(sys.argv)):\n        arg = sys.argv[i]\n        if arg == '--model':\n            if i + 1 < len(sys.argv):\n                model_size = sys.argv[i + 1]\n        elif arg == '--language':\n            if i + 1 < len(sys.argv):\n                language = sys.argv[i + 1]\n        elif arg == '--convert':\n            convert_first = True\n    \n    # 检查文件格式\n    file_ext = os.path.splitext(audio_file)[1].lower()\n    \n    # 如果不是 WAV，询问是否转换\n    if file_ext != '.wav' and not convert_first:\n        print('⚠ 检测到非 WAV 格式音频')\n        print(f'  当前格式: {file_ext}')\n        print('  WAV 格式可以获得最佳转录效果')\n        print('')\n        print('选择:')\n        print('  1. 直接转录 (可能效果较差)')\n        print('  2. 先转换为 WAV (推荐)')\n        print('')\n        print('提示: 使用 --convert 参数可直接转换为 WAV')\n        print('')\n        \n        # 自动转换 (因为.m4a不被Whisper完美支持)\n        if file_ext == '.m4a':\n            print('正在自动转换为 WAV 格式...')\n            wav_file = convert_audio(audio_file, 'wav')\n            if wav_file:\n                audio_file = wav_file\n                print('')\n            else:\n                print('⚠ 转换失败，尝试直接转录...')\n                print('')\n    \n    # 执行转录\n    result = transcribe_audio(audio_file, model_size, language)\n    \n    # 保存结果\n    if result:\n        output_file = os.path.splitext(audio_file)[0] + '_transcription.txt'\n        save_to_file(result, output_file)\n    \n    print('')\n    print('='*50)\n    print('转录完成!')\n    print('='*50)\n\nif __name__ == '__main__':\n    main()\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":137213,"output":2352,"cacheRead":0,"cacheWrite":0,"totalTokens":139565,"cost":{"input":0.08232779999999999,"output":0.0051744,"cacheRead":0,"cacheWrite":0,"total":0.08750219999999999}},"stopReason":"toolUse","timestamp":1773130189470}}
