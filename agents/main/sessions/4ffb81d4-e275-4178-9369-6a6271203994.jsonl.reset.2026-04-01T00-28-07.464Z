{"type":"message","id":"851a216a","parentId":"049dca47","timestamp":"2026-03-31T02:12:27.167Z","message":{"role":"toolResult","toolCallId":"call_fea5cfd788af4e74b5f0c4db","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\nA股主板股票基本面+技术面综合分析\n筛选低PE、高股息、技术面良好的股票\n\"\"\"\n\nimport requests\nimport json\nimport time\nimport math\nimport os\nfrom datetime import datetime\nfrom typing import List, Dict, Any\nimport statistics\n\n# 配置\nOUTPUT_FILE = \"stock_analysis_results.json\"\nLOG_FILE = \"stock_analysis.log\"\n\n# 股票代码前缀筛选\nSTOCK_CODE_PREFIXES = [\n    \"600\", \"601\", \"603\", \"605\",  # 沪市主板\n    \"000\", \"001\", \"002\", \"003\"   # 深市主板/中小板\n]\n\n# 净利润同比增长率筛选阈值（单位：%）\nNET_PROFIT_GROWTH_THRESHOLD = 30\n\n# 营业收入筛选阈值（单位：亿元）\nREVENUE_THRESHOLD = 10\n\ndef log(message: str):\n    \"\"\"记录日志\"\"\"\n    timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n    line = f\"[{timestamp}] {message}\"\n    print(line)\n    with open(LOG_FILE, \"a\", encoding=\"utf-8\") as f:\n        f.write(line + \"\\n\")\n\ndef safe_float(value, default=0):\n    \"\"\"安全转换浮点数，处理None、\"-\"等无效值\"\"\"\n    if value is None or value == \"\" or value == \"-\":\n        return default\n    try:\n        return float(value)\n    except (ValueError, TypeError):\n        return default\n\ndef get_stock_list() -> List[Dict]:\n    \"\"\"获取A股主板股票列表\"\"\"\n    log(\"正在获取A股主板股票列表...\")\n\n    # 不使用代理\n    proxies = {\n        'http': None,\n        'https': None,\n    }\n\n    try:\n        # 使用东方财富网的股票列表API\n        url = \"https://80.push2.eastmoney.com/api/qt/clist/get\"\n        params = {\n            \"pn\": 1,\n            \"pz\": 5000,\n            \"po\": 1,\n            \"np\": 1,\n            \"ut\": \"bd1d9ddb04089700cf9c27f6f7426281\",\n            \"fltt\": 2,\n            \"invt\": 2,\n            \"fid\": \"f3\",\n            \"fs\": \"m:0+t:6,m:0+t:80,m:1+t:2,m:1+t:23\",  # 主板\n            \"fields\": \"f12,f14,f2,f3,f4,f5,f6,f7,f8,f9,f10,f11,f13,f15,f16,f17,f18,f20,f21,f23,f24,f25,f22,f33,f11,f62,f128,f136,f115,f152\"\n        }\n        headers = {\n            \"User-Agent\": \"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36\"\n        }\n\n        # 尝试3次\n        for attempt in range(3):\n            try:\n                response = requests.get(\n                    url,\n                    params=params,\n                    headers=headers,\n                    timeout=30,\n                    proxies=proxies\n                )\n                response.raise_for_status()\n                data = response.json()\n\n                if data.get(\"rc\") == 0 and data.get(\"data\"):\n                    stocks = data[\"data\"][\"diff\"]\n                    log(f\"成功获取 {len(stocks)} 只股票\")\n\n                    # 打印第一只股票的数据样本\n                    if len(stocks) > 0:\n                        sample = stocks[0]\n                        log(f\"股票样本数据: code={sample.get('f12')}, name={sample.get('f14')}\")\n                        # 打印所有可能的财务相关字段\n                        for key in sorted(sample.keys()):\n                            if 'f' in str(key):\n                                log(f\"  {key}: {sample.get(key)}\")\n\n                    return stocks\n                else:\n                    log(f\"API返回异常: {data}\")\n                    return []\n            except Exception as e:\n                log(f\"第 {attempt + 1} 次尝试失败: {e}\")\n                if attempt < 2:\n                    time.sleep(2)\n                    continue\n                else:\n                    raise\n\n    except Exception as e:\n        log(f\"获取股票列表失败: {e}\")\n        return []\n\ndef calculate_score(stock: Dict, net_profit_growth: float = 0) -> float:\n    \"\"\"\n    综合评分 (0-100)\n    考虑因素:\n    - PE比率 (越低越好)\n    - 净利润同比增长率 (越高越好)\n    - 股息率 (越高越好)\n    - 换手率 (适中为宜)\n    - 涨跌幅\n    - 成交额\n    \"\"\"\n    try:\n        pe_ratio = safe_float(stock.get(\"f9\"))  # 市盈率\n        dividend_yield = (safe_float(stock.get(\"f128\")) / 100) if stock.get(\"f128\") else 0  # 股息率\n        change_percent = safe_float(stock.get(\"f3\"))  # 涨跌幅\n        turnover = safe_float(stock.get(\"f8\"))  # 换手率\n        amount = safe_float(stock.get(\"f5\"))  # 成交额\n        volume = safe_float(stock.get(\"f6\"))  # 成交量\n\n        score = 50  # 基准分\n\n        # 净利润同比增长率评分 (0-35分)\n        if net_profit_growth >= 50:  # 50%以上\n            score += 35\n        elif net_profit_growth >= 30:  # 30%以上\n            score += 30\n        elif net_profit_growth >= 20:  # 20%以上\n            score += 25\n        elif net_profit_growth >= 10:  # 10%以上\n            score += 15\n        elif net_profit_growth > 0:  # 正增长\n            score += 10\n\n        # PE评分 (0-30分)\n        if pe_ratio > 0 and pe_ratio < 100:\n            if pe_ratio < 10:\n                score += 30\n            elif pe_ratio < 20:\n                score += 25\n            elif pe_ratio < 30:\n                score += 20\n            elif pe_ratio < 50:\n                score += 10\n\n        # 股息率评分 (0-25分)\n        if dividend_yield > 0:\n            if dividend_yield >= 0.05:  # 5%以上\n                score += 25\n            elif dividend_yield >= 0.03:\n                score += 20\n            elif dividend_yield >= 0.02:\n                score += 15\n            elif dividend_yield >= 0.01:\n                score += 10\n\n        # 换手率评分 (0-15分)\n        if 0.5 <= turnover <= 5:\n            score += 15\n        elif 0.1 <= turnover < 0.5:\n            score += 10\n        elif 5 < turnover <= 10:\n            score += 5\n\n        # 涨跌幅评分 (0-20分，小幅上涨较好)\n        if 0 < change_percent <= 3:\n            score += 20\n        elif -1 < change_percent <= 0:\n            score += 15\n        elif 3 < change_percent <= 5:\n            score += 10\n        elif -3 < change_percent <= -1:\n            score += 5\n\n        # 流动性评分 (0-10分)\n        if amount > 100000000:  # 1亿以上\n            score += 10\n        elif amount > 50000000:\n            score += 8\n        elif amount > 20000000:\n            score += 5\n\n        return round(score, 2)\n    except Exception as e:\n        log(f\"计算评分失败: {e}\")\n        return 0\n\ndef analyze_stocks(stock_list: List[Dict]) -> List[Dict]:\n    \"\"\"分析股票列表\"\"\"\n    log(\"开始分析股票数据...\")\n    results = []\n\n    for idx, stock in enumerate(stock_list):\n        try:\n            if idx % 100 == 0:\n                log(f\"已处理 {idx}/{len(stock_list)} 只股票...\")\n\n            # 基本面数据\n            pe_ratio = safe_float(stock.get(\"f9\"))  # 市盈率\n            pb_ratio = safe_float(stock.get(\"f10\"))  # 市净率\n            market_cap = safe_float(stock.get(\"f20\"))  # 总市值\n            dividend_yield = (safe_float(stock.get(\"f128\")) / 100) if stock.get(\"f128\") else 0  # 股息率\n\n            # 市场数据\n            price = safe_float(stock.get(\"f2\"))  # 最新价\n            change_percent = safe_float(stock.get(\"f3\"))  # 涨跌幅\n            change_amount = safe_float(stock.get(\"f4\"))  # 涨跌额\n            open_price = safe_float(stock.get(\"f17\"))  # 今开\n            high_price = safe_float(stock.get(\"f15\"))  # 最高\n            low_price = safe_float(stock.get(\"f16\"))  # 最低\n            prev_close = safe_float(stock.get(\"f18\"))  # 昨收\n\n            # 成交数据\n            volume = safe_float(stock.get(\"f6\"))  # 成交量(手)\n            amount = safe_float(stock.get(\"f5\"))  # 成交额\n            turnover = safe_float(stock.get(\"f8\"))  # 换手率\n\n            # 获取财务数据（包括净利润同比增长率）\n            # f62: 营业收入（万元）\n            # f115: 净利润同比增长率（%）\n            revenue_yuan = safe_float(stock.get(\"f62\"), 0)  # 万元\n            net_profit_growth = safe_float(stock.get(\"f115\"), 0)  # %\n\n            # 数据验证：只保留满足条件的股票\n            # 营业收入 >= 10亿元（1000000万元）\n            # 净利润同比增长 >= 30%\n            if revenue_yuan < REVENUE_THRESHOLD * 10000:  # 万元转亿元对比\n                log(f\"股票 {code} 营业收入不达标：{revenue_yuan}万元 < {REVENUE_THRESHOLD}亿元\")\n                continue\n\n            if net_profit_growth < NET_PROFIT_GROWTH_THRESHOLD:\n                log(f\"股票 {code} 净利润增长率不达标：{net_profit_growth}% < {NET_PROFIT_GROWTH_THRESHOLD}%\")\n                continue\n\n            # 计算技术指标\n            # 均线趋势 (简单判断)\n            ma_trend = \"横盘\"\n            if price > open_price > prev_close:\n                ma_trend = \"上涨\"\n            elif price < open_price < prev_close:\n                ma_trend = \"下跌\"\n\n            # RSI简化估算 (基于涨跌幅)\n            rsi = 50 + change_percent * 10\n            rsi = max(0, min(100, rsi))\n\n            # 综合评分\n            score = calculate_score(stock, net_profit_growth)\n\n            # 基本信息\n            code = stock.get(\"f12\", \"\")\n            name = stock.get(\"f14\", \"\")\n\n            stock_data = {\n                \"代码\": code,\n                \"名称\": name,\n                \"价格\": round(price, 2) if price else 0,\n                \"涨跌幅\": f\"{change_percent:.2f}%\" if change_percent else \"0.00%\",\n                \"涨跌额\": round(change_amount, 2) if change_amount else 0,\n                \"PE\": round(pe_ratio, 2) if pe_ratio else 0,\n                \"PB\": round(pb_ratio, 2) if pb_ratio else 0,\n                \"股息率\": f\"{dividend_yield:.2%}\" if dividend_yield else \"0.00%\",\n                \"换手率\": f\"{turnover:.2f}%\" if turnover else \"0.00%\",\n                \"成交额\": f\"{amount/100000000:.2f}亿\" if amount > 0 else \"0\",\n                \"总市值\": f\"{market_cap/100000000:.2f}亿\" if market_cap > 0 else \"0\",\n                \"营业收入\": f\"{revenue_yuan/10000:.2f}亿\" if revenue_yuan > 0 else \"0\",  # 万元 → 亿元\n                \"净利润同比增长\": f\"{net_profit_growth:.2f}%\" if net_profit_growth else \"0.00%\",\n                \"趋势\": ma_trend,\n                \"RSI\": round(rsi, 2),\n                \"评分\": score\n            }\n\n            results.append(stock_data)\n\n        except Exception as e:\n            code = stock.get(\"f12\", \"UNKNOWN\")\n            log(f\"分析股票 {code} 时出错: {e}\")\n            continue\n\n    log(f\"分析完成，共 {len(results)} 只股票\")\n    return results\n\ndef filter_by_market(stocks: List[Dict]) -> List[Dict]:\n    \"\"\"根据市场筛选股票\"\"\"\n    log(f\"正在筛选沪市主板和深市主板股票...\")\n    filtered = []\n    for stock in stocks:\n        code = stock.get(\"代码\", \"\")\n        # 检查代码前缀\n        prefix = code[:3] if len(code) >= 3 else \"\"\n        if prefix in STOCK_CODE_PREFIXES:\n            filtered.append(stock)\n\n    log(f\"筛选后剩余 {len(filtered)} 只股票\")\n    return filtered\n\ndef filter_and_sort(stocks: List[Dict], top_n: int = 50) -> List[Dict]:\n    \"\"\"筛选并排序\"\"\"\n    log(\"正在筛选和排序...\")\n\n    # 先按市场筛选\n    market_filtered = filter_by_market(stocks)\n\n    # 筛选条件\n    # 1. PE: 0 < PE < 100\n    # 2. 净利润同比增长率 >= 30%\n    # 3. 营业收入 >= 10亿元\n    filtered = [\n        s for s in market_filtered\n        if s[\"PE\"] > 0\n        and s[\"PE\"] < 100\n        and safe_float(str(s[\"净利润同比增长\"]).rstrip('%')) >= NET_PROFIT_GROWTH_THRESHOLD\n        and safe_float(str(s[\"营业收入\"]).rstrip('亿')) >= REVENUE_THRESHOLD\n    ]\n\n    log(f\"筛选后剩余 {len(filtered)} 只股票（净利润同比增长 >= {NET_PROFIT_GROWTH_THRESHOLD}%，营业收入 >= {REVENUE_THRESHOLD}亿）\")\n\n    # 按评分排序\n    sorted_stocks = sorted(filtered, key=lambda x: x[\"评分\"], reverse=True)\n\n    # 返回前N只\n    return sorted_stocks[:top_n]\n\ndef save_results(stocks: List[Dict], filename: str):\n    \"\"\"保存结果\"\"\"\n    log(f\"正在保存结果到 {filename}...\")\n    with open(filename, \"w\", encoding=\"utf-8\") as f:\n        json.dump(stocks, f, ensure_ascii=False, indent=2)\n    log(f\"结果已保存\")\n\ndef format_summary(stocks: List[Dict]) -> str:\n    \"\"\"格式化摘要\"\"\"\n    if not stocks:\n        return \"没有符合条件的股票\"\n\n    summary = \"\\n\" + \"=\"*80 + \"\\n\"\n    summary += f\"{'排名':<6}{'代码':<10}{'名称':<10}{'价格':<10}{'涨跌幅':<10}{'PE':<8}{'营业收入':<10}{'净利润同比增长':<12}{'评分':<8}\\n\"\n    summary += \"-\"*80 + \"\\n\"\n\n    for idx, stock in enumerate(stocks[:30], 1):\n        summary += f\"{idx:<6}{stock['代码']:<10}{stock['名称']:<10}{stock['价格']:<10}{stock['涨跌幅']:<10}{stock['PE']:<8}{stock['营业收入']:<10}{stock['净利润同比增长']:<12}{stock['评分']:<8}\\n\"\n\n    summary += \"=\"*80 + \"\\n\"\n    summary += f\"\\n统计信息:\\n\"\n    summary += f\"  - 分析股票总数: {len(stocks)}\\n\"\n    summary += f\"  - 平均PE: {statistics.mean([s['PE'] for s in stocks if s['PE'] > 0]):.2f}\\n\"\n    summary += f\"  - 平均营业收入: {statistics.mean([safe_float(str(s['营业收入']).rstrip('亿')) for s in stocks]):.2f}亿\\n\"\n    summary += f\"  - 平均净利润同比增长: {statistics.mean([safe_float(str(s['净利润同比增长']).rstrip('%')) for s in stocks]):.2f}%\\n\"\n    summary += f\"  - 平均评分: {statistics.mean([s['评分'] for s in stocks]):.2f}\\n\"\n\n    return summary\n\ndef main():\n    \"\"\"主函数\"\"\"\n    log(\"=\"*60)\n    log(\"A股股票分析程序启动\")\n    log(\"=\"*60)\n\n    start_time = time.time()\n\n    # 1. 获取股票列表\n    stock_list = get_stock_list()\n    if not stock_list:\n        log(\"未获取到股票数据，退出程序\")\n        return\n\n    # 2. 分析股票\n    analyzed = analyze_stocks(stock_list)\n\n    # 3. 筛选排序\n    top_stocks = filter_and_sort(analyzed, top_n=50)\n\n    # 4. 保存结果\n    save_results(top_stocks, OUTPUT_FILE)\n\n    # 5. 打印摘要\n    summary = format_summary(top_stocks)\n    print(summary)\n\n    # 6. 记录到日志\n    with open(LOG_FILE, \"a\", encoding=\"utf-8\") as f:\n        f.write(summary + \"\\n\")\n\n    elapsed = time.time() - start_time\n    log(f\"\\n程序运行完成！耗时: {elapsed:.2f}秒\")\n    log(\"=\"*60)\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1774923147158}}
{"type":"message","id":"e3f01f08","parentId":"851a216a","timestamp":"2026-03-31T02:15:16.218Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"找到了！这个脚本在 `filter_and_sort` 函数里有一个参数 `top_n=50`，但是问题是前面的 `analyze_stocks` 函数会分析所有股票，只是最后只保留前50只。从代码来看，它实际上会分析所有获取到的股票（从东方财富网API获取的可能是全部5000只）。\n\n不过用户要求看100只股票然后筛选，我理解他的意思是想看更多的样本。但是这个脚本的问题在于：\n1. `filter_and_sort` 函数最后只返回 `top_n=50` 只股票\n2. 前面的分析是针对所有获取到的股票\n\n如果要分析100只，我需要修改这个脚本的 `top_n` 参数。不过用户现在想立即看到结果，我应该直接修改并运行这个脚本。\n\n让我创建一个临时脚本，把 top_n 改成 100，然后运行它。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_ddcfd6e8b95648c784666cf1","name":"write","arguments":{"path":"C:\\Users\\Administrator\\.openclaw\\workspace\\stock_analysis_100.py","content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\nA股主板股票基本面+技术面综合分析 - 100只版本\n\"\"\"\n\nimport requests\nimport json\nimport time\nimport math\nimport os\nfrom datetime import datetime\nfrom typing import List, Dict, Any\nimport statistics\n\n# 配置\nOUTPUT_FILE = \"stock_analysis_results.json\"\nLOG_FILE = \"stock_analysis.log\"\n\n# 股票代码前缀筛选\nSTOCK_CODE_PREFIXES = [\n    \"600\", \"601\", \"603\", \"605\",  # 沪市主板\n    \"000\", \"001\", \"002\", \"003\"   # 深市主板/中小板\n]\n\n# 净利润同比增长率筛选阈值（单位：%）\nNET_PROFIT_GROWTH_THRESHOLD = 30\n\n# 营业收入筛选阈值（单位：亿元）\nREVENUE_THRESHOLD = 10\n\ndef log(message: str):\n    \"\"\"记录日志\"\"\"\n    timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n    line = f\"[{timestamp}] {message}\"\n    print(line)\n    with open(LOG_FILE, \"a\", encoding=\"utf-8\") as f:\n        f.write(line + \"\\n\")\n\ndef safe_float(value, default=0):\n    \"\"\"安全转换浮点数，处理None、\"-\"等无效值\"\"\"\n    if value is None or value == \"\" or value == \"-\":\n        return default\n    try:\n        return float(value)\n    except (ValueError, TypeError):\n        return default\n\ndef get_stock_list() -> List[Dict]:\n    \"\"\"获取A股主板股票列表\"\"\"\n    log(\"正在获取A股主板股票列表...\")\n\n    # 不使用代理\n    proxies = {\n        'http': None,\n        'https': None,\n    }\n\n    try:\n        # 使用东方财富网的股票列表API\n        url = \"https://80.push2.eastmoney.com/api/qt/clist/get\"\n        params = {\n            \"pn\": 1,\n            \"pz\": 5000,\n            \"po\": 1,\n            \"np\": 1,\n            \"ut\": \"bd1d9ddb04089700cf9c27f6f7426281\",\n            \"fltt\": 2,\n            \"invt\": 2,\n            \"fid\": \"f3\",\n            \"fs\": \"m:0+t:6,m:0+t:80,m:1+t:2,m:1+t:23\",  # 主板\n            \"fields\": \"f12,f14,f2,f3,f4,f5,f6,f7,f8,f9,f10,f11,f13,f15,f16,f17,f18,f20,f21,f23,f24,f25,f22,f33,f11,f62,f128,f136,f115,f152\"\n        }\n        headers = {\n            \"User-Agent\": \"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36\"\n        }\n\n        # 尝试3次\n        for attempt in range(3):\n            try:\n                response = requests.get(\n                    url,\n                    params=params,\n                    headers=headers,\n                    timeout=30,\n                    proxies=proxies\n                )\n                response.raise_for_status()\n                data = response.json()\n\n                if data.get(\"rc\") == 0 and data.get(\"data\"):\n                    stocks = data[\"data\"][\"diff\"]\n                    log(f\"成功获取 {len(stocks)} 只股票\")\n\n                    # 打印第一只股票的数据样本\n                    if len(stocks) > 0:\n                        sample = stocks[0]\n                        log(f\"股票样本数据: code={sample.get('f12')}, name={sample.get('f14')}\")\n\n                    return stocks\n                else:\n                    log(f\"API返回异常: {data}\")\n                    return []\n            except Exception as e:\n                log(f\"第 {attempt + 1} 次尝试失败: {e}\")\n                if attempt < 2:\n                    time.sleep(2)\n                    continue\n                else:\n                    raise\n\n    except Exception as e:\n        log(f\"获取股票列表失败: {e}\")\n        return []\n\ndef calculate_score(stock: Dict, net_profit_growth: float = 0) -> float:\n    \"\"\"\n    综合评分 (0-100)\n    考虑因素:\n    - PE比率 (越低越好)\n    - 净利润同比增长率 (越高越好)\n    - 股息率 (越高越好)\n    - 换手率 (适中为宜)\n    - 涨跌幅\n    - 成交额\n    \"\"\"\n    try:\n        pe_ratio = safe_float(stock.get(\"f9\"))  # 市盈率\n        dividend_yield = (safe_float(stock.get(\"f128\")) / 100) if stock.get(\"f128\") else 0  # 股息率\n        change_percent = safe_float(stock.get(\"f3\"))  # 涨跌幅\n        turnover = safe_float(stock.get(\"f8\"))  # 换手率\n        amount = safe_float(stock.get(\"f5\"))  # 成交额\n        volume = safe_float(stock.get(\"f6\"))  # 成交量\n\n        score = 50  # 基准分\n\n        # 净利润同比增长率评分 (0-35分)\n        if net_profit_growth >= 50:  # 50%以上\n            score += 35\n        elif net_profit_growth >= 30:  # 30%以上\n            score += 30\n        elif net_profit_growth >= 20:  # 20%以上\n            score += 25\n        elif net_profit_growth >= 10:  # 10%以上\n            score += 15\n        elif net_profit_growth > 0:  # 正增长\n            score += 10\n\n        # PE评分 (0-30分)\n        if pe_ratio > 0 and pe_ratio < 100:\n            if pe_ratio < 10:\n                score += 30\n            elif pe_ratio < 20:\n                score += 25\n            elif pe_ratio < 30:\n                score += 20\n            elif pe_ratio < 50:\n                score += 10\n\n        # 股息率评分 (0-25分)\n        if dividend_yield > 0:\n            if dividend_yield >= 0.05:  # 5%以上\n                score += 25\n            elif dividend_yield >= 0.03:\n                score += 20\n            elif dividend_yield >= 0.02:\n                score += 15\n            elif dividend_yield >= 0.01:\n                score += 10\n\n        # 换手率评分 (0-15分)\n        if 0.5 <= turnover <= 5:\n            score += 15\n        elif 0.1 <= turnover < 0.5:\n            score += 10\n        elif 5 < turnover <= 10:\n            score += 5\n\n        # 涨跌幅评分 (0-20分，小幅上涨较好)\n        if 0 < change_percent <= 3:\n            score += 20\n        elif -1 < change_percent <= 0:\n            score += 15\n        elif 3 < change_percent <= 5:\n            score += 10\n        elif -3 < change_percent <= -1:\n            score += 5\n\n        # 流动性评分 (0-10分)\n        if amount > 100000000:  # 1亿以上\n            score += 10\n        elif amount > 50000000:\n            score += 8\n        elif amount > 20000000:\n            score += 5\n\n        return round(score, 2)\n    except Exception as e:\n        log(f\"计算评分失败: {e}\")\n        return 0\n\ndef analyze_stocks(stock_list: List[Dict]) -> List[Dict]:\n    \"\"\"分析股票列表\"\"\"\n    log(\"开始分析股票数据...\")\n    results = []\n\n    for idx, stock in enumerate(stock_list):\n        try:\n            if idx % 100 == 0:\n                log(f\"已处理 {idx}/{len(stock_list)} 只股票...\")\n\n            # 基本面数据\n            pe_ratio = safe_float(stock.get(\"f9\"))  # 市盈率\n            pb_ratio = safe_float(stock.get(\"f10\"))  # 市净率\n            market_cap = safe_float(stock.get(\"f20\"))  # 总市值\n            dividend_yield = (safe_float(stock.get(\"f128\")) / 100) if stock.get(\"f128\") else 0  # 股息率\n\n            # 市场数据\n            price = safe_float(stock.get(\"f2\"))  # 最新价\n            change_percent = safe_float(stock.get(\"f3\"))  # 涨跌幅\n            change_amount = safe_float(stock.get(\"f4\"))  # 涨跌额\n            open_price = safe_float(stock.get(\"f17\"))  # 今开\n            high_price = safe_float(stock.get(\"f15\"))  # 最高\n            low_price = safe_float(stock.get(\"f16\"))  # 最低\n            prev_close = safe_float(stock.get(\"f18\"))  # 昨收\n\n            # 成交数据\n            volume = safe_float(stock.get(\"f6\"))  # 成交量(手)\n            amount = safe_float(stock.get(\"f5\"))  # 成交额\n            turnover = safe_float(stock.get(\"f8\"))  # 换手率\n\n            # 获取财务数据（包括净利润同比增长率）\n            # f62: 营业收入（万元）\n            # f115: 净利润同比增长率（%）\n            revenue_yuan = safe_float(stock.get(\"f62\"), 0)  # 万元\n            net_profit_growth = safe_float(stock.get(\"f115\"), 0)  # %\n\n            # 数据验证：只保留满足条件的股票\n            # 营业收入 >= 10亿元（1000000万元）\n            # 净利润同比增长 >= 30%\n            if revenue_yuan < REVENUE_THRESHOLD * 10000:  # 万元转亿元对比\n                log(f\"股票 {code} 营业收入不达标：{revenue_yuan}万元 < {REVENUE_THRESHOLD}亿元\")\n                continue\n\n            if net_profit_growth < NET_PROFIT_GROWTH_THRESHOLD:\n                log(f\"股票 {code} 净利润增长率不达标：{net_profit_growth}% < {NET_PROFIT_GROWTH_THRESHOLD}%\")\n                continue\n\n            # 计算技术指标\n            # 均线趋势 (简单判断)\n            ma_trend = \"横盘\"\n            if price > open_price > prev_close:\n                ma_trend = \"上涨\"\n            elif price < open_price < prev_close:\n                ma_trend = \"下跌\"\n\n            # RSI简化估算 (基于涨跌幅)\n            rsi = 50 + change_percent * 10\n            rsi = max(0, min(100, rsi))\n\n            # 综合评分\n            score = calculate_score(stock, net_profit_growth)\n\n            # 基本信息\n            code = stock.get(\"f12\", \"\")\n            name = stock.get(\"f14\", \"\")\n\n            stock_data = {\n                \"代码\": code,\n                \"名称\": name,\n                \"价格\": round(price, 2) if price else 0,\n                \"涨跌幅\": f\"{change_percent:.2f}%\" if change_percent else \"0.00%\",\n                \"涨跌额\": round(change_amount, 2) if change_amount else 0,\n                \"PE\": round(pe_ratio, 2) if pe_ratio else 0,\n                \"PB\": round(pb_ratio, 2) if pb_ratio else 0,\n                \"股息率\": f\"{dividend_yield:.2%}\" if dividend_yield else \"0.00%\",\n                \"换手率\": f\"{turnover:.2f}%\" if turnover else \"0.00%\",\n                \"成交额\": f\"{amount/100000000:.2f}亿\" if amount > 0 else \"0\",\n                \"总市值\": f\"{market_cap/100000000:.2f}亿\" if market_cap > 0 else \"0\",\n                \"营业收入\": f\"{revenue_yuan/10000:.2f}亿\" if revenue_yuan > 0 else \"0\",  # 万元 → 亿元\n                \"净利润同比增长\": f\"{net_profit_growth:.2f}%\" if net_profit_growth else \"0.00%\",\n                \"趋势\": ma_trend,\n                \"RSI\": round(rsi, 2),\n                \"评分\": score\n            }\n\n            results.append(stock_data)\n\n        except Exception as e:\n            code = stock.get(\"f12\", \"UNKNOWN\")\n            log(f\"分析股票 {code} 时出错: {e}\")\n            continue\n\n    log(f\"分析完成，共 {len(results)} 只股票\")\n    return results\n\ndef filter_by_market(stocks: List[Dict]) -> List[Dict]:\n    \"\"\"根据市场筛选股票\"\"\"\n    log(f\"正在筛选沪市主板和深市主板股票...\")\n    filtered = []\n    for stock in stocks:\n        code = stock.get(\"代码\", \"\")\n        # 检查代码前缀\n        prefix = code[:3] if len(code) >= 3 else \"\"\n        if prefix in STOCK_CODE_PREFIXES:\n            filtered.append(stock)\n\n    log(f\"筛选后剩余 {len(filtered)} 只股票\")\n    return filtered\n\ndef filter_and_sort(stocks: List[Dict], top_n: int = 100) -> List[Dict]:\n    \"\"\"筛选并排序\"\"\"\n    log(\"正在筛选和排序...\")\n\n    # 先按市场筛选\n    market_filtered = filter_by_market(stocks)\n\n    # 筛选条件\n    # 1. PE: 0 < PE < 100\n    # 2. 净利润同比增长率 >= 30%\n    # 3. 营业收入 >= 10亿元\n    filtered = [\n        s for s in market_filtered\n        if s[\"PE\"] > 0\n        and s[\"PE\"] < 100\n        and safe_float(str(s[\"净利润同比增长\"]).rstrip('%')) >= NET_PROFIT_GROWTH_THRESHOLD\n        and safe_float(str(s[\"营业收入\"]).rstrip('亿')) >= REVENUE_THRESHOLD\n    ]\n\n    log(f\"筛选后剩余 {len(filtered)} 只股票（净利润同比增长 >= {NET_PROFIT_GROWTH_THRESHOLD}%，营业收入 >= {REVENUE_THRESHOLD}亿）\")\n\n    # 按评分排序\n    sorted_stocks = sorted(filtered, key=lambda x: x[\"评分\"], reverse=True)\n\n    # 返回前N只\n    return sorted_stocks[:top_n]\n\ndef save_results(stocks: List[Dict], filename: str):\n    \"\"\"保存结果\"\"\"\n    log(f\"正在保存结果到 {filename}...\")\n    with open(filename, \"w\", encoding=\"utf-8\") as f:\n        json.dump(stocks, f, ensure_ascii=False, indent=2)\n    log(f\"结果已保存\")\n\ndef format_summary(stocks: List[Dict]) -> str:\n    \"\"\"格式化摘要\"\"\"\n    if not stocks:\n        return \"没有符合条件的股票\"\n\n    summary = \"\\n\" + \"=\"*80 + \"\\n\"\n    summary += f\"{'排名':<6}{'代码':<10}{'名称':<10}{'价格':<10}{'涨跌幅':<10}{'PE':<8}{'营业收入':<10}{'净利润同比增长':<12}{'评分':<8}\\n\"\n    summary += \"-\"*80 + \"\\n\"\n\n    for idx, stock in enumerate(stocks[:100], 1):\n        summary += f\"{idx:<6}{stock['代码']:<10}{stock['名称']:<10}{stock['价格']:<10}{stock['涨跌幅']:<10}{stock['PE']:<8}{stock['营业收入']:<10}{stock['净利润同比增长']:<12}{stock['评分']:<8}\\n\"\n\n    summary += \"=\"*80 + \"\\n\"\n    summary += f\"\\n统计信息:\\n\"\n    summary += f\"  - 分析股票总数: {len(stocks)}\\n\"\n    summary += f\"  - 平均PE: {statistics.mean([s['PE'] for s in stocks if s['PE'] > 0]):.2f}\\n\"\n    summary += f\"  - 平均营业收入: {statistics.mean([safe_float(str(s['营业收入']).rstrip('亿')) for s in stocks]):.2f}亿\\n\"\n    summary += f\"  - 平均净利润同比增长: {statistics.mean([safe_float(str(s['净利润同比增长']).rstrip('%')) for s in stocks]):.2f}%\\n\"\n    summary += f\"  - 平均评分: {statistics.mean([s['评分'] for s in stocks]):.2f}\\n\"\n\n    return summary\n\ndef main():\n    \"\"\"主函数\"\"\"\n    log(\"=\"*60)\n    log(\"A股股票分析程序启动 - 100只版本\")\n    log(\"=\"*60)\n\n    start_time = time.time()\n\n    # 1. 获取股票列表\n    stock_list = get_stock_list()\n    if not stock_list:\n        log(\"未获取到股票数据，退出程序\")\n        return\n\n    # 2. 分析股票\n    analyzed = analyze_stocks(stock_list)\n\n    # 3. 筛选排序 (返回前100只)\n    top_stocks = filter_and_sort(analyzed, top_n=100)\n\n    # 4. 保存结果\n    save_results(top_stocks, OUTPUT_FILE)\n\n    # 5. 打印摘要\n    summary = format_summary(top_stocks)\n    print(summary)\n\n    # 6. 记录到日志\n    with open(LOG_FILE, \"a\", encoding=\"utf-8\") as f:\n        f.write(summary + \"\\n\")\n\n    elapsed = time.time() - start_time\n    log(f\"\\n程序运行完成！耗时: {elapsed:.2f}秒\")\n    log(\"=\"*60)\n\nif __name__ == \"__main__\":\n    main()\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":3899,"output":4253,"cacheRead":29048,"cacheWrite":0,"totalTokens":37200,"cost":{"input":0.0023393999999999997,"output":0.0093566,"cacheRead":0.00319528,"cacheWrite":0,"total":0.01489128}},"stopReason":"toolUse","timestamp":1774923147168}}
