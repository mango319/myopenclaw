─┬─────────┬─────────┬───────┐\\n\"\n        message += \"│  排名  │  名称    │   代码   │  价格   │   PE    │ 评分  │\\n\"\n        message += \"├────────┼──────────┼──────────┼─────────┼─────────┼───────┤\\n\"\n\n        # 表格内容\n        for idx, stock in enumerate(top10, 1):\n            name = stock['名称'][:8]  # 限制名称长度\n            message += f\"│  {idx:2d}   │  {name:<8} │ {stock['代码']:8s} │ {stock['价格']:>7.2f} │ {stock['PE']:>7.2f} │ {stock['评分']:>4.0f} │\\n\"\n\n        message += \"└────────┴──────────┴──────────┴─────────┴─────────┴───────┘\\n\\n\"\n        message += \"┌────────┬──────────┬──────────┬─────────┬─────────┐\\n\"\n        message += \"│  排名  │  名称    │   代码   │  涨跌幅  │  净利增长│\\n\"\n        message += \"├────────┼──────────┼──────────┼─────────┼─────────┤\\n\"\n\n        for idx, stock in enumerate(top10, 1):\n            name = stock['名称'][:8]\n            growth = stock['净利润同比增长'].rstrip('%')\n            message += f\"│  {idx:2d}   │  {name:<8} │ {stock['代码']:8s} │ {stock['涨跌幅']:>7s} │ {growth:>7s}%│\\n\"\n\n        message += \"└────────┴──────────┴──────────┴─────────┴─────────┘\\n\\n\"\n        message += \"⚠️ 数据仅供参考，投资有风险！\"\n\n        return message\n\n    except Exception as e:\n        return f\"❌ 获取股票数据失败：{e}\""}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":5728,"output":1150,"cacheRead":44585,"cacheWrite":0,"totalTokens":51463,"cost":{"input":0.0034368,"output":0.00253,"cacheRead":0.00490435,"cacheWrite":0,"total":0.01087115}},"stopReason":"toolUse","timestamp":1774923733435}}
