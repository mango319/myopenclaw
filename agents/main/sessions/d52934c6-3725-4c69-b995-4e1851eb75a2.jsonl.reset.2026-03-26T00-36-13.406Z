{"type":"message","id":"31193094","parentId":"1e3c015a","timestamp":"2026-03-25T09:41:50.208Z","message":{"role":"toolResult","toolCallId":"call_2e213da95f1f4b289e537235","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\nA股量化筛选脚本\n策略：\n1. PE<25\n2. 股息率>3%\n3. 近30天涨幅<8%\n4. 5日、10日、20日均线多头排列\n5. 今日放量突破20日线\n6. 选出前5名\n\"\"\"\n\nimport akshare as ak\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime, timedelta\nimport warnings\nwarnings.filterwarnings('ignore')\n\n# ==================== 配置参数 ====================\n# 筛选条件\nPE_THRESHOLD = 25           # PE上限\nDIVIDEND_YIELD_THRESHOLD = 3.0  # 股息率下限(%)\nRISE_30D_THRESHOLD = 8.0    # 30日涨幅上限(%)\nVOLUME_RATIO_THRESHOLD = 1.5 # 成交量放大倍数\nTOP_N = 5                   # 选出前N名\n\n# 均线周期\nMA5_PERIOD = 5\n\n[301 more lines in file. Use offset=31 to continue.]"}],"isError":false,"timestamp":1774431710204}}
