{"type":"message","id":"0724ea98","parentId":"435f333d","timestamp":"2026-03-25T07:15:27.071Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好，目录创建成功了。现在写脚本。我需要写一个Python脚本，使用AKShare（免费开源的A股数据源）来获取数据并按条件筛选。\n\n筛选条件：\n1. PE<25\n2. 股息率>3%\n3. 近30天涨幅<8%\n4. 5日、10日、20日均线多头排列\n5. 今日放量突破20日线\n6. 选出前5名\n\n我会写一个完整的脚本，包括：\n- 获取股票列表（主板非ST股）\n- 获取PE、股息率数据\n- 获取K线数据计算均线\n- 计算成交量放大\n- 筛选符合条件的股票\n- 输出前5名","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_96b63e0df5d9484a8dac2462","name":"write","arguments":{"path":"C:\\Users\\Administrator\\.openclaw\\workspace\\quant-stocks\\stock_screener.py","content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\nA股量化筛选脚本\n策略：\n1. PE<25\n2. 股息率>3%\n3. 近30天涨幅<8%\n4. 5日、10日、20日均线多头排列\n5. 今日放量突破20日线\n6. 选出前5名\n\"\"\"\n\nimport akshare as ak\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime, timedelta\nimport warnings\nwarnings.filterwarnings('ignore')\n\n# ==================== 配置参数 ====================\n# 筛选条件\nPE_THRESHOLD = 25           # PE上限\nDIVIDEND_YIELD_THRESHOLD = 3.0  # 股息率下限(%)\nRISE_30D_THRESHOLD = 8.0    # 30日涨幅上限(%)\nVOLUME_RATIO_THRESHOLD = 1.5 # 成交量放大倍数\nTOP_N = 5                   # 选出前N名\n\n# 均线周期\nMA5_PERIOD = 5\nMA10_PERIOD = 10\nMA20_PERIOD = 20\n\n# ==================== 工具函数 ====================\ndef calculate_ma(df, period):\n    \"\"\"计算移动平均线\"\"\"\n    return df['close'].rolling(window=period).mean()\n\ndef calculate_rsi(df, period=14):\n    \"\"\"计算RSI指标\"\"\"\n    delta = df['close'].diff()\n    gain = (delta.where(delta > 0, 0)).rolling(window=period).mean()\n    loss = (-delta.where(delta < 0, 0)).rolling(window=period).mean()\n    rs = gain / loss\n    rsi = 100 - (100 / (1 + rs))\n    return rsi\n\ndef check_bullish_alignment(ma5, ma10, ma20):\n    \"\"\"检查均线多头排列：5日线 > 10日线 > 20日线\"\"\"\n    latest_idx = -1\n    return (ma5.iloc[latest_idx] > ma10.iloc[latest_idx]) and \\\n           (ma10.iloc[latest_idx] > ma20.iloc[latest_idx])\n\ndef check_volume_breakthrough(df, ma20):\n    \"\"\"检查放量突破20日线\"\"\"\n    latest_idx = -1\n    prev_idx = -2\n\n    # 检查是否突破20日线（今天收盘价 > 昨日20日线，且昨日收盘价 < 昨日20日线）\n    today_close = df['close'].iloc[latest_idx]\n    yesterday_close = df['close'].iloc[prev_idx]\n    yesterday_ma20 = ma20.iloc[prev_idx]\n\n    breakthrough = (today_close > yesterday_ma20) and (yesterday_close < yesterday_ma20)\n\n    # 检查是否放量（今天成交量 > 近5日平均成交量 * 1.5倍）\n    today_volume = df['volume'].iloc[latest_idx]\n    avg_volume_5d = df['volume'].iloc[-6:-1].mean()\n    volume_breakout = today_volume > (avg_volume_5d * VOLUME_RATIO_THRESHOLD)\n\n    return breakthrough and volume_breakout\n\ndef calculate_rise_30d(df):\n    \"\"\"计算近30日涨幅\"\"\"\n    if len(df) < 30:\n        return None\n    close_30d_ago = df['close'].iloc[-30]\n    latest_close = df['close'].iloc[-1]\n    rise_pct = ((latest_close - close_30d_ago) / close_30d_ago) * 100\n    return rise_pct\n\n# ==================== 主函数 ====================\ndef screen_stocks():\n    \"\"\"主筛选函数\"\"\"\n    print(\"=\" * 60)\n    print(\"A股量化筛选系统启动\")\n    print(f\"策略: PE<{PE_THRESHOLD}, 股息率>{DIVIDEND_YIELD_THRESHOLD}%, \"\n          f\"30日涨幅<{RISE_30D_THRESHOLD}%, 均线多头排列, 放量突破20日线\")\n    print(\"=\" * 60)\n    print()\n\n    # 1. 获取A股列表（排除ST股，只保留主板60/00开头）\n    print(\"[1/6] 获取A股股票列表...\")\n    try:\n        stock_list = ak.stock_zh_a_spot_em()\n        # 过滤：主板非ST股（60/00开头，名称不含ST）\n        stock_list = stock_list[\n            (stock_list['代码'].str.startswith(('60', '00'))) &\n            (~stock_list['名称'].str.contains('ST'))\n        ]\n        print(f\"   ✓ 获取到 {len(stock_list)} 只主板非ST股\")\n    except Exception as e:\n        print(f\"   ✗ 获取股票列表失败: {e}\")\n        return []\n\n    # 2. 获取基本面数据（PE、股息率）\n    print(\"[2/6] 获取基本面数据...\")\n    try:\n        # 获取实时行情（包含PE）\n        real_time_data = ak.stock_zh_a_spot_em()\n        # 股息率数据\n        dividend_data = ak.stock_dividend_detail_em()\n\n        # 合并数据\n        stock_list = stock_list.merge(\n            real_time_data[['代码', '最新价', '市盈率-动态', '市盈率-静态', '换手率']],\n            on='代码',\n            how='left'\n        )\n\n        # 处理股息率\n        if not dividend_data.empty:\n            # 计算年度股息率\n            latest_dividend = dividend_data.groupby('股票代码')['每10股派息数'].sum().reset_index()\n            latest_dividend.columns = ['代码', '年度分红(元/10股)']\n            stock_list = stock_list.merge(latest_dividend, on='代码', how='left')\n            # 计算股息率 = (年度分红 / 股价) * 100\n            stock_list['股息率(%)'] = (stock_list['年度分红(元/10股)'] / 10 / stock_list['最新价']) * 100\n        else:\n            stock_list['股息率(%)'] = 0\n\n        print(f\"   ✓ 基本面数据获取完成\")\n    except Exception as e:\n        print(f\"   ✗ 获取基本面数据失败: {e}\")\n        return []\n\n    # 3. 基本面筛选：PE<25, 股息率>3%\n    print(\"[3/6] 基本面筛选...\")\n    filtered_stocks = stock_list[\n        (stock_list['市盈率-动态'] < PE_THRESHOLD) &\n        (stock_list['市盈率-动态'] > 0) &\n        (stock_list['股息率(%)'] > DIVIDEND_YIELD_THRESHOLD)\n    ].copy()\n\n    print(f\"   ✓ 基本面筛选后剩余: {len(filtered_stocks)} 只\")\n    if len(filtered_stocks) == 0:\n        print(\"   → 无符合基本面条件的股票，程序结束\")\n        return []\n\n    # 4. 技术面筛选：获取K线数据\n    print(\"[4/6] 技术面筛选（计算均线、成交量、涨幅）...\")\n    qualified_stocks = []\n\n    total = len(filtered_stocks)\n    for idx, row in filtered_stocks.iterrows():\n        stock_code = row['代码']\n        stock_name = row['名称']\n\n        # 显示进度\n        if idx % 50 == 0 or idx == total - 1:\n            print(f\"   进度: {idx+1}/{total} ({(idx+1)/total*100:.1f}%)\", end='\\r')\n\n        try:\n            # 获取历史K线数据（需要至少30天数据）\n            end_date = datetime.now().strftime('%Y%m%d')\n            start_date = (datetime.now() - timedelta(days=60)).strftime('%Y%m%d')\n\n            stock_hist = ak.stock_zh_a_hist(\n                symbol=stock_code,\n                period=\"daily\",\n                start_date=start_date,\n                end_date=end_date,\n                adjust=\"qfq\"  # 前复权\n            )\n\n            if len(stock_hist) < MA20_PERIOD:\n                continue\n\n            # 计算均线\n            ma5 = calculate_ma(stock_hist, MA5_PERIOD)\n            ma10 = calculate_ma(stock_hist, MA10_PERIOD)\n            ma20 = calculate_ma(stock_hist, MA20_PERIOD)\n\n            # 计算RSI\n            rsi = calculate_rsi(stock_hist, period=14)\n            latest_rsi = rsi.iloc[-1]\n\n            # 检查RSI<70（避免追高）\n            if latest_rsi >= 70:\n                continue\n\n            # 检查均线多头排列\n            if not check_bullish_alignment(ma5, ma10, ma20):\n                continue\n\n            # 检查放量突破20日线\n            if not check_volume_breakthrough(stock_hist, ma20):\n                continue\n\n            # 计算30日涨幅\n            rise_30d = calculate_rise_30d(stock_hist)\n            if rise_30d is None or rise_30d >= RISE_30D_THRESHOLD:\n                continue\n\n            # 所有条件满足，添加到结果\n            qualified_stocks.append({\n                '代码': stock_code,\n                '名称': stock_name,\n                '最新价': row['最新价'],\n                'PE(动态)': row['市盈率-动态'],\n                '股息率(%)': row['股息率(%)'],\n                '30日涨幅(%)': round(rise_30d, 2),\n                'RSI': round(latest_rsi, 2),\n                '5日均线': round(ma5.iloc[-1], 2),\n                '10日均线': round(ma10.iloc[-1], 2),\n                '20日均线': round(ma20.iloc[-1], 2),\n                '今日成交量': stock_hist['volume'].iloc[-1],\n                '评分': 0  # 后续计算\n            })\n\n        except Exception as e:\n            continue\n\n    print(f\"\\n   ✓ 技术面筛选完成，找到 {len(qualified_stocks)} 只符合所有条件的股票\")\n    if len(qualified_stocks) == 0:\n        print(\"   → 无完全符合条件的股票，程序结束\")\n        return []\n\n    # 5. 排序评分（综合评分：股息率高 + PE低 + 涨幅适中）\n    print(\"[5/6] 综合评分排序...\")\n    for stock in qualified_stocks:\n        # 评分规则（100分制）：\n        # - 股息率：越高越好，满分30分\n        # - PE：越低越好，满分30分\n        # - 30日涨幅：适中为好，满分20分（0-5%最优）\n        # - RSI：偏低为好，满分20分（30-50为理想区间）\n\n        dividend_score = min(30, stock['股息率(%)'] * 6)  # 股息率5%得满分\n        pe_score = min(30, (PE_THRESHOLD - stock['PE(动态)']) * 2)  # PE越小越好\n        rise_score = 0\n        if 0 <= stock['30日涨幅(%)'] <= 5:\n            rise_score = 20\n        elif stock['30日涨幅(%)'] < 0:\n            rise_score = 10\n        rsi_score = 0\n        if 30 <= stock['RSI'] <= 50:\n            rsi_score = 20\n        elif 50 < stock['RSI'] < 60:\n            rsi_score = 10\n        elif stock['RSI'] < 30:\n            rsi_score = 5\n\n        stock['评分'] = dividend_score + pe_score + rise_score + rsi_score\n\n    # 按评分排序\n    qualified_stocks.sort(key=lambda x: x['评分'], reverse=True)\n\n    # 6. 输出结果（前N名）\n    print(\"[6/6] 输出筛选结果...\")\n    print()\n    print(\"=\" * 80)\n    print(f\"✓ 筛选完成！推荐前 {TOP_N} 名股票：\")\n    print(\"=\" * 80)\n    print()\n\n    result_df = pd.DataFrame(qualified_stocks[:TOP_N])\n\n    for i, stock in enumerate(qualified_stocks[:TOP_N], 1):\n        print(f\"【第 {i} 名】{stock['代码']} {stock['名称']}\")\n        print(f\"  最新价: ¥{stock['最新价']:.2f}\")\n        print(f\"  PE(动态): {stock['PE(动态)']:.2f}  股息率: {stock['股息率(%)']:.2f}%\")\n        print(f\"  30日涨幅: {stock['30日涨幅(%)']:.2f}%  RSI: {stock['RSI']:.2f}\")\n        print(f\"  均线: 5日={stock['5日均线']:.2f}  10日={stock['10日均线']:.2f}  20日={stock['20日均线']:.2f}\")\n        print(f\"  综合评分: {stock['评分']:.1f}/100\")\n        print()\n\n    # 保存结果到CSV\n    timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')\n    result_df.to_csv(f'stock_selection_{timestamp}.csv', index=False, encoding='utf-8-sig')\n    print(f\"✓ 结果已保存到: stock_selection_{timestamp}.csv\")\n\n    return qualified_stocks[:TOP_N]\n\n# ==================== 风控提醒 ====================\ndef print_risk_warning():\n    \"\"\"风控规则提醒\"\"\"\n    print()\n    print(\"=\" * 80)\n    print(\"⚠️  风控规则（必须严格执行）\")\n    print(\"=\" * 80)\n    print(f\"1. 仓位管理：单票仓位 ≤ 10%，总持仓 ≤ 50%\")\n    print(f\"2. 止盈规则：盈利 ≥ 15% 立即止盈\")\n    print(f\"3. 止损规则：亏损 ≥ 5% 无条件止损\")\n    print(f\"4. 买入策略：5日均线上穿10日均线（金叉）+ 成交量放大1.5倍 + RSI<70\")\n    print(\"=\" * 80)\n    print()\n\n# ==================== 执行 ====================\nif __name__ == \"__main__\":\n    try:\n        # 先安装依赖（如果需要）\n        print(\"检查依赖包...\")\n        import importlib\n        try:\n            import akshare\n        except ImportError:\n            print(\"正在安装 akshare...\")\n            import subprocess\n            subprocess.run(['pip', 'install', 'akshare', 'pandas', 'numpy'], check=True)\n            print(\"✓ 依赖安装完成\\n\")\n\n        # 打印风控提醒\n        print_risk_warning()\n\n        # 执行筛选\n        results = screen_stocks()\n\n        print(\"\\n\" + \"=\" * 80)\n        if results:\n            print(\"✓ 筛选任务完成！请根据推荐名单结合风控规则操作。\")\n        else:\n            print(\"当前市场无符合策略的股票，建议空仓观望。\")\n        print(\"=\" * 80)\n\n    except KeyboardInterrupt:\n        print(\"\\n\\n程序被用户中断\")\n    except Exception as e:\n        print(f\"\\n\\n✗ 程序执行出错: {e}\")\n        import traceback\n        traceback.print_exc()\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":59,"output":3669,"cacheRead":34918,"cacheWrite":0,"totalTokens":38646,"cost":{"input":0.0000354,"output":0.0080718,"cacheRead":0.0038409800000000003,"cacheWrite":0,"total":0.011948180000000001}},"stopReason":"toolUse","timestamp":1774422788791}}
