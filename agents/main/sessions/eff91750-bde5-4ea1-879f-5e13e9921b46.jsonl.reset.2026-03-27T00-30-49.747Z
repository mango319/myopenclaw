# 股息率评分 (0-25分)\n        if dividend_yield > 0:\n            if dividend_yield >= 0.05:  # 5%以上\n                score += 25\n            elif dividend_yield >= 0.03:\n                score += 20\n            elif dividend_yield >= 0.02:\n                score += 15\n            elif dividend_yield >= 0.01:\n                score += 10\n\n        # 换手率评分 (0-15分)\n        if 0.5 <= turnover <= 5:\n            score += 15\n        elif 0.1 <= turnover < 0.5:\n            score += 10\n        elif 5 < turnover <= 10:\n            score += 5\n\n        # 涨跌幅评分 (0-20分，小幅上涨较好)\n        if 0 < change_percent <= 3:\n            score += 20\n        elif -1 < change_percent <= 0:\n\n[190 more lines in file. Use offset=200 to continue.]"}],"isError":false,"timestamp":1774491570791}}
