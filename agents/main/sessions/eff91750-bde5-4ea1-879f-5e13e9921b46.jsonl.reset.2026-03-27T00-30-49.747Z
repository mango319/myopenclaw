\n        params = {\n            \"pn\": 1,\n            \"pz\": 5000,\n            \"po\": 1,\n            \"np\": 1,\n            \"ut\": \"bd1d9ddb04089700cf9c27f6f7426281\",\n            \"fltt\": 2,\n            \"invt\": 2,\n            \"fid\": \"f3\",\n            \"fs\": \"m:0+t:6,m:0+t:80,m:1+t:2,m:1+t:23\",  # 主板\n            \"fields\": \"f12,f14,f2,f3,f4,f5,f6,f7,f8,f9,f10,f11,f13,f15,f16,f17,f18,f20,f21,f23,f24,f25,f22,f33,f11,f62,f128,f136,f115,f152\"\n        }\n        headers = {\n            \"User-Agent\": \"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36\"\n        }\n\n        # 尝试3次\n        for attempt in range(3):\n            try:\n                response = requests.get(\n                    url,\n                    params=params,\n                    headers=headers,\n                    timeout=30,\n                    proxies=proxies\n                )\n                response.raise_for_status()\n                data = response.json()\n\n                if data.get(\"rc\") == 0 and data.get(\"data\"):\n                    stocks = data[\"data\"][\"diff\"]\n                    log(f\"成功获取 {len(stocks)} 只股票\")\n                    return stocks\n                else:\n                    log(f\"API返回异常: {data}\")\n                    return []\n            except Exception as e:\n                log(f\"第 {attempt + 1} 次尝试失败: {e}\")\n                if attempt < 2:\n                    time.sleep(2)\n                    continue\n                else:\n                    raise\n\n    except Exception as e:\n        log(f\"获取股票列表失败: {e}\")\n        return []"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":26,"output":966,"cacheRead":66793,"cacheWrite":0,"totalTokens":67785,"cost":{"input":0.0000156,"output":0.0021252000000000003,"cacheRead":0.007347230000000001,"cacheWrite":0,"total":0.009488030000000001}},"stopReason":"toolUse","timestamp":1774488014223}}
