{"type":"message","id":"af2af498","parentId":"637ddede","timestamp":"2026-03-26T02:19:34.311Z","message":{"role":"toolResult","toolCallId":"call_2c97a00bd5e24d53a50a7112","toolName":"read","content":[{"type":"text","text":"            score += 15\n        elif 3 < change_percent <= 5:\n            score += 10\n        elif -3 < change_percent <= -1:\n            score += 5\n\n        # 流动性评分 (0-10分)\n        if amount > 100000000:  # 1亿以上\n            score += 10\n        elif amount > 50000000:\n            score += 8\n        elif amount > 20000000:\n            score += 5\n\n        return round(score, 2)\n    except Exception as e:\n        log(f\"计算评分失败: {e}\")\n        return 0\n\ndef analyze_stocks(stock_list: List[Dict]) -> List[Dict]:\n    \"\"\"分析股票列表\"\"\"\n    log(\"开始分析股票数据...\")\n    results = []\n\n    for idx, stock in enumerate(stock_list):\n        try:\n            if idx % 100 == 0:\n                log(f\"已处理 {idx}/{len(stock_list)} 只股票...\")\n\n            # 基本面数据\n            pe_ratio = safe_float(stock.get(\"f9\"))  # 市盈率\n            pb_ratio = safe_float(stock.get(\"f10\"))  # 市净率\n            market_cap = safe_float(stock.get(\"f20\"))  # 总市值\n            dividend_yield = (safe_float(stock.get(\"f128\")) / 100) if stock.get(\"f128\") else 0  # 股息率\n\n            # 市场数据\n            price = safe_float(stock.get(\"f2\"))  # 最新价\n            change_percent = safe_float(stock.get(\"f3\"))  # 涨跌幅\n            change_amount = safe_float(stock.get(\"f4\"))  # 涨跌额\n            open_price = safe_float(stock.get(\"f17\"))  # 今开\n            high_price = safe_float(stock.get(\"f15\"))  # 最高\n            low_price = safe_float(stock.get(\"f16\"))  # 最低\n            prev_close = safe_float(stock.get(\"f18\"))  # 昨收\n\n            # 成交数据\n            volume = safe_float(stock.get(\"f6\"))  # 成交量(手)\n            amount = safe_float(stock.get(\"f5\"))  # 成交额\n            turnover = safe_float(stock.get(\"f8\"))  # 换手率\n\n            # 计算技术指标\n            # 均线趋势 (简单判断)\n            ma_trend = \"横盘\"\n            if price > open_price > prev_close:\n                ma_trend = \"上涨\"\n            elif price < open_price < prev_close:\n                ma_trend = \"下跌\"\n\n            # RSI简化估算 (基于涨跌幅)\n            rsi = 50 + change_percent * 10\n            rsi = max(0, min(100, rsi))\n\n            # 综合评分\n            score = calculate_score(stock)\n\n            # 基本信息\n            code = stock.get(\"f12\", \"\")\n            name = stock.get(\"f14\", \"\")\n\n            stock_data = {\n                \"代码\": code,\n                \"名称\": name,\n                \"价格\": round(price, 2) if price else 0,\n                \"涨跌幅\": f\"{change_percent:.2f}%\" if change_percent else \"0.00%\",\n                \"涨跌额\": round(change_amount, 2) if change_amount else 0,\n                \"PE\": round(pe_ratio, 2) if pe_ratio else 0,\n                \"PB\": round(pb_ratio, 2) if pb_ratio else 0,\n                \"股息率\": f\"{dividend_yield:.2%}\" if dividend_yield else \"0.00%\",\n                \"换手率\": f\"{turnover:.2f}%\" if turnover else \"0.00%\",\n                \"成交额\": f\"{amount/100000000:.2f}亿\" if amount > 0 else \"0\",\n                \"总市值\": f\"{market_cap/100000000:.2f}亿\" if market_cap > 0 else \"0\",\n                \"趋势\": ma_trend,\n                \"RSI\": round(rsi, 2),\n                \"评分\": score\n            }\n\n            results.append(stock_data)\n\n        except Exception as e:\n            code = stock.get(\"f12\", \"UNKNOWN\")\n            log(f\"分析股票 {code} 时出错: {e}\")\n            continue\n\n    log(f\"分析完成，共 {len(results)} 只股票\")\n    return results\n\ndef filter_by_market(stocks: List[Dict]) -> List[Dict]:\n    \"\"\"根据市场筛选股票\"\"\"\n    log(f\"正在筛选沪市主板和深市主板股票...\")\n    filtered = []\n    for stock in stocks:\n\n[90 more lines in file. Use offset=300 to continue.]"}],"isError":false,"timestamp":1774491574298}}
