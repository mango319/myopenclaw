{"type":"message","id":"128cd3a1","parentId":"14b9efaa","timestamp":"2026-03-26T00:38:34.534Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"用户回复\"需要\"，意思是需要我启动股票分析程序。让我看看能不能帮他创建一个Python脚本来分析A股股票数据。\n\n我需要：\n1. 创建一个脚本来获取A股数据\n2. 分析基本面（PE、股息率等）\n3. 计算技术指标（均线、RSI、成交量）\n4. 筛选和排序\n\n由于A股数据比较特殊，可能需要用到tushare库或者其他API。让我先创建一个脚本框架，然后后台运行。\n\n我会：\n1. 创建一个Python脚本\n2. 在后台运行它\n3. 稍后检查结果\n\n让我开始吧。","thinkingSignature":"reasoning_content"},{"type":"text","text":"好！我现在帮你启动A股分析程序 🚀"},{"type":"toolCall","id":"call_b43b1b1653414dbea324d4fa","name":"write","arguments":{"path":"C:\\Users\\Administrator\\.openclaw\\workspace\\stock_analysis.py","content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\nA股主板股票基本面+技术面综合分析\n筛选低PE、高股息、技术面良好的股票\n\"\"\"\n\nimport requests\nimport json\nimport time\nimport math\nfrom datetime import datetime\nfrom typing import List, Dict, Any\nimport statistics\n\n# 配置\nOUTPUT_FILE = \"stock_analysis_results.json\"\nLOG_FILE = \"stock_analysis.log\"\n\ndef log(message: str):\n    \"\"\"记录日志\"\"\"\n    timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n    line = f\"[{timestamp}] {message}\"\n    print(line)\n    with open(LOG_FILE, \"a\", encoding=\"utf-8\") as f:\n        f.write(line + \"\\n\")\n\ndef get_stock_list() -> List[Dict]:\n    \"\"\"获取A股主板股票列表\"\"\"\n    log(\"正在获取A股主板股票列表...\")\n    try:\n        # 使用东方财富网的股票列表API\n        url = \"https://80.push2.eastmoney.com/api/qt/clist/get\"\n        params = {\n            \"pn\": 1,\n            \"pz\": 5000,\n            \"po\": 1,\n            \"np\": 1,\n            \"ut\": \"bd1d9ddb04089700cf9c27f6f7426281\",\n            \"fltt\": 2,\n            \"invt\": 2,\n            \"fid\": \"f3\",\n            \"fs\": \"m:0+t:6,m:0+t:80,m:1+t:2,m:1+t:23\",  # 主板\n            \"fields\": \"f12,f14,f2,f3,f4,f5,f6,f7,f8,f9,f10,f11,f13,f15,f16,f17,f18,f20,f21,f23,f24,f25,f22,f33,f11,f62,f128,f136,f115,f152\"\n        }\n        headers = {\n            \"User-Agent\": \"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36\"\n        }\n\n        response = requests.get(url, params=params, headers=headers, timeout=30)\n        response.raise_for_status()\n        data = response.json()\n\n        if data.get(\"rc\") == 0 and data.get(\"data\"):\n            stocks = data[\"data\"][\"diff\"]\n            log(f\"成功获取 {len(stocks)} 只股票\")\n            return stocks\n        else:\n            log(f\"API返回异常: {data}\")\n            return []\n    except Exception as e:\n        log(f\"获取股票列表失败: {e}\")\n        return []\n\ndef calculate_score(stock: Dict) -> float:\n    \"\"\"\n    综合评分 (0-100)\n    考虑因素:\n    - PE比率 (越低越好)\n    - 股息率 (越高越好)\n    - 换手率 (适中为宜)\n    - 涨跌幅\n    - 成交额\n    \"\"\"\n    try:\n        pe_ratio = stock.get(\"f9\", 0)  # 市盈率\n        dividend_yield = stock.get(\"f128\", 0) / 100 if stock.get(\"f128\") else 0  # 股息率\n        change_percent = stock.get(\"f3\", 0)  # 涨跌幅\n        turnover = stock.get(\"f8\", 0)  # 换手率\n        amount = stock.get(\"f5\", 0)  # 成交额\n        volume = stock.get(\"f6\", 0)  # 成交量\n\n        score = 50  # 基准分\n\n        # PE评分 (0-30分)\n        if pe_ratio > 0 and pe_ratio < 100:\n            if pe_ratio < 10:\n                score += 30\n            elif pe_ratio < 20:\n                score += 25\n            elif pe_ratio < 30:\n                score += 20\n            elif pe_ratio < 50:\n                score += 10\n\n        # 股息率评分 (0-25分)\n        if dividend_yield > 0:\n            if dividend_yield >= 0.05:  # 5%以上\n                score += 25\n            elif dividend_yield >= 0.03:\n                score += 20\n            elif dividend_yield >= 0.02:\n                score += 15\n            elif dividend_yield >= 0.01:\n                score += 10\n\n        # 换手率评分 (0-15分)\n        if 0.5 <= turnover <= 5:\n            score += 15\n        elif 0.1 <= turnover < 0.5:\n            score += 10\n        elif 5 < turnover <= 10:\n            score += 5\n\n        # 涨跌幅评分 (0-20分，小幅上涨较好)\n        if 0 < change_percent <= 3:\n            score += 20\n        elif -1 < change_percent <= 0:\n            score += 15\n        elif 3 < change_percent <= 5:\n            score += 10\n        elif -3 < change_percent <= -1:\n            score += 5\n\n        # 流动性评分 (0-10分)\n        if amount > 100000000:  # 1亿以上\n            score += 10\n        elif amount > 50000000:\n            score += 8\n        elif amount > 20000000:\n            score += 5\n\n        return round(score, 2)\n    except Exception as e:\n        log(f\"计算评分失败: {e}\")\n        return 0\n\ndef analyze_stocks(stock_list: List[Dict]) -> List[Dict]:\n    \"\"\"分析股票列表\"\"\"\n    log(\"开始分析股票数据...\")\n    results = []\n\n    for idx, stock in enumerate(stock_list):\n        try:\n            if idx % 100 == 0:\n                log(f\"已处理 {idx}/{len(stock_list)} 只股票...\")\n\n            # 基本面数据\n            pe_ratio = stock.get(\"f9\", 0)  # 市盈率\n            pb_ratio = stock.get(\"f10\", 0)  # 市净率\n            market_cap = stock.get(\"f20\", 0)  # 总市值\n            dividend_yield = stock.get(\"f128\", 0) / 100 if stock.get(\"f128\") else 0  # 股息率\n\n            # 市场数据\n            price = stock.get(\"f2\", 0)  # 最新价\n            change_percent = stock.get(\"f3\", 0)  # 涨跌幅\n            change_amount = stock.get(\"f4\", 0)  # 涨跌额\n            open_price = stock.get(\"f17\", 0)  # 今开\n            high_price = stock.get(\"f15\", 0)  # 最高\n            low_price = stock.get(\"f16\", 0)  # 最低\n            prev_close = stock.get(\"f18\", 0)  # 昨收\n\n            # 成交数据\n            volume = stock.get(\"f6\", 0)  # 成交量(手)\n            amount = stock.get(\"f5\", 0)  # 成交额\n            turnover = stock.get(\"f8\", 0)  # 换手率\n\n            # 计算技术指标\n            # 均线趋势 (简单判断)\n            ma_trend = \"横盘\"\n            if price > open_price > prev_close:\n                ma_trend = \"上涨\"\n            elif price < open_price < prev_close:\n                ma_trend = \"下跌\"\n\n            # RSI简化估算 (基于涨跌幅)\n            rsi = 50 + change_percent * 10\n            rsi = max(0, min(100, rsi))\n\n            # 综合评分\n            score = calculate_score(stock)\n\n            # 基本信息\n            code = stock.get(\"f12\", \"\")\n            name = stock.get(\"f14\", \"\")\n\n            stock_data = {\n                \"代码\": code,\n                \"名称\": name,\n                \"价格\": round(price, 2) if price else 0,\n                \"涨跌幅\": f\"{change_percent:.2f}%\" if change_percent else \"0.00%\",\n                \"涨跌额\": round(change_amount, 2) if change_amount else 0,\n                \"PE\": round(pe_ratio, 2) if pe_ratio else 0,\n                \"PB\": round(pb_ratio, 2) if pb_ratio else 0,\n                \"股息率\": f\"{dividend_yield:.2%}\" if dividend_yield else \"0.00%\",\n                \"换手率\": f\"{turnover:.2f}%\" if turnover else \"0.00%\",\n                \"成交额\": f\"{amount/100000000:.2f}亿\" if amount > 0 else \"0\",\n                \"总市值\": f\"{market_cap/100000000:.2f}亿\" if market_cap > 0 else \"0\",\n                \"趋势\": ma_trend,\n                \"RSI\": round(rsi, 2),\n                \"评分\": score\n            }\n\n            results.append(stock_data)\n\n        except Exception as e:\n            code = stock.get(\"f12\", \"UNKNOWN\")\n            log(f\"分析股票 {code} 时出错: {e}\")\n            continue\n\n    log(f\"分析完成，共 {len(results)} 只股票\")\n    return results\n\ndef filter_and_sort(stocks: List[Dict], top_n: int = 50) -> List[Dict]:\n    \"\"\"筛选并排序\"\"\"\n    log(\"正在筛选和排序...\")\n\n    # 筛选条件\n    filtered = [s for s in stocks if s[\"PE\"] > 0 and s[\"PE\"] < 100]\n\n    # 按评分排序\n    sorted_stocks = sorted(filtered, key=lambda x: x[\"评分\"], reverse=True)\n\n    # 返回前N只\n    return sorted_stocks[:top_n]\n\ndef save_results(stocks: List[Dict], filename: str):\n    \"\"\"保存结果\"\"\"\n    log(f\"正在保存结果到 {filename}...\")\n    with open(filename, \"w\", encoding=\"utf-8\") as f:\n        json.dump(stocks, f, ensure_ascii=False, indent=2)\n    log(f\"结果已保存\")\n\ndef format_summary(stocks: List[Dict]) -> str:\n    \"\"\"格式化摘要\"\"\"\n    if not stocks:\n        return \"没有符合条件的股票\"\n\n    summary = \"\\n\" + \"=\"*80 + \"\\n\"\n    summary += f\"{'排名':<6}{'代码':<10}{'名称':<10}{'价格':<10}{'涨跌幅':<10}{'PE':<8}{'股息率':<10}{'评分':<8}\\n\"\n    summary += \"-\"*80 + \"\\n\"\n\n    for idx, stock in enumerate(stocks[:30], 1):\n        summary += f\"{idx:<6}{stock['代码']:<10}{stock['名称']:<10}{stock['价格']:<10}{stock['涨跌幅']:<10}{stock['PE']:<8}{stock['股息率']:<10}{stock['评分']:<8}\\n\"\n\n    summary += \"=\"*80 + \"\\n\"\n    summary += f\"\\n统计信息:\\n\"\n    summary += f\"  - 分析股票总数: {len(stocks)}\\n\"\n    summary += f\"  - 平均PE: {statistics.mean([s['PE'] for s in stocks if s['PE'] > 0]):.2f}\\n\"\n    summary += f\"  - 平均评分: {statistics.mean([s['评分'] for s in stocks]):.2f}\\n\"\n\n    return summary\n\ndef main():\n    \"\"\"主函数\"\"\"\n    log(\"=\"*60)\n    log(\"A股股票分析程序启动\")\n    log(\"=\"*60)\n\n    start_time = time.time()\n\n    # 1. 获取股票列表\n    stock_list = get_stock_list()\n    if not stock_list:\n        log(\"未获取到股票数据，退出程序\")\n        return\n\n    # 2. 分析股票\n    analyzed = analyze_stocks(stock_list)\n\n    # 3. 筛选排序\n    top_stocks = filter_and_sort(analyzed, top_n=50)\n\n    # 4. 保存结果\n    save_results(top_stocks, OUTPUT_FILE)\n\n    # 5. 打印摘要\n    summary = format_summary(top_stocks)\n    print(summary)\n\n    # 6. 记录到日志\n    with open(LOG_FILE, \"a\", encoding=\"utf-8\") as f:\n        f.write(summary + \"\\n\")\n\n    elapsed = time.time() - start_time\n    log(f\"\\n程序运行完成！耗时: {elapsed:.2f}秒\")\n    log(\"=\"*60)\n\nif __name__ == \"__main__\":\n    main()\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":1202,"output":3060,"cacheRead":16305,"cacheWrite":0,"totalTokens":20567,"cost":{"input":0.0007212,"output":0.006732,"cacheRead":0.00179355,"cacheWrite":0,"total":0.00924675}},"stopReason":"toolUse","timestamp":1774485478548}}
