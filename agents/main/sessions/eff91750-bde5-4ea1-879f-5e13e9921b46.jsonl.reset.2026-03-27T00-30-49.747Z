"secid\": f\"0.{code}\" if code.startswith(\"6\") else f\"1.{code}\",  # 沪市0，深市1\n            \"fields1\": \"f1,f2,f3,f4,f5,f6,f7,f8,f9,f10,f11,f12,f13,f14,f15,f16,f17,f18,f19,f20\",\n            \"ut\": \"bd1d9ddb04089700cf9c27f6f7426281\",\n            \"fltt\": 2\n        }\n        headers = {\n            \"User-Agent\": \"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36\"\n        }\n\n        proxies = {\n            'http': None,\n            'https': None,\n        }\n\n        response = requests.get(url, params=params, headers=headers, timeout=30, proxies=proxies)\n        response.raise_for_status()\n        data = response.json()\n\n        if data.get(\"rc\") == 0 and data.get(\"data\"):\n            financial = data[\"data\"]\n            # 解析财务数据\n            # 假设API返回的数据是数组或字典\n            if isinstance(financial, list) and len(financial) > 0:\n                financial = financial[0]\n\n            # 返回营业收入和净利润同比增长率\n            return {\n                \"营业收入\": safe_float(financial.get(\"营业收入\") or financial.get(\"f1\"), 0),\n                \"净利润同比增长率\": safe_float(financial.get(\"净利润同比增长\") or financial.get(\"f3\"), 0),\n            }\n        else:\n            return {}\n\n    except Exception as e:\n        log(f\"获取 {code} 财务数据失败: {e}\")\n        return {\"营业收入\": 0, \"净利润同比增长率\": 0}"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":26,"output":940,"cacheRead":90023,"cacheWrite":0,"totalTokens":90989,"cost":{"input":0.0000156,"output":0.002068,"cacheRead":0.00990253,"cacheWrite":0,"total":0.01198613}},"stopReason":"toolUse","timestamp":1774491722382}}
