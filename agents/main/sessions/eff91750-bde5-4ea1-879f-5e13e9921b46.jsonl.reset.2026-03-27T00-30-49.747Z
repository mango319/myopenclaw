: revenue,\n                \"净利润同比增长率\": net_profit_growth\n            }\n        else:\n            return {\"营业收入\": 0, \"净利润同比增长率\": 0}\n\n    except Exception as e:\n        log(f\"获取 {code} 财务数据失败: {e}\")\n        return {\"营业收入\": 0, \"净利润同比增长率\": 0}\n\ndef get_stock_list() -> List[Dict]:"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":426,"output":606,"cacheRead":133051,"cacheWrite":0,"totalTokens":134083,"cost":{"input":0.0002556,"output":0.0013332,"cacheRead":0.01463561,"cacheWrite":0,"total":0.01622441}},"stopReason":"toolUse","timestamp":1774496563637}}
