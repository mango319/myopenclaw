{"type":"message","id":"c9d13cb3","parentId":"545edb88","timestamp":"2026-03-26T03:47:16.027Z","message":{"role":"toolResult","toolCallId":"call_9799a58d35604b3a85663152","toolName":"read","content":[{"type":"text","text":"        elif net_profit_growth >= 30:  # 30%以上\n            score += 30\n        elif net_profit_growth >= 20:  # 20%以上\n            score += 25\n        elif net_profit_growth >= 10:  # 10%以上\n            score += 15\n        elif net_profit_growth > 0:  # 正增长\n            score += 10\n\n        # PE评分 (0-30分)\n        if pe_ratio > 0 and pe_ratio < 100:\n            if pe_ratio < 10:\n                score += 30\n            elif pe_ratio < 20:\n                score += 25\n            elif pe_ratio < 30:\n                score += 20\n            elif pe_ratio < 50:\n                score += 10\n\n        # 股息率评分 (0-25分)\n        if dividend_yield > 0:\n            if dividend_yield >= 0.05:  # 5%以上\n                score += 25\n            elif dividend_yield >= 0.03:\n                score += 20\n            elif dividend_yield >= 0.02:\n                score += 15\n            elif dividend_yield >= 0.01:\n                score += 10\n\n        # 换手率评分 (0-15分)\n        if 0.5 <= turnover <= 5:\n            score += 15\n        elif 0.1 <= turnover < 0.5:\n            score += 10\n        elif 5 < turnover <= 10:\n            score += 5\n\n        # 涨跌幅评分 (0-20分，小幅上涨较好)\n        if 0 < change_percent <= 3:\n            score += 20\n        elif -1 < change_percent <= 0:\n            score += 15\n        elif 3 < change_percent <= 5:\n            score += 10\n        elif -3 < change_percent <= -1:\n            score += 5\n\n        # 流动性评分 (0-10分)\n        if amount > 100000000:  # 1亿以上\n            score += 10\n        elif amount > 50000000:\n            score += 8\n        elif amount > 20000000:\n            score += 5\n\n        return round(score, 2)\n    except Exception as e:\n        log(f\"计算评分失败: {e}\")\n        return 0\n\ndef analyze_stocks(stock_list: List[Dict]) -> List[Dict]:\n    \"\"\"分析股票列表\"\"\"\n    log(\"开始分析股票数据...\")\n    results = []\n\n    for idx, stock in enumerate(stock_list):\n        try:\n            if idx % 100 == 0:\n                log(f\"已处理 {idx}/{len(stock_list)} 只股票...\")\n\n            # 基本面数据\n            pe_ratio = safe_float(stock.get(\"f9\"))  # 市盈率\n            pb_ratio = safe_float(stock.get(\"f10\"))  # 市净率\n            market_cap = safe_float(stock.get(\"f20\"))  # 总市值\n            dividend_yield = (safe_float(stock.get(\"f128\")) / 100) if stock.get(\"f128\") else 0  # 股息率\n\n            # 市场数据\n            price = safe_float(stock.get(\"f2\"))  # 最新价\n\n[174 more lines in file. Use offset=225 to continue.]"}],"isError":false,"timestamp":1774496836013}}
