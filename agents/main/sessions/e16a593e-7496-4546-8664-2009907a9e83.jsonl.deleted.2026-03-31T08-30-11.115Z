{"type":"message","id":"e1cea106","parentId":"7d9bb3a7","timestamp":"2026-03-30T08:26:12.946Z","message":{"role":"toolResult","toolCallId":"call_59dccd7fa2d94c0b95e12d56","toolName":"exec","content":[{"type":"text","text":"����λ�� ��:1 �ַ�: 47\r\n+ cd ~/.openclaw/skills/follow-builders/scripts && node prepare-digest. ...\r\n+                                               ~~\r\n��ǡ�&&�����Ǵ˰汾�е���Ч���ָ�����\r\n    + CategoryInfo          : ParserError: (:) [], ParentContainsErrorRecordException\r\n    + FullyQualifiedErrorId : InvalidEndOfLine\n\n(Command exited with code 1)"}],"details":{"status":"completed","exitCode":1,"durationMs":2277,"aggregated":"����λ�� ��:1 �ַ�: 47\r\n+ cd ~/.openclaw/skills/follow-builders/scripts && node prepare-digest. ...\r\n+                                               ~~\r\n��ǡ�&&�����Ǵ˰汾�е���Ч���ָ�����\r\n    + CategoryInfo          : ParserError: (:) [], ParentContainsErrorRecordException\r\n    + FullyQualifiedErrorId : InvalidEndOfLine\n\n(Command exited with code 1)","cwd":"C:\\Users\\Administrator\\.openclaw\\workspace"},"isError":false,"timestamp":1774859172945}}
