{"type":"message","id":"7a4ef62e","parentId":"58da3bdc","timestamp":"2026-03-23T03:03:41.664Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"看来Python进程都没有在运行了。脚本可能已经完成但没有输出，或者执行时出错了。由于命令行窗口可能无法直接看到输出，让我直接创建一个更简单的版本，不依赖akshare，而是模拟一些数据来测试整个流程。","thinkingSignature":"reasoning_content"},{"type":"text","text":"脚本似乎没有产生输出。可能是akshare数据获取有问题。让我创建一个模拟数据测试版本："},{"type":"toolCall","id":"call_36b9dc90ba3a4dab80de2d39","name":"write","arguments":{"content":"\"\"\"\n模拟数据测试 - 不依赖akshare\n用于验证整个扫描流程\n\"\"\"\n\nimport pandas as pd\nimport json\nfrom datetime import datetime\nimport random\n\nprint(\"=\"*60)\nprint(\"模拟数据测试 - 验证扫描流程\")\nprint(\"=\"*60)\n\n# 模拟主板非ST股票数据\ndef generate_mock_data(num_stocks=100):\n    codes = []\n    names = []\n\n    # 生成主板代码（60xxx）\n    for i in range(num_stocks):\n        code = f\"60{50001 + i:05d}\"\n        codes.append(code)\n        names.append(f\"模拟公司{i:02d}\")\n\n    return codes, names\n\n# 生成历史数据\ndef generate_price_data(base_price, num_days=60):\n    import numpy as np\n\n    # 随机游走生成价格\n    returns = np.random.normal(0.02, 0.03, num_days)\n    prices = [base_price]\n    for ret in returns:\n        prices.append(prices[-1] * (1 + ret))\n\n    # 生成成交量\n    base_volume = random.randint(10000000, 100000000)\n    volumes = [base_volume * random.uniform(0.5, 2.0) for _ in range(num_days)]\n\n    # 生成日期\n    from datetime import datetime, timedelta\n    dates = [(datetime.now() - timedelta(days=i)).strftime('%Y%m%d') for i in range(num_days, 0, -1)]\n\n    df = pd.DataFrame({\n        '日期': dates,\n        'close': prices,\n        'volume': volumes\n    })\n    df = df.sort_values('日期').reset_index(drop=True)\n\n    return df\n\n# 扫描股票\ndef scan_stocks():\n    print(\"\\n开始模拟扫描...\")\n\n    codes, names = generate_mock_data(num_stocks=20)\n    print(f\"模拟股票数量: {len(codes)}\")\n\n    candidates = []\n\n    for code, name in zip(codes, names):\n        try:\n            # 生成价格数据\n            base_price = random.uniform(5, 100)\n            df = generate_price_data(base_price)\n\n            # 计算指标\n            df['MA5'] = df['close'].rolling(window=5).mean()\n            df['MA10'] = df['close'].rolling(window=10).mean()\n            df['AvgVolume'] = df['volume'].rolling(window=20).mean()\n            df['VolumeRatio'] = df['volume'] / df['AvgVolume']\n\n            latest = df.iloc[-1]\n            prev = df.iloc[-2]\n\n            # 金叉检查\n            ma5_golden = (prev['MA5'] < prev['MA10']) and (latest['MA5'] > latest['MA10'])\n\n            # 成交量检查\n            vol_ok = latest['VolumeRatio'] >= 1.5\n\n            # RSI计算\n            delta = df['close'].diff()\n            gain = (delta.where(delta > 0, 0)).rolling(window=14).mean()\n            loss = (-delta.where(delta < 0, 0)).rolling(window=14).mean()\n            rs = gain / loss\n            rsi = 100 - (100 / (1 + rs))\n            rsi_ok = rsi.iloc[-1] < 70\n\n            if ma5_golden and vol_ok and rsi_ok:\n                candidates.append({\n                    'code': code,\n                    'name': name,\n                    'close': latest['close'],\n                    'change': random.uniform(-5, 5),\n                    'ma5': latest['MA5'],\n                    'ma10': latest['MA10'],\n                    'volume_ratio': latest['VolumeRatio'],\n                    'rsi': rsi.iloc[-1]\n                })\n\n        except Exception as e:\n            continue\n\n    print(f\"扫描完成！找到 {len(candidates)} 个候选\")\n\n    return candidates\n\n# 主函数\ndef main():\n    print(f\"模拟数据测试 - {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n\n    candidates = scan_stocks()\n\n    if candidates:\n        print(\"\\n【候选股票列表】\")\n        print(f\"{'代码':<10} {'名称':<15} {'现价':<10} {'涨跌幅':<10} {'量比':<10} {'RSI':<10}\")\n        print(\"-\"*80)\n\n        for stock in candidates:\n            print(f\"{stock['code']:<10} {stock['name']:<15} {stock['close']:<10.2f} {stock['change']:>8.2f}% {stock['volume_ratio']:.2f} {stock['rsi']:.1f}\")\n\n        # 保存结果\n        df = pd.DataFrame(candidates)\n        df.to_csv('mock_scan_results.csv', index=False, encoding='utf-8-sig')\n        print(f\"\\n模拟扫描结果已保存到：mock_scan_results.csv\")\n\n        # 同时保存JSON\n        with open('mock_scan_results.json', 'w', encoding='utf-8') as f:\n            json.dump(candidates, f, ensure_ascii=False, indent=2)\n\n    else:\n        print(\"\\n未找到符合条件的候选股票\")\n\n    print(\"\\n\" + \"=\"*60)\n    print(\"测试完成！\")\n    print(\"=\"*60)\n\nif __name__ == \"__main__\":\n    main()\n","path":"C:\\Users\\Administrator\\.openclaw\\workspace\\test_mock.py"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":137213,"output":1293,"cacheRead":0,"cacheWrite":0,"totalTokens":138506,"cost":{"input":0.08232779999999999,"output":0.0028446,"cacheRead":0,"cacheWrite":0,"total":0.0851724}},"stopReason":"toolUse","timestamp":1774234977373}}
