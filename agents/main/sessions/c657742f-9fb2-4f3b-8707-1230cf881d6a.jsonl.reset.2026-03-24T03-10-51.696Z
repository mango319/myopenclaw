{"type":"message","id":"19f62a6a","parentId":"4fea5c34","timestamp":"2026-03-23T04:29:49.683Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"命令执行失败，看起来PowerShell的Where-Object语法有问题。让我尝试更简单的方法，直接读取文件内容。","thinkingSignature":"reasoning_content"},{"type":"text","text":"让我创建一个简化版本来测试akshare并显示结果："},{"type":"toolCall","id":"call_3cafddb779c94d2d84850114","name":"write","arguments":{"content":"\"\"\"\n简化版akshare测试 - 直接显示输出\n\"\"\"\nimport akshare as ak\n\nprint(\"=\"*60)\nprint(\"akshare数据源连接测试\")\nprint(\"=\"*60)\n\ntry:\n    # 1. 测试获取股票列表\n    print(\"\\n[步骤1] 获取主板非ST股票列表...\")\n    stocks = ak.stock_info_a_code_name()\n    print(f\"总股票数: {len(stocks)}\")\n\n    # 筛选主板\n    main_board = stocks[\n        (stocks['code'].str.startswith('60') | stocks['code'].str.startswith('00'))\n    ]\n    print(f\"主板股票数: {len(main_board)}\")\n\n    # 排除ST\n    non_st = main_board[\n        (~main_board['name'].str.contains('ST'))\n    ]\n    print(f\"主板非ST股票数: {len(non_st)}\")\n\n    # 显示前10只\n    print(\"\\n前10只主板非ST股票:\")\n    print(non_st.head(10)[['code', 'name']])\n\n    # 2. 测试获取历史数据（第1只）\n    if len(non_st) > 0:\n        test_code = non_st.iloc[0]['code']\n        test_name = non_st.iloc[0]['name']\n\n        print(f\"\\n[步骤2] 测试获取 {test_code}({test_name}) 历史数据...\")\n\n        from datetime import datetime, timedelta\n        end_date = datetime.now().strftime('%Y%m%d')\n        start_date = (datetime.now() - timedelta(days=60)).strftime('%Y%m%d')\n\n        print(f\"数据范围: {start_date} ~ {end_date}\")\n\n        df = ak.stock_zh_a_hist(\n            symbol=test_code,\n            period=\"daily\",\n            start_date=start_date,\n            end_date=end_date,\n            adjust=\"qfq\"\n        )\n\n        print(f\"数据点数: {len(df)}\")\n        print(f\"数据列: {list(df.columns)}\")\n\n        # 显示最后5行\n        print(\"\\n最后5个交易日数据:\")\n        print(df[['日期', '收盘', '成交量']].tail())\n\n        # 3. 测试技术指标计算\n        print(\"\\n[步骤3] 计算技术指标...\")\n\n        df['MA5'] = df['收盘'].rolling(window=5).mean()\n        df['MA10'] = df['收盘'].rolling(window=10).mean()\n        df['AvgVolume'] = df['成交量'].rolling(window=20).mean()\n        df['VolumeRatio'] = df['成交量'] / df['AvgVolume']\n\n        latest = df.iloc[-1]\n        prev = df.iloc[-2]\n\n        # 金叉\n        ma5_golden = (prev['MA5'] < prev['MA10']) and (latest['MA5'] > latest['MA10'])\n\n        # 成交量\n        vol_ratio = latest['VolumeRatio']\n\n        # RSI\n        delta = df['收盘'].diff()\n        gain = (delta.where(delta > 0, 0)).rolling(window=14).mean()\n        loss = (-delta.where(delta < 0, 0)).rolling(window=14).mean()\n        rs = gain / loss\n        rsi = 100 - (100 / (1 + rs))\n        latest_rsi = rsi.iloc[-1]\n\n        print(f\"MA5: {latest['MA5']:.2f}, MA10: {latest['MA10']:.2f}\")\n        print(f\"金叉: {'是' if ma5_golden else '否'}\")\n        print(f\"成交量比: {vol_ratio:.2f}\")\n        print(f\"RSI: {latest_rsi:.2f}\")\n\n        # 判断是否满足条件\n        print(\"\\n[步骤4] 检查买入条件...\")\n\n        golden_ok = ma5_golden\n        vol_ok = vol_ratio >= 1.5\n        rsi_ok = not pd.isna(latest_rsi) and latest_rsi < 70\n\n        print(f\"金叉条件: {'✅' if golden_ok else '❌'}\")\n        print(f\"成交量条件(≥1.5倍): {'✅' if vol_ok else '❌'} ({vol_ratio:.2f})\")\n        print(f\"RSI条件(<70): {'✅' if rsi_ok else '❌'} ({latest_rsi:.2f})\")\n\n        all_ok = golden_ok and vol_ok and rsi_ok\n\n        print(f\"\\n是否满足全部条件: {'✅ 是' if all_ok else '❌ 否'}\")\n\n        if all_ok:\n            print(f\"\\n🎯 找到候选股票：{test_code} {test_name}\")\n            print(f\"现价: {latest['收盘']:.2f}\")\n            print(f\"信号: MA5({latest['MA5']:.2f}) > MA10({latest['MA10']:.2f}) 金叉 + 放量({vol_ratio:.2f}倍) + RSI({latest_rsi:.2f})\")\n        else:\n            print(f\"\\n❌ 不满足条件\")\n\n    print(\"\\n\" + \"=\"*60)\n    print(\"测试完成！\")\n\nexcept Exception as e:\n    print(f\"\\n❌ 错误: {e}\")\n    import traceback\n    traceback.print_exc()\n","path":"C:\\Users\\Administrator\\.openclaw\\workspace\\simple_akshare_test.py"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":137213,"output":1228,"cacheRead":0,"cacheWrite":0,"totalTokens":138441,"cost":{"input":0.08232779999999999,"output":0.0027016,"cacheRead":0,"cacheWrite":0,"total":0.08502939999999999}},"stopReason":"toolUse","timestamp":1774240154426}}
