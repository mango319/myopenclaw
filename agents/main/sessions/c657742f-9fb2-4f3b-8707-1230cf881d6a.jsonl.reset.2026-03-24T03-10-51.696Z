{"type":"message","id":"2d49e90e","parentId":"b621d8e9","timestamp":"2026-03-23T05:41:40.149Z","message":{"role":"toolResult","toolCallId":"call_072c0f9c6c1e41a88e0f288e","toolName":"exec","content":[{"type":"text","text":"============================================================\r\nA���������� - tushare�汾\r\n============================================================\r\nTraceback (most recent call last):\r\n  File \"C:\\Users\\Administrator\\.openclaw\\workspace\\quant_scanner_tushare.py\", line 316, in <module>\r\n    main()\r\n  File \"C:\\Users\\Administrator\\.openclaw\\workspace\\quant_scanner_tushare.py\", line 284, in main\r\n    print(\"\\n\\u26a0\\ufe0f ��Ҫ����Ҫ���� tushare token\")\r\nUnicodeEncodeError: 'gbk' codec can't encode character '\\u26a0' in position 2: illegal multibyte sequence\n\n(Command exited with code 1)"}],"details":{"status":"completed","exitCode":1,"durationMs":2559,"aggregated":"============================================================\r\nA���������� - tushare�汾\r\n============================================================\r\nTraceback (most recent call last):\r\n  File \"C:\\Users\\Administrator\\.openclaw\\workspace\\quant_scanner_tushare.py\", line 316, in <module>\r\n    main()\r\n  File \"C:\\Users\\Administrator\\.openclaw\\workspace\\quant_scanner_tushare.py\", line 284, in main\r\n    print(\"\\n\\u26a0\\ufe0f ��Ҫ����Ҫ���� tushare token\")\r\nUnicodeEncodeError: 'gbk' codec can't encode character '\\u26a0' in position 2: illegal multibyte sequence\n\n(Command exited with code 1)","cwd":"C:\\Users\\Administrator\\.openclaw\\workspace"},"isError":false,"timestamp":1774244500139}}
{"type":"message","id":"c4105f2e","parentId":"2d49e90e","timestamp":"2026-03-23T05:43:18.065Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"遇到了 Unicode 编码问题（Windows 控制台 GBK 无法显示 emoji）。让我创建一个修复版本的脚本，避免使用 emoji。","thinkingSignature":"reasoning_content"},{"type":"text","text":"编码问题！让我创建一个修复版本，避免使用 emoji："},{"type":"toolCall","id":"call_55ea7e3792b247febc8f3382","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\ntushare version quant scanner (no emoji to avoid encoding issues)\n\"\"\"\n\nimport tushare as ts\nimport pandas as pd\nfrom datetime import datetime, timedelta\nimport sys\nimport io\nfrom contextlib import redirect_stdout\n\n# =================== Configuration ===================\n\nTOTAL_CAPITAL = 50000\nSINGLE_STOCK_MAX_RATIO = 0.20\nTOTAL_MAX_POSITION = 0.80\nTAKE_PROFIT_RATIO = 0.15\nSTOP_LOSS_RATIO = 0.05\nMA5_PERIOD = 5\nMA10_PERIOD = 10\nVOLUME_MULTIPLIER = 1.5\nRSI_MAX = 70\n\nTUSHARE_TOKEN = \"your_token_here\"\n\nPOSITION_FILE = \"quant_positions_tushare.json\"\nSCAN_RESULT_FILE = \"scan_results_tushare.csv\"\n\n# =================== Core Classes ===================\n\nclass TushareStrategy:\n    \"\"\"Tushare quant strategy\"\"\"\n\n    def __init__(self):\n        # Init tushare token\n        if TUSHARE_TOKEN and TUSHARE_TOKEN != \"your_token_here\":\n            self.pro_api = ts.pro_api(token=TUSHARE_TOKEN)\n        else:\n            self.pro_api = ts.pro_api()\n        self.positions = {}\n        self.load_positions()\n\n    def calculate_rsi(self, prices, period=14):\n        \"\"\"Calculate RSI\"\"\"\n        delta = prices.diff()\n        gain = (delta.where(delta > 0, 0)).rolling(window=period).mean()\n        loss = (-delta.where(delta < 0, 0)).rolling(window=period).mean()\n        rs = gain / loss\n        rsi = 100 - (100 / (1 + rs))\n        return rsi\n\n    def check_buy_signal(self, df):\n        \"\"\"Check buy conditions\"\"\"\n        if df is None or len(df) < 10:\n            return False, \"Not enough data\"\n\n        latest = df.iloc[-1]\n        prev = df.iloc[-2]\n\n        # 1. Golden cross check: MA5 crosses above MA10\n        ma5_golden = (prev['ma5'] < prev['ma10']) and (latest['ma5'] > latest['ma10'])\n\n        if not ma5_golden:\n            return False, \"No golden cross\"\n\n        # 2. Volume check: Volume >= 1.5x of 20-day average\n        vol_ratio = latest['volume'] / latest['avg_volume']\n        if vol_ratio < VOLUME_MULTIPLIER:\n            return False, f\"Volume too low ({vol_ratio:.2f} < {VOLUME_MULTIPLIER})\"\n\n        # 3. RSI check: RSI < 70\n        rsi_ok = not pd.isna(latest['rsi']) and latest['rsi'] < RSI_MAX\n        if not rsi_ok:\n            return False, f\"RSI too high ({latest['rsi']:.2f} >= {RSI_MAX})\"\n\n        return True, f\"Meets all conditions: MA5={latest['ma5']:.2f}>MA10={latest['ma10']:.2f}, RSI={latest['rsi']:.2f}, VolumeRatio={vol_ratio:.2f}\"\n\n    def get_stock_list(self):\n        \"\"\"Get main board non-ST stocks\"\"\"\n        print(\"[1] Getting A-share stock list...\")\n        stocks = ts.get_stock_basics()\n        print(f\"Total stocks: {len(stocks)}\")\n\n        # Filter main board (60/00 prefix)\n        main_board = stocks[\n            (stocks.index.str.startswith('60') | stocks.index.str.startswith('00'))\n        ]\n        print(f\"Main board stocks: {len(main_board)}\")\n\n        # Exclude ST\n        non_st = main_board[~stocks.index.str.contains('ST')]\n        print(f\"Main board non-ST stocks: {len(non_st)}\")\n\n        return non_st\n\n    def scan_stocks(self, max_results=20):\n        \"\"\"Scan stocks for buy signals\"\"\"\n        print(\"\\n[2] Scanning stocks...\")\n        print(f\"Max results: {max_results}\")\n\n        stock_list = self.get_stock_list()\n        candidates = []\n        scanned_count = 0\n\n        for idx, stock in stock_list.iterrows():\n            code = stock.name  # Stock code is index\n            name = stock['name']\n\n            scanned_count += 1\n            if scanned_count % 10 == 0:\n                print(f\"Scanned {scanned_count}/{len(stock_list)} stocks, found {len(candidates)} candidates\")\n\n            try:\n                # Get historical data (recent 120 days)\n                end_date = datetime.now()\n                start_date = end_date - timedelta(days=120)\n\n                df = ts.get_hist(\n                    code,\n                    start_date=start_date.strftime('%Y%m%d'),\n                    end_date=end_date.strftime('%Y%m%d'),\n                    ktype='D',  # Daily line\n                    adjust='qfq'\n                )\n\n                if df is None or len(df) < 20:\n                    continue\n\n                # Calculate indicators\n                df['ma5'] = df['close'].rolling(window=MA5_PERIOD).mean()\n                df['ma10'] = df['close'].rolling(window=MA10_PERIOD).mean()\n                df['avg_volume'] = df['volume'].rolling(window=20).mean()\n                df['volume_ratio'] = df['volume'] / df['avg_volume']\n\n                latest = df.iloc[-1]\n                prev = df.iloc[-2]\n\n                # Check golden cross\n                golden_cross = (prev['ma5'] < prev['ma10']) and (latest['ma5'] > latest['ma10'])\n                if not golden_cross:\n                    continue\n\n                # Check volume\n                if latest['volume_ratio'] < VOLUME_MULTIPLIER:\n                    continue\n\n                # Check RSI\n                rsi = self.calculate_rsi(df['close']).iloc[-1]\n                if pd.isna(rsi) or rsi >= RSI_MAX:\n                    continue\n\n                candidates.append({\n                    'code': code,\n                    'name': name,\n                    'close': latest['close'],\n                    'change': (latest['close'] - latest['open']) / latest['open'] * 100,\n                    'ma5': latest['ma5'],\n                    'ma10': latest['ma10'],\n                    'volume_ratio': latest['volume_ratio'],\n                    'rsi': rsi,\n                    'signal_reason': f\"Golden Cross + Volume ({latest['volume_ratio']:.2f}x) + RSI ({rsi:.1f})\",\n                    'scan_time': datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n                })\n\n            except Exception as e:\n                continue\n\n        print(f\"\\nScan complete! Scanned {scanned_count} stocks, found {len(candidates)} candidates\")\n\n        return candidates\n\n    def save_scan_results(self, candidates):\n        \"\"\"Save scan results\"\"\"\n        df = pd.DataFrame(candidates)\n        df.to_csv(SCAN_RESULT_FILE, index=False, encoding='utf-8-sig')\n        print(f\"\\nScan results saved to: {SCAN_RESULT_FILE}\")\n\n        # Also save JSON\n        import json\n        with open('scan_results_tushare.json', 'w', encoding='utf-8') as f:\n            json.dump(candidates, f, ensure_ascii=False, indent=2)\n\n        return df\n\n    def load_positions(self):\n        \"\"\"Load positions\"\"\"\n        import json\n        import os\n        if os.path.exists(POSITION_FILE):\n            with open(POSITION_FILE, 'r', encoding='utf-8') as f:\n                self.positions = json.load(f)\n\n    def save_positions(self):\n        \"\"\"Save positions\"\"\"\n        import json\n        with open(POSITION_FILE, 'w', encoding='utf-8') as f:\n            json.dump(self.positions, f, ensure_ascii=False, indent=2)\n\n    def add_position(self, stock_code, name, price, shares):\n        \"\"\"Add position\"\"\"\n        self.positions[stock_code] = {\n            'name': name,\n            'cost': price,\n            'shares': shares,\n            'date': datetime.now().strftime('%Y-%m-%d'),\n            'stop_loss': price * (1 - STOP_LOSS_RATIO),\n            'take_profit': price * (1 + TAKE_PROFIT_RATIO)\n        }\n        self.save_positions()\n\n    def print_dashboard(self):\n        \"\"\"Print position dashboard\"\"\"\n        print(\"\\n\" + \"=\"*80)\n        print(\"A-Share Quant Trading - Position Dashboard (Tushare version)\")\n        print(\"=\"*80)\n\n        # Capital overview\n        used_capital = sum([pos['cost'] * pos['shares'] for pos in self.positions.values()])\n        self.cash = TOTAL_CAPITAL - used_capital\n\n        print(\"\\n[Capital Overview]\")\n        print(f\"Total Capital: {TOTAL_CAPITAL:,.2f} Yuan\")\n        print(f\"Position Value: {used_capital:,.2f} Yuan\")\n        print(f\"Cash Balance: {self.cash:,.2f} Yuan\")\n        print(f\"Position Ratio: {(used_capital/TOTAL_CAPITAL*100):.2f}%\")\n\n        # Position details\n        print(f\"\\n[Position Details]({len(self.positions)} stocks)\")\n        print(f\"{'Code':<10} {'Name':<15} {'Shares':<10} {'Cost':<10} {'Price':<10} {'Profit':<12} {'Profit%':<10}\")\n        print(\"-\"*80)\n\n        for code, pos in self.positions.items():\n            try:\n                # Get latest price\n                end_date = datetime.now()\n                start_date = end_date - timedelta(days=5)\n\n                df = ts.get_hist(\n                    code,\n                    start_date=start_date.strftime('%Y%m%d'),\n                    end_date=end_date.strftime('%Y%m%d'),\n                    ktype='D',\n                    adjust='qfq'\n                )\n\n                if df is None or len(df) == 0:\n                    current_price = pos['cost']\n                else:\n                    current_price = df.iloc[-1]['close']\n\n                profit = (current_price - pos['cost']) * pos['shares']\n                profit_ratio = profit / (pos['cost'] * pos['shares']) * 100\n\n                sign = \"+\" if profit >= 0 else \"\"\n                profit_str = f\"{sign}{profit:.2f}\"\n\n                print(f\"{code:<10} {pos['name']:<15} {pos['shares']:<10} {pos['cost']:<10.2f} {current_price:<10.2f} {profit_str:<12} {profit_ratio:>7.2f}%\")\n\n            except Exception as e:\n                print(f\"{code:<10} {pos['name']:<15} {pos['shares']:<10} {pos['cost']:<10.2f} Error\")\n\n        # Risk control status\n        position_ratio = (used_capital / TOTAL_CAPITAL * 100) if TOTAL_CAPITAL > 0 else 0\n        print(f\"\\n[Risk Control Status]\")\n        if position_ratio > TOTAL_MAX_POSITION * 100:\n            print(f\"WARNING: Position ratio too high ({position_ratio:.2f}% > {TOTAL_MAX_POSITION*100:.0f}%)\")\n        else:\n            print(f\"OK: Position ratio normal ({position_ratio:.2f}%)\")\n\n        print(\"=\"*80)\n\n\n# =================== Main Function ===================\n\ndef main():\n    \"\"\"Main function\"\"\"\n    print(\"\\n\" + \"=\"*60)\n    print(\"A-Share Quant Trading - Tushare Version\")\n    print(\"=\"*60)\n\n    # Check token\n    if TUSHARE_TOKEN == \"your_token_here\":\n        print(\"\\nIMPORTANT: Need to configure tushare token\")\n        print(\"\\nPlease follow these steps:\")\n        print(\"1. Visit: https://tushare.pro/register\")\n        print(\"2. Register free account\")\n        print(\"3. Login and get API Token\")\n        print(\"4. Update TUSHARE_TOKEN in this script (line 28)\")\n        print(\"   Replace: TUSHARE_TOKEN = \\\"your_token_here\\\"\")\n        print(\"   With: TUSHARE_TOKEN = \\\"xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\\\"\")\n        print(\"\\nAfter configuration, run the script again\")\n        return\n\n    strategy = TushareStrategy()\n\n    # Print position dashboard\n    strategy.print_dashboard()\n\n    # If command line arg is 'scan', then execute scanning\n    if len(sys.argv) > 1 and sys.argv[1] == 'scan':\n        print(\"\\nStarting stock scanning...\")\n        candidates = strategy.scan_stocks(max_results=20)\n        strategy.save_scan_results(candidates)\n\n        # Display candidate stocks\n        if candidates:\n            print(\"\\n[Candidate Stock List]\")\n            print(f\"{'Code':<10} {'Name':<15} {'Price':<10} {'Change%':<10} {'VolRatio':<10} {'RSI':<10} {'Signal Reason':<30}\")\n            print(\"-\"*100)\n            for stock in candidates:\n                print(f\"{stock['code']:<10} {stock['name']:<15} {stock['close']:<10.2f} {stock['change']:>8.2f}% {stock['volume_ratio']:.2f} {stock['rsi']:.1f} {stock['signal_reason']}\")\n        else:\n            print(\"\\nNo candidate stocks found\")\n\nif __name__ == \"__main__\":\n    main()\n","path":"C:\\Users\\Administrator\\.openclaw\\workspace\\quant_scanner_tushare.py"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":137213,"output":2933,"cacheRead":0,"cacheWrite":0,"totalTokens":140146,"cost":{"input":0.08232779999999999,"output":0.0064526,"cacheRead":0,"cacheWrite":0,"total":0.0887804}},"stopReason":"toolUse","timestamp":1774244500150}}
