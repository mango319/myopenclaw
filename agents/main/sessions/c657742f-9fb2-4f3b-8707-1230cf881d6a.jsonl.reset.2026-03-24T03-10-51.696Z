{"type":"message","id":"91de3fa6","parentId":"bcc0c27c","timestamp":"2026-03-23T02:22:23.291Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"我需要用.format()来替代f-string，避免这个问题。让我重新写一个简化版本。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_d830317c750a46938f0bb031","name":"write","arguments":{"content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\nA股量化交易监控程序（简化版）\n功能：持仓监控界面 + 股票扫描\n\"\"\"\n\nimport akshare as ak\nimport pandas as pd\nimport json\nimport os\nimport sys\nfrom datetime import datetime, timedelta\n\n# 配置\nTOTAL_CAPITAL = 50000\nSINGLE_STOCK_MAX_RATIO = 0.20\nTOTAL_MAX_POSITION = 0.80\nTAKE_PROFIT_RATIO = 0.15\nSTOP_LOSS_RATIO = 0.05\nMA5_PERIOD = 5\nMA10_PERIOD = 10\nVOLUME_MULTIPLIER = 1.5\nRSI_MAX = 70\n\nPOSITION_FILE = \"quant_positions.json\"\n\n\nclass PositionMonitor:\n    def __init__(self):\n        self.positions = {}\n        self.cash = TOTAL_CAPITAL\n        self.load_positions()\n\n    def load_positions(self):\n        if os.path.exists(POSITION_FILE):\n            with open(POSITION_FILE, 'r', encoding='utf-8') as f:\n                self.positions = json.load(f)\n\n    def save_positions(self):\n        with open(POSITION_FILE, 'w', encoding='utf-8') as f:\n            json.dump(self.positions, f, ensure_ascii=False, indent=2)\n\n    def print_dashboard(self):\n        used_capital = sum([pos['cost'] * pos['shares'] for pos in self.positions.values()])\n        self.cash = TOTAL_CAPITAL - used_capital\n\n        print(\"\\n\" + \"=\"*80)\n        print(\"A股量化交易 - 持仓监控界面\")\n        print(\"=\"*80)\n\n        print(\"\\n【资金概览】\")\n        print(\"总资金: {:.2f} 元\".format(TOTAL_CAPITAL))\n        print(\"持仓市值: {:.2f} 元\".format(used_capital))\n        print(\"现金余额: {:.2f} 元\".format(self.cash))\n        position_ratio = (used_capital / TOTAL_CAPITAL * 100) if TOTAL_CAPITAL > 0 else 0\n        print(\"总持仓比例: {:.2f}%\".format(position_ratio))\n\n        print(\"\\n【持仓明细】({}只)\".format(len(self.positions)))\n        print(\"{:<10} {:<15} {:<10} {:<10} {:<10}\".format('代码', '名称', '持仓数', '成本价', '现价'))\n        print(\"-\"*80)\n\n        for code, pos in self.positions.items():\n            try:\n                end_date = datetime.now().strftime('%Y%m%d')\n                start_date = (datetime.now() - timedelta(days=5)).strftime('%Y%m%d')\n                df = ak.stock_zh_a_hist(symbol=code, period=\"daily\",\n                                           start_date=start_date, end_date=end_date,\n                                           adjust=\"qfq\")\n                current_price = df.iloc[-1]['close']\n            except:\n                current_price = pos['cost']\n\n            profit = (current_price - pos['cost']) * pos['shares']\n            profit_ratio = profit / (pos['cost'] * pos['shares']) * 100\n\n            sign = \"+\" if profit >= 0 else \"\"\n            profit_str = \"{}{:.2f}\".format(sign, profit)\n\n            print(\"{:<10} {:<15} {:<10} {:<10.2f} {:<10.2f} {:<12} {:>7.2f}%\".format(\n                code, pos['name'], pos['shares'], pos['cost'], current_price, profit_str, profit_ratio))\n\n        print(\"\\n【风控状态】\")\n        if position_ratio > TOTAL_MAX_POSITION * 100:\n            print(\"警告 总持仓比例超标 ({:.2f}% > {:.0f}%)\".format(position_ratio, TOTAL_MAX_POSITION*100))\n        else:\n            print(\"总持仓比例正常 ({:.2f}%)\".format(position_ratio))\n\n        print(\"=\"*80)\n\n\ndef scan_stocks(max_results=10):\n    print(\"\\n开始扫描主板股票...\")\n    print(\"获取股票列表...\")\n\n    all_stocks = ak.stock_info_a_code_name()\n\n    main_board_stocks = []\n    for idx, row in all_stocks.iterrows():\n        code = row['code']\n        name = row['name']\n\n        if code.startswith('60') or code.startswith('00'):\n            if 'ST' in name or '*ST' in name:\n                continue\n            main_board_stocks.append({'code': code, 'name': name})\n\n    print(\"主板非ST股票数量: {}\".format(len(main_board_stocks)))\n\n    candidates = []\n    scanned_count = 0\n\n    print(\"\\n扫描技术指标...\")\n    for i, stock in enumerate(main_board_stocks):\n        code = stock['code']\n        name = stock['name']\n\n        scanned_count += 1\n        if scanned_count % 50 == 0:\n            print(\"已扫描 {}/{} 只股票，找到 {} 个候选\".format(scanned_count, len(main_board_stocks), len(candidates)))\n\n        try:\n            end_date = datetime.now().strftime('%Y%m%d')\n            start_date = (datetime.now() - timedelta(days=120)).strftime('%Y%m%d')\n\n            df = ak.stock_zh_a_hist(symbol=code, period=\"daily\",\n                                       start_date=start_date, end_date=end_date,\n                                       adjust=\"qfq\")\n\n            if len(df) < 20:\n                continue\n\n            df['MA5'] = df['close'].rolling(window=MA5_PERIOD).mean()\n            df['MA10'] = df['close'].rolling(window=MA10_PERIOD).mean()\n            df['AvgVolume'] = df['volume'].rolling(window=20).mean()\n            df['VolumeRatio'] = df['volume'] / df['AvgVolume']\n\n            latest = df.iloc[-1]\n            prev = df.iloc[-2]\n\n            # 金叉检查\n            ma5_golden_cross = (prev['MA5'] < prev['MA10']) and (latest['MA5'] > latest['MA10'])\n\n            if not ma5_golden_cross:\n                continue\n\n            # 成交量检查\n            if latest['VolumeRatio'] < VOLUME_MULTIPLIER:\n                continue\n\n            # RSI计算\n            delta = df['close'].diff()\n            gain = (delta.where(delta > 0, 0)).rolling(window=14).mean()\n            loss = (-delta.where(delta < 0, 0)).rolling(window=14).mean()\n            rs = gain / loss\n            rsi = 100 - (100 / (1 + rs))\n\n            if pd.isna(rsi) or rsi >= RSI_MAX:\n                continue\n\n            candidates.append({\n                'code': code,\n                'name': name,\n                'close': latest['close'],\n                'change': latest.get('pct_chg', 0) * 100,\n                'volume_ratio': latest['VolumeRatio'],\n                'rsi': rsi,\n                'ma5': latest['MA5'],\n                'ma10': latest['MA10'],\n                'scan_time': datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n            })\n\n            if len(candidates) >= max_results:\n                break\n\n        except Exception as e:\n            continue\n\n    print(\"\\n扫描完成！共扫描 {} 只股票，找到 {} 个候选\".format(scanned_count, len(candidates)))\n\n    # 保存结果\n    df = pd.DataFrame(candidates)\n    df.to_csv('scan_results.csv', index=False, encoding='utf-8-sig')\n\n    with open('scan_results.json', 'w', encoding='utf-8') as f:\n        json.dump(candidates, f, ensure_ascii=False, indent=2)\n\n    print(\"扫描结果已保存到: scan_results.csv 和 scan_results.json\")\n\n    # 显示候选股票\n    if candidates:\n        print(\"\\n【候选股票列表】\")\n        print(\"{:<10} {:<15} {:<10} {:<10} {:<8} {:<8} {:<30}\".format(\n            '代码', '名称', '现价', '涨跌幅', '量比', 'RSI', '信号原因'))\n        print(\"-\"*100)\n        for stock in candidates:\n            print(\"{:<10} {:<15} {:<10.2f} {:>8.2f}% {:>6.2f}x {:<8.1f} 金叉+放量+RSI={:.1f}\".format(\n                stock['code'], stock['name'], stock['close'], stock['change'],\n                stock['volume_ratio'], stock['rsi'], stock['rsi']))\n\n\ndef main():\n    print(\"\\n\" + \"=\"*60)\n    print(\"A股量化交易 - 数据扫描与持仓监控\")\n    print(\"=\"*60)\n\n    monitor = PositionMonitor()\n    monitor.print_dashboard()\n\n    print(\"\\n提示：使用 'python quant_scanner.py scan' 启动股票扫描\")\n\n    if len(sys.argv) > 1 and sys.argv[1] == 'scan':\n        scan_stocks(max_results=20)\n\n\nif __name__ == \"__main__\":\n    main()\n","path":"C:\\Users\\Administrator\\.openclaw\\workspace\\quant_scanner.py"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":269,"output":1985,"cacheRead":131888,"cacheWrite":0,"totalTokens":134142,"cost":{"input":0.0001614,"output":0.004367,"cacheRead":0.01450768,"cacheWrite":0,"total":0.01903608}},"stopReason":"toolUse","timestamp":1774232509440}}
