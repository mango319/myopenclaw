display: grid;\n            grid-template-columns: 1fr 350px;\n            gap: 30px;\n        }\n\n        .panel {\n            background: white;\n            border-radius: 12px;\n            padding: 25px;\n            box-shadow: 0 8px 24px rgba(0,0,0,0.15);\n            margin-bottom: 20px;\n        }\n\n        .panel h2 {\n            margin-top: 0;\n            color: #667eea;\n            font-size: 1.3em;\n            padding-bottom: 15px;\n            border-bottom: 3px solid #667eea;\n        }\n\n        .form-group {\n            margin-bottom: 20px;\n        }\n\n        .form-group label {\n            display: block;\n            margin-bottom: 8px;\n            font-weight: 600;\n            color: #555;\n        }\n\n        .form-group input,\n        .form-group select {\n            width: 100%;\n            padding: 12px;\n            border: 2px solid #ddd;\n            border-radius: 8px;\n            font-size: 14px;\n            transition: border-color 0.3s;\n        }\n\n        .form-group input:focus,\n        .form-group select:focus {\n            outline: none;\n            border-color: #667eea;\n        }\n\n        .form-row {\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n            gap: 15px;\n        }\n\n        button {\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            color: white;\n            border: none;\n            padding: 12px 25px;\n            border-radius: 8px;\n            font-size: 16px;\n            font-weight: 600;\n            cursor: pointer;\n            transition: transform 0.2s, box-shadow 0.2s;\n            margin: 5px 0;\n        }\n\n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        button.primary {\n            width: 100%;\n            padding: 15px;\n            font-size: 18px;\n        }\n\n        button.secondary {\n            background: #95a5a6;\n        width: 100%;\n        padding: 12px;\n        font-size: 14px;\n        margin-top: 10px;\n        border: none;\n            color: white;\n            border-radius: 8px;\n            cursor: pointer;\n        }\n\n        button.danger {\n            background: #e74c3c;\n        width: 100%;\n            padding: 12px;\n            font-size: 14px;\n            margin-top: 10px;\n            border: none;\n            color: white;\n            border-radius: 8px;\n            cursor: pointer;\n        }\n\n        .results-container {\n            background: white;\n            border-radius: 12px;\n            padding: 25px;\n            box-shadow: 0 8px 24px rgba(0,0,0,0.15);\n        }\n\n        .results-container h2 {\n            margin-top: 0;\n            color: #667eea;\n            font-size: 1.3em;\n            padding-bottom: 15px;\n            border-bottom: 3px solid #667eea;\n        }\n\n        .stock-list {\n            margin-top: 20px;\n        }\n\n        .stock-item {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            padding: 15px;\n            margin-bottom: 10px;\n            border: 1px solid #eee;\n            border-radius: 8px;\n            transition: background-color 0.2s;\n        }\n\n        .stock-item:hover {\n            background-color: #f8f9fa;\n        }\n\n        .stock-info {\n            flex: 1;\n        margin-right: 20px;\n        margin-left: 20px;\n        flex-grow: 1;\n        display: flex;\n            justify-content: space-between;\n            align-items: center;\n        flex-wrap: wrap;\n        gap: 10px;\n        white-space: nowrap;\n            flex-grow: 1;\n        flex-shrink: 1;\n            min-width: 0;\n            overflow: hidden;\n        text-overflow: ellipsis;\n        margin-left: 20px;\n        margin-right: 20px;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            flex-wrap: wrap;\n            gap: 15px;\n        }\n\n        .stock-actions {\n            display: flex;\n            gap: 8px;\n        }\n\n        .stock-actions .btn {\n            padding: 6px 15px;\n            font-size: 12px;\n            margin: 0;\n        }\n\n        .stock-actions .btn-primary {\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            color: white;\n            border: none;\n            border-radius: 6px;\n            cursor: pointer;\n            font-weight: 600;\n            transition: transform 0.2s, box-shadow 0.2s;\n            white-space: nowrap;\n        }\n\n        .stock-actions .btn-primary:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);\n        }\n\n        .stock-actions .btn-secondary {\n            background: #95a5a6;\n            color: white;\n            border: none;\n            border-radius: 6px;\n            cursor: pointer;\n            font-weight: 600;\n            transition: transform 0.2s, box-shadow 0.2s;\n            white-space: nowrap;\n        }\n\n        .stock-actions .btn-secondary:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 4px 12px rgba(149, 165, 166, 0.4);\n        }\n\n        .stock-actions .btn-danger {\n            background: #e74c3c;\n            color: white;\n            border: none;\n            border-radius: 6px;\n            cursor: pointer;\n            font-weight: 600;\n            transition: transform 0.2s, box-shadow 0.2s;\n            white-space: nowrap;\n        }\n\n        .stock-actions .btn-danger:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 4px 12px rgba(231, 76, 60, 0.4);\n        }\n\n        .status-badge {\n            display: inline-block;\n            padding: 4px 12px;\n            border-radius: 20px;\n            font-size: 12px;\n            font-weight: 600;\n            margin-left: 10px;\n            white-space: nowrap;\n        }\n\n        .status-badge.success {\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            color: white;\n        }\n\n        .status-badge.fail {\n            background: #e74c3c;\n            color: white;\n        }\n\n        .position-table {\n            width: 100%;\n            border-collapse: collapse;\n            margin-top: 20px;\n        }\n\n        .position-table th,\n        .position-table td {\n            padding: 12px;\n            text-align: left;\n            border-bottom: 1px solid #eee;\n        }\n\n        .position-table th {\n            background: #f8f9fa;\n            font-weight: 600;\n            color: #333;\n        }\n\n        .position-table td.profit {\n            color: #28a745;\n            font-weight: 600;\n        }\n\n        .position-table td.loss {\n            color: #dc3545;\n            font-weight: 600;\n        }\n\n        .position-table td:first-child,\n        .position-table th:first-child {\n            width: 120px;\n        }\n\n        .dashboard {\n            background: white;\n            border-radius: 12px;\n            padding: 25px;\n            box-shadow: 0 8px 24px rgba(0,0,0,0.15);\n            margin-top: 20px;\n        }\n\n        .dashboard h2 {\n            margin-top: 0;\n            color: #667eea;\n            font-size: 1.3em;\n            padding-bottom: 15px;\n            border-bottom: 3px solid #667eea;\n        }\n\n        .stat-card {\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n            gap: 15px;\n            margin-bottom: 15px;\n        }\n\n        .stat-item {\n            background: #f8f9fa;\n            padding: 15px;\n            border-radius: 8px;\n            border-left: 4px solid #667eea;\n        }\n\n        .stat-label {\n            color: #666;\n            font-size: 0.9em;\n            margin-bottom: 5px;\n        }\n\n        .stat-value {\n            color: #333;\n            font-size: 1.2em;\n            font-weight: 600;\n            margin: 0;\n        }\n\n        .stat-value span {\n            color: #667eea;\n        }\n\n        .alert {\n            padding: 15px;\n            border-radius: 8px;\n            margin-top: 15px;\n            font-weight: 600;\n            display: none;\n        }\n\n        .alert.success {\n            background: #d4edda;\n            color: #155724;\n            border: 1px solid #c3e6cb;\n            display: block;\n        }\n\n        .alert.error {\n            background: #f8d7da;\n            color: #721c24;\n            border: 1px solid #f5c6cb;\n            display: block;\n        }\n\n        .info-box {\n            background: #fff3cd;\n            color: #856404;\n            border: 1px solid #ffecb3;\n            padding: 15px;\n            border-radius: 8px;\n            margin-top: 15px;\n            font-size: 14px;\n        }\n\n        .info-box ul {\n            margin: 10px 0 0 20px 20px;\n        }\n\n        .info-box li {\n            margin-bottom: 8px;\n        }\n\n        @media (max-width: 768px) {\n            .main-content {\n                grid-template-columns: 1fr;\n            }\n\n            .form-row {\n                grid-template-columns: 1fr;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>📈 A股量化交易系统</h1>\n            <p>Web版本 - 完全在浏览器中使用，无需Python命令行</p>\n        </div>\n\n        <div class=\"main-content\">\n            <!-- 左侧：数据录入 -->\n            <div class=\"panel\">\n                <h2>📊 数据录入</h2>\n\n                <div class=\"form-group\">\n                    <label>股票代码</label>\n                    <input type=\"text\" id=\"stockCode\" placeholder=\"例如: 600000\">\n                </div>\n\n                <div class=\"form-group\">\n                    <label>股票名称</label>\n                    <input type=\"text\" id=\"stockName\" placeholder=\"例如: 浦发银行\">\n                </div>\n\n                <div class=\"form-group\">\n                    <label>日期</label>\n                    <input type=\"date\" id=\"date\" placeholder=\"选择日期\">\n                </div>\n\n                <div class=\"form-row\">\n                    <div class=\"form-group\">\n                        <label>开盘价</label>\n                        <input type=\"number\" id=\"openPrice\" step=\"0.01\" placeholder=\"0.00\">\n                    </div>\n                    <div class=\"form-group\">\n                        <label>收盘价</label>\n                        <input type=\"number\" id=\"closePrice\" step=\"0.01\" placeholder=\"0.00\">\n                    </div>\n                </div>\n\n                <div class=\"form-row\">\n                    <div class=\"form-group\">\n                        <label>最高价</label>\n                        <input type=\"number\" id=\"highPrice\" step=\"0.01\" placeholder=\"0.00\">\n                    </div>\n                    <div class=\"form-group\">\n                        <label>最低价</label>\n                        <input type=\"number\" id=\"lowPrice\" step=\"0.01\" placeholder=\"0.00\">\n                    </div>\n                </div>\n\n                <div class=\"form-group\">\n                    <label>成交量</label>\n                    <input type=\"number\" id=\"volume\" placeholder=\"10000000\">\n                </div>\n\n                <button class=\"primary\" onclick=\"addStockData()\">➕ 添加股票数据</button>\n                <button class=\"secondary\" onclick=\"clearForm()\">🔄 清空表单</button>\n            </div>\n\n            <!-- 右侧：策略分析 -->\n            <div class=\"panel\">\n                <h2>📈 策略分析</h2>\n\n                <div class=\"info-box\">\n                    <p><strong>买入条件：</strong></p>\n                    <ul>\n                        <li>✅ MA5 > MA10 金叉</li>\n                        <li>✅ 成交量 ≥ 近20日均量1.5倍</li>\n                        <li>✅ RSI < 70（避免超买）</li>\n                    </ul>\n\n                    <p><strong>卖出条件：</strong></p>\n                    <ul>\n                        <li>⚠️ 止盈：盈利达到 15%</li>\n                        <li>⚠️ 止损：亏损达到 5%</li>\n                    </ul>\n                </div>\n\n                <div class=\"form-group\">\n                    <label>选择股票分析</label>\n                    <select id=\"selectStock\">\n                        <option value=\"\">-- 选择股票 --</option>\n                    </select>\n                </div>\n\n                <button class=\"primary\" onclick=\"checkBuySignal()\">🔍 检查买入信号</button>\n\n                <div id=\"signalResult\" class=\"alert\" style=\"display:none;\"></div>\n\n                <div class=\"info-box\">\n                    <p><strong>仓位控制：</strong></p>\n                    <ul>\n                        <li>总资金：50,000 元</li>\n                        <li>单票最大：20%（10,000 元）</li>\n                        <li>总持仓最大：80%（40,000 元）</li>\n                        <li>现金保留：20%（10,000 元）</li>\n                    </ul>\n                </div>\n\n                <button class=\"primary\" onclick=\"showBuyModal()\">💰 模拟买入</button>\n                <button class=\"secondary\" onclick=\"showSellModal()\">📤 模拟卖出</button>\n            </div>\n        </div>\n\n        <!-- 买入模拟弹窗 -->\n        <div id=\"buyModal\" style=\"display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000; justify-content:center; align-items:center;\">\n            <div style=\"background:white; padding:40px; border-radius:12px; max-width:500px; width:90%; box-shadow:0 10px 40px rgba(0,0,0,0.3); text-align:center;\">\n                <h2 style=\"color:#667eea; margin-top:0;\">💰 模拟买入</h2>\n                <div class=\"form-group\" style=\"margin-top:20px;\">\n                    <label>股票代码</label>\n                    <input type=\"text\" id=\"buyStockCode\" placeholder=\"600000\">\n                </div>\n                <div class=\"form-group\">\n                    <label>股票名称</label>\n                    <input type=\"text\" id=\"buyStockName\" placeholder=\"浦发银行\">\n                </div>\n                <div class=\"form-row\">\n                    <div class=\"form-group\">\n                        <label>买入价格（元）</label>\n                        <input type=\"number\" id=\"buyPrice\" step=\"0.01\" placeholder=\"10.00\">\n                    </div>\n                    <div class=\"form-group\">\n                        <label>买入数量（股）</label>\n                        <input type=\"number\" id=\"buyShares\" placeholder=\"500\">\n                    </div>\n                </div>\n                <div class=\"info-box\" style=\"margin-top:20px;\">\n                    <p><strong>预计成本：</strong> <span id=\"expectedCost\">0</span> 元</p>\n                    <p><strong>仓位限制：</strong></p>\n                    <ul>\n                        <li>单票最大：10,000 元</li>\n                        <li>总持仓最大：40,000 元</li>\n                    </ul>\n                </div>\n                <div style=\"margin-top:25px; display:grid; gap:15px;\">\n                    <button class=\"primary\" onclick=\"executeBuy()\" style=\"grid-column:1\">✅ 确认买入</button>\n                    <button class=\"secondary\" onclick=\"closeBuyModal()\" style=\"grid-column:1\">❌ 取消</button>\n                </div>\n            </div>\n        </div>\n\n        <!-- 持仓监控面板 -->\n        <div class=\"panel\">\n            <h2>📊 持仓监控</h2>\n\n            <div class=\"dashboard\">\n                <h2>💰 资金概览</h2>\n\n                <div class=\"stat-card\">\n                    <div class=\"stat-item\">\n                        <div class=\"stat-label\">总资金</div>\n                        <div class=\"stat-value\">50,000 元</div>\n                    </div>\n                    <div class=\"stat-item\">\n                        <div class=\"stat-label\">持仓市值</div>\n                        <div class=\"stat-value\"><span id=\"positionValue\">0</span> 元</div>\n                    </div>\n                </div>\n\n                <div class=\"stat-card\">\n                    <div class=\"stat-item\">\n                        <div class=\"stat-label\">现金余额</div>\n                        <div class=\"stat-value\"><span id=\"cashBalance\">50,000</span> 元</div>\n                    </div>\n                    <div class=\"stat-item\">\n                        <div class=\"stat-label\">持仓比例</div>\n                        <div class=\"stat-value\"><span id=\"positionRatio\">0</span>%</div>\n                    </div>\n                </div>\n\n                <h2 style=\"margin-top:25px;\">📈 持仓明细</h2>\n\n                <table class=\"position-table\">\n                    <thead>\n                        <tr>\n                            <th>代码</th>\n                            <th>名称</th>\n                            <th>数量</th>\n                            <th>成本</th>\n                            <th>现价</th>\n                            <th>市值</th>\n                            <th>盈亏</th>\n                            <th>盈亏%</th>\n                            <th>操作</th>\n                        </tr>\n                    </thead>\n                    <tbody id=\"positionTableBody\">\n                        <tr>\n                            <td colspan=\"9\" style=\"text-align:center; padding:30px; color:#999;\">\n                                暂无持仓\n                            </td>\n                        </tr>\n                    </tbody>\n                </table>\n\n                <div style=\"margin-top:20px;\">\n                    <button class=\"secondary\" onclick=\"clearAllPositions()\" style=\"margin-bottom:10px;\">🔄 清空所有持仓</button>\n                    <button class=\"primary\" onclick=\"refreshPositions()\">🔄 刷新持仓</button>\n                </div>\n\n                <div id=\"sellAlert\" class=\"alert\" style=\"display:none;\"></div>\n            </div>\n        </div>\n\n        <!-- 候选股票面板 -->\n        <div class=\"panel\">\n            <h2>📋 候选股票</h2>\n\n            <div class=\"info-box\">\n                <p>根据策略筛选出的买入候选股票</p>\n                <ul>\n                    <li>按买入信号强度排序</li>\n                    <li>显示最近10只符合条件的股票</li>\n                </ul>\n            </div>\n\n            <div class=\"stock-list\" id=\"candidatesList\">\n                <div style=\"text-align:center; padding:30px; color:#999;\">\n                    扫描股票后显示候选列表\n                </div>\n            </div>\n\n            <div style=\"margin-top:20px;\">\n                <button class=\"primary\" onclick=\"scanAllStocks()\">🔍 扫描所有股票</button>\n                <button class=\"secondary\" onclick=\"clearAllCandidates()\">🔄 清空候选列表</button>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        // =================== 配置 ===================\n        const CONFIG = {\n            totalCapital: 50000,\n            singleStockMaxRatio: 0.20,\n            totalMaxPosition: 0.80,\n            takeProfitRatio: 0.15,\n            stopLossRatio: 0.05\n            ma5Period: 5,\n            ma10Period: 10,\n            volumeMultiplier: 1.5,\n            rsiMax: 70\n        };\n\n        // =================== 数据存储 ===================\n        let stockData = {};\n        let positions = {};\n\n        // =================== 核心函数 ===================\n\n        function calculateMA(prices, period) {\n            if (prices.length < period) return null;\n\n            let sum = 0;\n            for (let i = period - 1; i < prices.length; i++) {\n                sum += prices[i];\n            }\n            return sum / period;\n        }\n\n        function calculateRSI(prices, period = 14) {\n            if (prices.length < period + 1) return null;\n\n            let gains = 0;\n            let losses = 0;\n\n            for (let i = period; i < prices.length; i++) {\n                const change = prices[i] - prices[i - period];\n                if (change > 0) {\n                    gains += change;\n                } else {\n                    losses += Math.abs(change);\n                }\n            }\n\n            const avgGain = gains / period;\n            const avgLoss = losses / period;\n            const rs = avgLoss === 0 ? 100 : 100 - (100 / (1 + (avgGain / avgLoss)));\n            return rs;\n        }\n\n        function checkBuySignal(code) {\n            const data = stockData[code];\n            if (!data || data.length < 10) {\n                return { isSignal: false, reason: '数据不足（需要至少10天）' };\n            }\n\n            // 计算技术指标\n            const prices = data.map(d => d.close);\n            const volumes = data.map(d => d.volume);\n\n            const ma5 = calculateMA(prices, CONFIG.ma5Period);\n            const ma10 = calculateMA(prices, CONFIG.ma10Period);\n            const avgVolume = calculateMA(volumes, 20);\n\n            const latest = data[data.length - 1];\n            const prev = data[data.length - 2];\n\n            // 金叉检查\n            const goldenCross = (prev.ma5 < prev.ma10) && (latest.ma5 > latest.ma10);\n            if (!goldenCross) {\n                return { isSignal: false, reason: '未出现金叉（MA5 > MA10）' };\n            }\n\n            // 成交量检查\n            const volumeRatio = latest.volume / avgVolume;\n            if (volumeRatio < CONFIG.volumeMultiplier) {\n                return { isSignal: false, reason: `成交量不足（${volumeRatio.toFixed(2)} < ${CONFIG.volumeMultiplier}）` };\n            }\n\n            // RSI检查\n            const rsi = calculateRSI(prices);\n            if (rsi === null || rsi >= CONFIG.rsiMax) {\n                return { isSignal: false, reason: `RSI过高（${rsi.toFixed(2)} >= 70）` };\n            }\n\n            return {\n                isSignal: true,\n                reason: `买入信号：MA5=${latest.ma5.toFixed(2)} > MA10=${latest.ma10.toFixed(2)}, RSI=${rsi.toFixed(1)}, 量比=${volumeRatio.toFixed(2)}`\n            };\n        }\n\n        function addStockData() {\n            const code = document.getElementById('stockCode').value.trim();\n            const name = document.getElementById('stockName').value.trim();\n            const date = document.getElementById('date').value;\n            const openPrice = parseFloat(document.getElementById('openPrice').value);\n            const closePrice = parseFloat(document.getElementById('closePrice').value);\n            const highPrice = parseFloat(document.getElementById('highPrice').value);\n            const lowPrice = parseFloat(document.getElementById('lowPrice').value);\n            const volume = parseInt(document.getElementById('volume').value);\n\n            if (!code || !name || !date || isNaN(openPrice) || isNaN(closePrice) || isNaN(highPrice) || isNaN(lowPrice) || isNaN(volume)) {\n                alert('请填写完整的股票数据！');\n                return;\n            }\n\n            if (!stockData[code]) {\n                stockData[code] = [];\n            }\n\n            stockData[code].push({\n                code: code,\n                name: name,\n                date: date,\n                open: openPrice,\n                close: closePrice,\n                high: highPrice,\n                low: lowPrice,\n                volume: volume\n            });\n\n            stockData[code].sort((a, b) => a.date.localeCompare(b.date));\n\n            updateStockSelect();\n            alert(`成功添加 ${code}（${name}）的数据！\\n该股票现有 ${stockData[code].length} 天数据`);\n\n            // 更新买入信号检查\n            if (stockData[code].length >= 10) {\n                const result = checkBuySignal(code);\n                updateSignalDisplay(code, name, result);\n            }\n\n            clearForm();\n        }\n\n        function updateStockSelect() {\n            const select = document.getElementById('selectStock');\n            select.innerHTML = '<option value=\"\">-- 选择股票 --</option>';\n\n            Object.keys(stockData).forEach(code => {\n                const data = stockData[code];\n                const name = data[0].name;\n                const count = data.length;\n                select.innerHTML += `<option value=\"${code}\">${name} (${count}天)</option>`;\n            });\n        }\n\n        function checkBuySignal() {\n            const code = document.getElementById('selectStock').value;\n            if (!code) {\n                alert('请先选择股票！');\n                return;\n            }\n\n            const data = stockData[code];\n            if (!data || data.length < 10) {\n                alert('该股票数据不足（需要至少10天）');\n                return;\n            }\n\n            const result = checkBuySignal(code);\n            updateSignalDisplay(code, data[0].name, result);\n        }\n\n        function updateSignalDisplay(code, name, result) {\n            const signalDiv = document.getElementById('signalResult');\n            signalDiv.style.display = 'block';\n\n            if (result.isSignal) {\n                signalDiv.className = 'alert success';\n                signalDiv.innerHTML = `\n                    <strong>✅ 买入信号！</strong><br>\n                    股票：${code} - ${name}<br>\n                    ${result.reason}\n                `;\n            } else {\n                signalDiv.className = 'alert error';\n                signalDiv.innerHTML = `\n                    <strong>❌ 无买入信号</strong><br>\n                    股票：${code} - ${name}<br>\n                    原因：${result.reason}\n                `;\n            }\n        }\n\n        function showBuyModal() {\n            const code = document.getElementById('selectStock').value;\n            if (!code) {\n                alert('请先选择股票！');\n                return;\n            }\n\n            const data = stockData[code];\n            if (!data || data.length === 0) {\n                alert('该股票没有数据！');\n                return;\n            }\n\n            const latest = data[data.length - 1];\n            document.getElementById('buyStockCode').value = code;\n            document.getElementById('buyStockName').value = latest.name;\n            document.getElementById('buyPrice').value = latest.close;\n            document.getElementById('expectedCost').textContent = (latest.close * 500).toFixed(2);\n\n            document.getElementById('buyModal').style.display = 'flex';\n        }\n\n        function executeBuy() {\n            const code = document.getElementById('buyStockCode').value.trim();\n            const name = document.getElementById('buyStockName').value.trim();\n            const price = parseFloat(document.getElementById('buyPrice').value);\n            const shares = parseInt(document.getElementById('buyShares').value);\n\n            if (!code || !name || isNaN(price) || isNaN(shares) || shares <= 0) {\n                alert('请填写完整的买入信息！');\n                return;\n            }\n\n            const cost = price * shares;\n            const singleMax = CONFIG.totalCapital * CONFIG.singleStockMaxRatio;\n            const totalUsed = Object.values(positions).reduce((sum, pos) => sum + pos.cost * pos.shares, 0);\n            const totalMax = CONFIG.totalCapital * CONFIG.totalMaxPosition;\n\n            if (cost > singleMax) {\n                alert(`超出单票最大仓位！\\n最大金额：${singleMax.toFixed(2)}元\\n实际金额：${cost.toFixed(2)}元`);\n                return;\n            }\n\n            if (totalUsed + cost > totalMax) {\n                alert(`超出总持仓最大仓位！\\n最大金额：${totalMax.toFixed(2)}元\\n实际金额：${(totalUsed + cost).toFixed(2)}元`);\n                return;\n            }\n\n            positions[code] = {\n                name: name,\n                cost: price,\n                shares: shares,\n                date: new Date().toISOString().split('T')[0],\n                stopLoss: price * (1 - CONFIG.stopLossRatio),\n                takeProfit: price * (1 + CONFIG.takeProfitRatio)\n            };\n\n            updatePositionsTable();\n            document.getElementById('buyModal').style.display = 'none';\n\n            alert(`成功买入！\\n股票：${code} ${name}\\n数量：${shares}股\\n成本：${cost.toFixed(2)}元`);\n        }\n\n        function closeBuyModal() {\n            document.getElementById('buyModal').style.display = 'none';\n        }\n\n        function showSellModal(code) {\n            if (!code || !positions[code]) {\n                alert('请选择有效的持仓股票！');\n                return;\n            }\n\n            const pos = positions[code];\n            const currentPrice = getLatestPrice(code);\n\n            const profit = (currentPrice - pos.cost) * pos.shares;\n            const profitRatio = profit / (pos.cost * pos.shares) * 100;\n\n            if (confirm(`确认卖出 ${pos.name}（${code}）？\\n\\n成本价：${pos.cost.toFixed(2)}元\\n当前价：${currentPrice.toFixed(2)}元\\n数量：${pos.shares}股\\n\\n盈亏：${profit.toFixed(2)}元（${profitRatio.toFixed(2)}%）`)) {\n                delete positions[code];\n                updatePositionsTable();\n                alert(`卖出成功！\\n获得收益：${profit.toFixed(2)}元`);\n            }\n        }\n\n        function clearForm() {\n            document.getElementById('stockCode').value = '';\n            document.getElementById('stockName').value = '';\n            document.getElementById('date').value = '';\n            document.getElementById('openPrice').value = '';\n            document.getElementById('closePrice').value = '';\n            document.getElementById('highPrice').value = '';\n            document.getElementById('lowPrice').value = '';\n            document.getElementById('volume').value = '';\n        }\n\n        function getLatestPrice(code) {\n            const data = stockData[code];\n            if (!data || data.length === 0) return 0;\n            return data[data.length - 1].close;\n        }\n\n        function updatePositionsTable() {\n            const tbody = document.getElementById('positionTableBody');\n            tbody.innerHTML = '';\n\n            let usedCapital = 0;\n            let cash = CONFIG.totalCapital;\n\n            Object.entries(positions).forEach(([code, pos]) => {\n                const currentPrice = getLatestPrice(code);\n                const marketValue = currentPrice * pos.shares;\n                const profit = (currentPrice - pos.cost) * pos.shares;\n                const profitRatio = profit / (pos.cost * pos.shares) * 100;\n\n                usedCapital += marketValue;\n\n                const row = document.createElement('tr');\n                row.innerHTML = `\n                    <td>${code}</td>\n                    <td>${pos.name}</td>\n                    <td>${pos.shares}</td>\n                    <td>${pos.cost.toFixed(2)}</td>\n                    <td>${currentPrice.toFixed(2)}</td>\n                    <td>${marketValue.toFixed(2)}</td>\n                    <td class=\"${profit >= 0 ? 'profit' : 'loss'}\">${profit.toFixed(2)}</td>\n                    <td class=\"${profit >= 0 ? 'profit' : 'loss'}\">${profitRatio.toFixed(2)}%</td>\n                    <td>\n                        <button class=\"btn btn-primary\" onclick=\"showSellModal('${code}')\">卖出</button>\n                        <button class=\"btn btn-danger\" onclick=\"deletePosition('${code}')\">删除</button>\n                    </td>\n                `;\n                tbody.appendChild(row);\n\n                // 检查止盈止损\n                if (profit >= pos.takeProfit - pos.cost * pos.shares) {\n                    showSellAlert(code, pos, currentPrice, profit, '止盈');\n                } else if (profit <= pos.stopLoss - pos.cost * pos.shares) {\n                    showSellAlert(code, pos, currentPrice, profit, '止损');\n                }\n            });\n\n            cash = CONFIG.totalCapital - usedCapital;\n\n            // 更新显示\n            document.getElementById('positionValue').textContent = usedCapital.toFixed(2);\n            document.getElementById('cashBalance').textContent = cash.toFixed(2);\n            document.getElementById('positionRatio').textContent = ((usedCapital / CONFIG.totalCapital) * 100).toFixed(2);\n        }\n\n        function showSellAlert(code, pos, currentPrice, profit, reason) {\n            const sellAlert = document.getElementById('sellAlert');\n            sellAlert.style.display = 'block';\n\n            sellAlert.className = 'alert ' + (profit >= 0 ? 'success' : 'error');\n            sellAlert.innerHTML = `\n                <strong>${reason}信号！</strong><br>\n                股票：${code} - ${pos.name}<br>\n                ${profit.toFixed(2)}元（${(profit/(pos.cost*pos.shares)*100).toFixed(2)}%）<br>\n                成本：${pos.cost.toFixed(2)}元<br>\n                当前价：${currentPrice.toFixed(2)}元<br>\n                <button class=\"btn btn-primary\" onclick=\"showSellModal('${code}')\" style=\"margin-top:10px;\">确认卖出</button>\n                <button class=\"btn btn-secondary\" onclick=\"document.getElementById('sellAlert').style.display='none'\" style=\"margin-top:10px;\">忽略</button>\n            `;\n        }\n\n        function deletePosition(code) {\n            if (confirm(`确认删除 ${code} 的持仓？`)) {\n                delete positions[code];\n                updatePositionsTable();\n                alert('持仓已删除');\n            }\n        }\n\n        function clearAllPositions() {\n            if (confirm('确认清空所有持仓？')) {\n                positions = {};\n                updatePositionsTable();\n                document.getElementById('sellAlert').style.display = 'none';\n                alert('所有持仓已清空');\n            }\n        }\n\n        function refreshPositions() {\n            updatePositionsTable();\n            alert('持仓已刷新');\n        }\n\n        function scanAllStocks() {\n            const candidates = [];\n\n            Object.keys(stockData).forEach(code => {\n                const result = checkBuySignal(code);\n                if (result.isSignal) {\n                    const data = stockData[code][stockData[code].length - 1];\n                    candidates.push({\n                        code: code,\n                        name: data.name,\n                        close: data.close,\n                        ma5: data.ma5,\n                        ma10: data.ma10,\n                        rsi: data.rsi,\n                        volumeRatio: data.volumeRatio,\n                        signal: result.reason\n                    });\n                }\n            });\n\n            // 按买入信号强度排序\n            candidates.sort((a, b) => {\n                // 强度判断：金叉 + 放量 + RSI低\n                let scoreA = 0;\n                let scoreB = 0;\n\n                // 金叉加分\n                if (a.ma5 > a.ma10) scoreA += 1;\n                if (b.ma5 > b.ma10) scoreB += 1;\n\n                // 放量加分\n                if (a.volumeRatio >= 1.5) scoreA += 1;\n                if (b.volumeRatio >= 1.5) scoreB += 1;\n\n                // RSI低"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"aborted","timestamp":1774257968135,"errorMessage":"Request was aborted"}}
