{"type":"message","id":"00caa7cf","parentId":"51f054bb","timestamp":"2026-03-23T02:17:06.054Z","message":{"role":"toolResult","toolCallId":"call_8639e98d7f05483aa1337f9d","toolName":"exec","content":[{"type":"text","text":"Name: akshare\r\nVersion: 1.18.44\r\nSummary: AKShare is an elegant and simple financial data interface library for Python, built for human beings!\r\nHome-page: \r\nAuthor: \r\nAuthor-email: AKFamily <albertandking@gmail.com>\r\nLicense: MIT\r\nLocation: C:\\Program Files\\Python312\\Lib\\site-packages\r\nRequires: beautifulsoup4, curl_cffi, decorator, html5lib, jsonpath, lxml, mini-racer, openpyxl, pandas, requests, tabulate, tqdm, urllib3, xlrd\r\nRequired-by:"}],"details":{"status":"completed","exitCode":0,"durationMs":3150,"aggregated":"Name: akshare\r\nVersion: 1.18.44\r\nSummary: AKShare is an elegant and simple financial data interface library for Python, built for human beings!\r\nHome-page: \r\nAuthor: \r\nAuthor-email: AKFamily <albertandking@gmail.com>\r\nLicense: MIT\r\nLocation: C:\\Program Files\\Python312\\Lib\\site-packages\r\nRequires: beautifulsoup4, curl_cffi, decorator, html5lib, jsonpath, lxml, mini-racer, openpyxl, pandas, requests, tabulate, tqdm, urllib3, xlrd\r\nRequired-by:","cwd":"C:\\Users\\Administrator\\.openclaw\\workspace"},"isError":false,"timestamp":1774232226048}}
{"type":"message","id":"f3e9f763","parentId":"00caa7cf","timestamp":"2026-03-23T02:18:29.268Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，akshare已经安装成功（版本1.18.44）。现在我需要：\n1. 测试akshare获取股票数据\n2. 编写实际的扫描脚本\n3. 创建持仓监控界面\n\n先编写一个测试脚本来验证akshare功能，然后编写增强版的扫描程序。","thinkingSignature":"reasoning_content"},{"type":"text","text":"✅ **akshare 已安装成功**（版本：1.18.44）\n\n现在编写实际数据扫描脚本和持仓监控界面："},{"type":"toolCall","id":"call_6bef621758c349c585944558","name":"write","arguments":{"path":"C:\\Users\\Administrator\\.openclaw\\workspace\\quant_scanner.py","content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\nA股量化交易扫描程序（基于akshare）\n功能：每日盘后扫描符合条件的股票\n\"\"\"\n\nimport akshare as ak\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime, timedelta\nimport json\nimport os\n\n# ============== 配置 ==============\n# 交易策略参数\nTOTAL_CAPITAL = 50000  # 总资金 5W\nSINGLE_STOCK_MAX_RATIO = 0.20  # 单票最大仓位 20%\nTOTAL_MAX_POSITION = 0.80  # 总持仓最大 80%\nTAKE_PROFIT_RATIO = 0.15  # 止盈 15%\nSTOP_LOSS_RATIO = 0.05  # 止损 5%\nMA5_PERIOD = 5\nMA10_PERIOD = 10\nVOLUME_MULTIPLIER = 1.5\nRSI_MAX = 70\n\n# 持仓文件\nPOSITION_FILE = \"quant_positions.json\"\nSCAN_RESULT_FILE = \"scan_results.json\"\n\n\nclass StockScanner:\n    \"\"\"股票扫描器\"\"\"\n\n    def __init__(self):\n        print(f\"初始化扫描器...\")\n\n    def get_stock_list(self):\n        \"\"\"获取主板非ST股票列表\"\"\"\n        print(\"正在获取主板股票列表...\")\n\n        # 获取所有A股股票列表\n        all_stocks = ak.stock_info_a_code_name()\n\n        # 筛选主板股票（60xxxx、00xxxx开头）并排除ST\n        main_board_stocks = []\n        for idx, row in all_stocks.iterrows():\n            code = row['code']\n            name = row['name']\n\n            # 筛选主板\n            if code.startswith('60') or code.startswith('00'):\n                # 排除ST股\n                if 'ST' in name or '*ST' in name:\n                    continue\n                main_board_stocks.append({\n                    'code': code,\n                    'name': name\n                })\n\n        print(f\"主板非ST股票数量：{len(main_board_stocks)}\")\n        return main_board_stocks\n\n    def calculate_indicators(self, stock_code):\n        \"\"\"计算技术指标\"\"\"\n        try:\n            # 获取历史数据（最近60天）\n            end_date = datetime.now().strftime('%Y%m%d')\n            start_date = (datetime.now() - timedelta(days=120)).strftime('%Y%m%d')\n\n            df = ak.stock_zh_a_hist(symbol=stock_code, period=\"daily\",\n                                        start_date=start_date, end_date=end_date,\n                                        adjust=\"qfq\")\n\n            if len(df) < 20:\n                return None, \"数据不足\"\n\n            # 计算指标\n            df['MA5'] = df['close'].rolling(window=MA5_PERIOD).mean()\n            df['MA10'] = df['close'].rolling(window=MA10_PERIOD).mean()\n            df['RSI'] = self.calculate_rsi(df['close'])\n\n            # 计算成交量变化\n            df['AvgVolume'] = df['volume'].rolling(window=20).mean()\n            df['VolumeRatio'] = df['volume'] / df['AvgVolume']\n\n            latest = df.iloc[-1]\n\n            return df, None\n\n        except Exception as e:\n            return None, str(e)\n\n    def calculate_rsi(self, prices, period=14):\n        \"\"\"计算RSI\"\"\"\n        delta = prices.diff()\n        gain = (delta.where(delta > 0, 0)).rolling(window=period).mean()\n        loss = (-delta.where(delta < 0, 0)).rolling(window=period).mean()\n\n        rs = gain / loss\n        rsi = 100 - (100 / (1 + rs))\n        return rsi\n\n    def check_buy_signal(self, df, stock_code, name):\n        \"\"\"检查买入条件\"\"\"\n        if df is None or len(df) < 10:\n            return False, \"数据不足\"\n\n        latest = df.iloc[-1]\n        prev = df.iloc[-2]\n\n        # 条件1: 金叉 - MA5上穿MA10\n        ma5_golden_cross = (prev['MA5'] < prev['MA10']) and (latest['MA5'] > latest['MA10'])\n\n        if not ma5_golden_cross:\n            return False, \"未出现金叉\"\n\n        # 条件2: 成交量放大 ≥ 1.5倍\n        volume_ratio = latest['VolumeRatio']\n        if volume_ratio < VOLUME_MULTIPLIER:\n            return False, f\"成交量不足（{volume_ratio:.2f}<{VOLUME_MULTIPLIER}）\"\n\n        # 条件3: RSI < 70\n        rsi = latest['RSI']\n        if pd.isna(rsi):\n            return False, \"RSI无效\"\n        if rsi >= RSI_MAX:\n            return False, f\"RSI过高（{rsi:.2f}≥{RSI_MAX}）\"\n\n        return True, f\"金叉+放量+RSI={rsi:.2f}\"\n\n    def scan_stocks(self, stock_list=None, max_results=20):\n        \"\"\"扫描股票寻找买入信号\"\"\"\n        print(f\"\\n开始扫描股票（最多{max_results}只）...\")\n\n        if stock_list is None:\n            stock_list = self.get_stock_list()\n\n        candidates = []\n        scanned_count = 0\n\n        for i, stock in enumerate(stock_list):\n            code = stock['code']\n            name = stock['name']\n\n            # 每100只打印进度\n            scanned_count += 1\n            if scanned_count % 100 == 0:\n                print(f\"已扫描 {scanned_count}/{len(stock_list)} 只股票，找到 {len(candidates)} 个候选\")\n\n            try:\n                df, error = self.calculate_indicators(code)\n                if error:\n                    continue\n\n                is_signal, reason = self.check_buy_signal(df, code, name)\n\n                if is_signal:\n                    latest = df.iloc[-1]\n                    candidates.append({\n                        'code': code,\n                        'name': name,\n                        'close': latest['close'],\n                        'change': latest.get('pct_chg', 0) * 100,\n                        'volume': latest['volume'],\n                        'volume_ratio': latest['VolumeRatio'],\n                        'rsi': latest['RSI'],\n                        'ma5': latest['MA5'],\n                        'ma10': latest['MA10'],\n                        'signal_reason': reason,\n                        'scan_time': datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n                    })\n\n                    if len(candidates) >= max_results:\n                        print(f\"已找到{max_results}个候选，停止扫描\")\n                        break\n\n            except Exception as e:\n                # 跳过错误继续\n                continue\n\n        print(f\"\\n扫描完成！共扫描 {scanned_count} 只股票，找到 {len(candidates)} 个候选\")\n\n        return candidates\n\n    def save_scan_results(self, candidates):\n        \"\"\"保存扫描结果\"\"\"\n        df = pd.DataFrame(candidates)\n        df.to_csv(SCAN_RESULT_FILE, index=False, encoding='utf-8-sig')\n        print(f\"\\n扫描结果已保存到：{SCAN_RESULT_FILE}\")\n\n        # 同时保存JSON格式\n        with open('scan_results.json', 'w', encoding='utf-8') as f:\n            json.dump(candidates, f, ensure_ascii=False, indent=2)\n\n        return df\n\n\nclass PositionMonitor:\n    \"\"\"持仓监控器\"\"\"\n\n    def __init__(self):\n        self.load_positions()\n        self.cash = TOTAL_CAPITAL\n        self.calculate_available_cash()\n\n    def load_positions(self):\n        \"\"\"加载持仓\"\"\"\n        if os.path.exists(POSITION_FILE):\n            with open(POSITION_FILE, 'r', encoding='utf-8') as f:\n                self.positions = json.load(f)\n        else:\n            self.positions = {}\n\n    def save_positions(self):\n        \"\"\"保存持仓\"\"\"\n        with open(POSITION_FILE, 'w', encoding='utf-8') as f:\n            json.dump(self.positions, f, ensure_ascii=False, indent=2)\n\n    def calculate_available_cash(self):\n        \"\"\"计算可用资金\"\"\"\n        used_capital = sum([pos['cost'] * pos['shares'] for pos in self.positions.values()])\n        self.cash = TOTAL_CAPITAL - used_capital\n\n    def check_sell_signals(self):\n        \"\"\"检查所有持仓的卖出信号\"\"\"\n        signals = []\n\n        if not self.positions:\n            return signals\n\n        print(f\"\\n检查 {len(self.positions)} 个持仓的卖出信号...\")\n\n        for code, pos in self.positions.items():\n            try:\n                # 获取最新价格\n                end_date = datetime.now().strftime('%Y%m%d')\n                start_date = (datetime.now() - timedelta(days=30)).strftime('%Y%m%d')\n\n                df = ak.stock_zh_a_hist(symbol=code, period=\"daily\",\n                                            start_date=start_date, end_date=end_date,\n                                            adjust=\"qfq\")\n\n                latest = df.iloc[-1]\n                current_price = latest['close']\n                cost_price = pos['cost']\n\n                # 计算盈亏比例\n                profit_ratio = (current_price - cost_price) / cost_price\n\n                # 检查止盈\n                if profit_ratio >= TAKE_PROFIT_RATIO:\n                    signals.append({\n                        'code': code,\n                        'name': pos['name'],\n                        'action': 'SELL',\n                        'signal_type': 'TAKE_PROFIT',\n                        'reason': f\"止盈：盈利{profit_ratio*100:.2f}%\",\n                        'current_price': current_price,\n                        'cost_price': cost_price,\n                        'shares': pos['shares'],\n                        'value': current_price * pos['shares'],\n                        'profit': (current_price - cost_price) * pos['shares'],\n                        'time': datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n                    })\n\n                # 检查止损\n                elif profit_ratio <= -STOP_LOSS_RATIO:\n                    signals.append({\n                        'code': code,\n                        'name': pos['name'],\n                        'action': 'SELL',\n                        'signal_type': 'STOP_LOSS',\n                        'reason': f\"止损：亏损{abs(profit_ratio)*100:.2f}%\",\n                        'current_price': current_price,\n                        'cost_price': cost_price,\n                        'shares': pos['shares'],\n                        'value': current_price * pos['shares'],\n                        'profit': (current_price - cost_price) * pos['shares'],\n                        'time': datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n                    })\n\n            except Exception as e:\n                print(f\"检查{code}时出错：{e}\")\n                continue\n\n        return signals\n\n    def get_portfolio_summary(self):\n        \"\"\"获取持仓汇总\"\"\"\n        if not self.positions:\n            return {\n                'stock_count': 0,\n                'total_value': 0,\n                'total_profit': 0,\n                'cash': self.cash,\n                'position_ratio': 0\n            }\n\n        stock_count = len(self.positions)\n        total_value = 0\n        total_cost = 0\n\n        for pos in self.positions.values():\n            try:\n                # 获取最新价格\n                end_date = datetime.now().strftime('%Y%m%d')\n                start_date = (datetime.now() - timedelta(days=5)).strftime('%Y%m%d')\n                df = ak.stock_zh_a_hist(symbol=pos['code'], period=\"daily\",\n                                            start_date=start_date, end_date=end_date,\n                                            adjust=\"qfq\")\n                latest_price = df.iloc[-1]['close']\n            except:\n                latest_price = pos['cost']  # 如果获取失败，使用成本价\n\n            value = latest_price * pos['shares']\n            cost = pos['cost'] * pos['shares']\n            total_value += value\n            total_cost += cost\n\n        total_profit = total_value - total_cost\n        position_ratio = (total_value / TOTAL_CAPITAL) * 100\n\n        return {\n            'stock_count': stock_count,\n            'total_value': total_value,\n            'total_cost': total_cost,\n            'total_profit': total_profit,\n            'profit_ratio': (total_profit / total_cost * 100) if total_cost > 0 else 0,\n            'cash': self.cash,\n            'position_ratio': position_ratio\n        }\n\n    def print_dashboard(self):\n        \"\"\"打印持仓监控界面\"\"\"\n        summary = self.get_portfolio_summary()\n        sell_signals = self.check_sell_signals()\n\n        print(\"\\n\" + \"=\"*80)\n        print(\"A股量化交易 - 持仓监控界面\")\n        print(\"=\"*80)\n\n        # 资金概览\n        print(f\"\\n【资金概览】\")\n        print(f\"总资金: {TOTAL_CAPITAL:,.2f} 元\")\n        print(f\"持仓市值: {summary['total_value']:,.2f} 元\")\n        print(f\"现金余额: {summary['cash']:,.2f} 元\")\n        print(f\"总持仓比例: {summary['position_ratio']:.2f}%\")\n        print(f\"浮盈浮亏: {summary['total_profit']:,.2f} 元 ({summary['profit_ratio']:.2f}%)\")\n\n        # 持仓明细\n        print(f\"\\n【持仓明细】({summary['stock_count']}只)\")\n        print(f\"{'代码':<10} {'名称':<15} {'持仓数':<10} {'成本价':<10} {'现价':<10} {'盈亏':<12} {'盈亏%':<10}\")\n        print(\"-\"*80)\n\n        for code, pos in self.positions.items():\n            try:\n                end_date = datetime.now().strftime('%Y%m%d')\n                start_date = (datetime.now() - timedelta(days=5)).strftime('%Y%m%d')\n                df = ak.stock_zh_a_hist(symbol=code, period=\"daily\",\n                                            start_date=start_date, end_date=end_date,\n                                            adjust=\"qfq\")\n                current_price = df.iloc[-1]['close']\n            except:\n                current_price = pos['cost']\n\n            profit = (current_price - pos['cost']) * pos['shares']\n            profit_ratio = profit / (pos['cost'] * pos['shares']) * 100\n\n            # 根据盈亏决定显示\n            sign = \"+\" if profit >= 0 else \"\"\n            profit_str = f\"{sign}{profit:,.2f}\"\n\n            print(f\"{code:<10} {pos['name']:<15} {pos['shares']:<10} {pos['cost']:<10.2f} {current_price:<10.2f} {profit_str:<12} {profit_ratio:>7.2f}%\")\n\n        # 卖出信号\n        if sell_signals:\n            print(f\"\\n【卖出信号】({len(sell_signals)}个)\")\n            for signal in sell_signals:\n                print(f\"⚠ {signal['code']} {signal['name']}: {signal['reason']}\")\n\n        # 风控提醒\n        print(f\"\\n【风控状态】\")\n        if summary['position_ratio'] > TOTAL_MAX_POSITION * 100:\n            print(f\"⚠ 总持仓比例超标 ({summary['position_ratio']:.2f}% > {TOTAL_MAX_POSITION*100:.0f}%)\")\n        else:\n            print(f\"✅ 总持仓比例正常 ({summary['position_ratio']:.2f}%)\")\n\n        print(\"=\"*80)\n\n\ndef main():\n    \"\"\"主函数\"\"\"\n    print(\"\\n\" + \"=\"*60)\n    print(\"A股量化交易 - 数据扫描与持仓监控\")\n    print(\"=\"*60)\n\n    # 创建监控器\n    monitor = PositionMonitor()\n\n    # 显示持仓监控界面\n    monitor.print_dashboard()\n\n    # 询问是否要扫描股票\n    print(\"\\n提示：使用 'python quant_scanner.py scan' 启动股票扫描\")\n\n    # 如果命令行参数是 'scan'，则执行扫描\n    import sys\n    if len(sys.argv) > 1 and sys.argv[1] == 'scan':\n        print(\"\\n开始扫描主板股票...\")\n        scanner = StockScanner()\n        candidates = scanner.scan_stocks(max_results=20)\n        scanner.save_scan_results(candidates)\n\n        # 显示候选股票\n        if candidates:\n            print(\"\\n【候选股票列表】\")\n            print(f\"{'代码':<10} {'名称':<15} {'现价':<10} {'涨跌幅':<10} {'量比':<10} {'RSI':<8} {'信号原因':<30}\")\n            print(\"-\"*100)\n            for stock in candidates:\n                print(f\"{stock['code']:<10} {stock['name']:<15} {stock['close']:<10.2f} {stock['change']:>8.2f}% {stock['volume_ratio']:.2f}x {stock['rsi']:.1f} {stock['signal_reason']}\")\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":137213,"output":3763,"cacheRead":0,"cacheWrite":0,"totalTokens":140976,"cost":{"input":0.08232779999999999,"output":0.0082786,"cacheRead":0,"cacheWrite":0,"total":0.09060639999999999}},"stopReason":"toolUse","timestamp":1774232226054}}
