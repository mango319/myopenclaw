es = {\n        'http': None,\n        'https': None,\n        'no_proxy': None\n    }\n\n    print(\"Requests session configured with NO proxy\")\n\n    # Test with session\n    print(\"Testing akshare with requests session...\")\n    stocks = ak.stock_info_a_code_name()\n    print(f\"Success! Got {len(stocks)} stocks using requests session\")\n\n    # Show first 5 stocks\n    print(\"\\nFirst 5 stocks:\")\n    print(stocks.head(5).to_string())\n\n    print(\"\\n[Method 2] SUCCESS!\")\n\nexcept Exception as e:\n    print(f\"[Method 2] FAILED: {e}\")\n\n# Method 3: Try using urllib without proxy\nprint(\"\\n[Method 3] Using urllib without proxy\")\nprint(\"-\"*80)\n\ntry:\n    import urllib.request\n    import urllib.parse\n\n    # Create opener without proxy\n    opener = urllib.request.build_opener()\n    opener.addheaders = [('User-Agent', 'Mozilla/5.0')]\n\n    print(\"Urllib opener configured with NO proxy\")\n\n    # Test with urllib\n    print(\"Testing akshare with urllib opener...\")\n    import importlib\n    importlib.reload(sys.modules['akshare'])\n    import akshare as ak\n\n    stocks = ak.stock_info_a_code_name()\n    print(f\"Success! Got {len(stocks)} stocks using urllib opener\")\n\n    print(\"\\n[Method 3] SUCCESS!\")\n\nexcept Exception as e:\n    print(f\"[Method 3] FAILED: {e}\")\n\n# Method 4: Check current proxy settings\nprint(\"\\n[Method 4] Check Current Proxy Settings\")\nprint(\"-\"*80)\n\nprint(\"Current proxy environment variables:\")\nfound_proxy = False\nfor var in ['HTTP_PROXY', 'HTTPS_PROXY', 'http_proxy', 'https_proxy', 'ALL_PROXY']:\n    value = os.environ.get(var, 'NOT SET')\n    if value and value != 'NOT SET' and value != 'NONE':\n        print(f\"  {var} = {value}\")\n        found_proxy = True\n\nif not found_proxy:\n    print(\"  No proxy environment variables detected\")\n\n# Method 5: Create a comprehensive test script\nprint(\"\\n[Method 5] Create Comprehensive Test\")\nprint(\"-\"*80)\n\ntest_script = \"\"\"\n# -*- coding: utf-8 -*-\nimport akshare as ak\nimport requests\n\nprint(\"=== Akshare Comprehensive Test ===\")\n\n# Test 1: Direct import\nprint(\"\\\\n[Test 1] Direct import\")\ntry:\n    stocks = ak.stock_info_a_code_name()\n    print(f\"Success! Got {len(stocks)} stocks\")\nexcept Exception as e:\n    print(f\"Failed: {e}\")\n\n# Test 2: With requests session (no proxy)\nprint(\"\\\\n[Test 2] With requests session (no proxy)\")\ntry:\n    session = requests.Session()\n    session.trust_env = False\n    session.proxies = {'http': None, 'https': None}\n\n    # Save to environment\n    import os\n    os.environ['HTTP_PROXY'] = ''\n    os.environ['HTTPS_PROXY'] = ''\n\n    import importlib\n    importlib.reload(sys.modules['akshare'])\n    import akshare as ak\n\n    stocks = ak.stock_info_a_code_name()\n    print(f\"Success! Got {len(stocks)} stocks\")\nexcept Exception as e:\n    print(f\"Failed: {e}\")\n\nprint(\"\\\\n=== Test Complete ===\")\n\"\"\"\n\n# Save test script\nwith open('akshare_comprehensive_test.py', 'w', encoding='utf-8') as f:\n    f.write(test_script)\n\nprint(\"Comprehensive test script saved to: akshare_comprehensive_test.py\")\n\n# Method 6: Final recommendation\nprint(\"\\n\" + \"=\"*80)\nprint(\"Final Recommendations\")\nprint(\"=\"*80)\n\nprint(\"\"\"\nIf all methods failed, please check:\n\n1. Windows Internet Options (inetcpl.cpl):\n   - Press Win + R, type 'inetcpl.cpl'\n   - Go to Internet Options -> Connections -> LAN Settings\n   - Uncheck all proxy boxes\n   - Click OK\n   - Restart your computer\n\n2. System Environment Variables:\n   - Press Win + R, type 'sysdm.cpl'\n   - Go to Advanced -> Environment Variables\n   - Delete or clear all HTTP_PROXY, HTTPS_PROXY variables\n   - Restart your computer\n\n3. Windows Registry (Advanced):\n   - Press Win + R, type 'regedit'\n   - Navigate to: HKEY_CURRENT_USER\\\\Software\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Internet Settings\n   - Check for ProxyServer or ProxyEnable settings\n   - Set 