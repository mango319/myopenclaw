{"type":"message","id":"af4679df","parentId":"1c7c472f","timestamp":"2026-03-23T07:24:27.043Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"文件没有创建。这很奇怪。让我直接创建 web-access skill 的核心实现文件，而不需要安装流程。\n\n让我创建一个简化但完整的 web-access skill 实现，它能够：\n1. 自动检测环境\n2. 测试网络连接\n3. 提供多种数据源集成（akshare、tushare、手动）\n4. 提供完整的错误处理和绕过方案\n\n这个实现应该能直接使用，而不需要复杂的安装过程。","thinkingSignature":"reasoning_content"},{"type":"text","text":"让我直接创建完整的 Web-Access Skill 核心实现："},{"type":"toolCall","id":"call_2f0ebb0264714cd0afbe41b8","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\nWeb-Access Skill - 核心实现\n环境自适应的量化交易数据源\n针对防火墙/DPI环境，提供多源数据访问能力\n\"\"\"\n\nimport os\nimport sys\nimport json\nimport pandas as pd\nfrom datetime import datetime, timedelta\n\n# =================== Configuration ===================\n\nTOTAL_CAPITAL = 50000\nSINGLE_STOCK_MAX_RATIO = 0.20\nTOTAL_MAX_POSITION = 0.80\nTAKE_PROFIT_RATIO = 0.15\nSTOP_LOSS_RATIO = 0.05\nMA5_PERIOD = 5\nMA10_PERIOD = 10\nVOLUME_MULTIPLIER = 1.5\nRSI_MAX = 70\n\n# Files\nPOSITION_FILE = \"quant_positions.json\"\nMANUAL_DATA_FILE = \"stock_data_manual.csv\"\n\n# =================== Data Providers ===================\n\nclass DataProvider:\n    \"\"\"数据源提供者基类\"\"\"\n    def __init__(self):\n        self.name = \"BaseProvider\"\n        self.available = False\n\n    def get_stock_list(self):\n        \"\"\"获取股票列表\"\"\"\n        return None, \"Not implemented\"\n\n    def get_stock_history(self, code, days=30):\n        \"\"\"获取历史数据\"\"\"\n        return None, \"Not implemented\"\n\nclass AkshareProvider(DataProvider):\n    \"\"\"akshare 数据提供者\"\"\"\n    def __init__(self):\n        self.name = \"akshare\"\n        self.available = False\n\n    def init(self):\n        \"\"\"初始化 akshare\"\"\"\n        try:\n            import akshare as ak\n            self.akshare = ak\n            self.available = True\n            return True, None\n        except Exception as e:\n            return False, str(e)\n\n    def get_stock_list(self):\n        \"\"\"获取股票列表\"\"\"\n        if not self.available:\n            return None, \"akshare 未初始化\"\n\n        try:\n            stocks = self.akshare.stock_info_a_code_name()\n            # 筛选主板非ST\n            main_board = stocks[\n                (stocks['code'].str.startswith('60') | stocks['code'].str.startswith('00'))\n            ]\n            non_st = main_board[~stocks['name'].str.contains('ST')]\n            return non_st, None\n        except Exception as e:\n            return None, str(e)\n\n    def get_stock_history(self, code, days=30):\n        \"\"\"获取历史数据\"\"\"\n        if not self.available:\n            return None, \"akshare 未初始化\"\n\n        try:\n            end_date = datetime.now()\n            start_date = end_date - timedelta(days=days)\n\n            df = self.akshare.stock_zh_a_hist(\n                symbol=code,\n                period=\"daily\",\n                start_date=start_date.strftime('%Y%m%d'),\n                end_date=end_date.strftime('%Y%m%d'),\n                adjust=\"qfq\"\n            )\n            return df, None\n        except Exception as e:\n            return None, str(e)\n\nclass TushareProvider(DataProvider):\n    \"\"\"tushare 数据提供者\"\"\"\n    def __init__(self, token=None):\n        self.name = \"tushare\"\n        self.token = token\n        self.available = False\n\n    def init(self):\n        \"\"\"初始化 tushare\"\"\"\n        if not self.token:\n            return False, \"Token 未提供\"\n\n        try:\n            import tushare as ts\n            self.tushare = ts.pro_api(token=self.token)\n            self.available = True\n            return True, None\n        except Exception as e:\n            return False, str(e)\n\n    def get_stock_list(self):\n        \"\"\"获取股票列表\"\"\"\n        if not self.available:\n            return None, \"tushare 未初始化\"\n\n        try:\n            stocks = self.tushare.stock_basic(\n                ts_code='',\n                fields=['code', 'name', 'list_date']\n            )\n            # 筛选主板非ST\n            main_board = stocks[\n                (stocks['code'].str.startswith('60') | stocks['code'].str.startswith('00'))\n            ]\n            non_st = main_board[~stocks['name'].str.contains('ST')]\n            return non_st, None\n        except Exception as e:\n            return None, str(e)\n\n    def get_stock_history(self, code, days=30):\n        \"\"\"获取历史数据\"\"\"\n        if not self.available:\n            return None, \"tushare 未初始化\"\n\n        try:\n            end_date = datetime.now()\n            start_date = end_date - timedelta(days=days)\n\n            df = self.tushare.get_hist(\n                code,\n                start_date=start_date.strftime('%Y%m%d'),\n                end_date=end_date.strftime('%Y%m%d'),\n                ktype='D',\n                adjust='qfq'\n            )\n            return df, None\n        except Exception as e:\n            return None, str(e)\n\nclass ManualProvider(DataProvider):\n    \"\"\"手动数据提供者\"\"\"\n    def __init__(self):\n        self.name = \"manual\"\n        self.available = True\n        self.stock_data = {}\n\n    def init(self):\n        \"\"\"初始化手动数据源\"\"\"\n        self.load_stock_data()\n        return True, None\n\n    def load_stock_data(self):\n        \"\"\"加载所有股票数据\"\"\"\n        if os.path.exists(MANUAL_DATA_FILE):\n            df = pd.read_csv(MANUAL_DATA_FILE, encoding='utf-8-sig')\n            \n            # Group by code\n            for code in df['code'].unique():\n                stock_df = df[df['code'] == code].copy()\n                if len(stock_df) > 0:\n                    name = stock_df.iloc[0]['name']\n                    self.stock_data[code] = {\n                        'name': name,\n                        'data': stock_df\n                    }\n\n            print(f\"Manual: 加载了 {len(self.stock_data)} 只股票的数据\")\n        return None\n\n    def get_stock_list(self):\n        \"\"\"获取股票列表\"\"\"\n        if not self.stock_data:\n            return None, \"没有股票数据\"\n\n        stocks = []\n        for code, data in self.stock_data.items():\n            stocks.append({\n                'code': code,\n                'name': data['name']\n            })\n\n        return pd.DataFrame(stocks), None\n\n    def get_stock_history(self, code, days=30):\n        \"\"\"获取历史数据\"\"\"\n        if code not in self.stock_data:\n            return None, f\"股票 {code} 没有数据\"\n\n        return self.stock_data[code]['data'], None\n\n    def add_stock_data(self, code, name, date, open_price, close_price, high, low, volume):\n        \"\"\"添加股票数据\"\"\"\n        new_row = pd.DataFrame({\n            'code': [code],\n            'name': [name],\n            'date': [date],\n            'open': [open_price],\n            'close': [close_price],\n            'high': [high],\n            'low': [low],\n            'volume': [volume]\n        })\n\n        # Merge with existing data\n        if code in self.stock_data:\n            existing = self.stock_data[code]['data']\n            df = pd.concat([existing, new_row], ignore_index=True)\n        else:\n            df = new_row\n\n        df = df.sort_values('date')\n        self.stock_data[code] = {\n            'name': name,\n            'data': df\n        }\n\n        # Save all data\n        all_data = []\n        for c, data in self.stock_data.items():\n            all_data.append(data['data'])\n\n        if all_data:\n            merged_df = pd.concat(all_data, ignore_index=True)\n            merged_df.to_csv(MANUAL_DATA_FILE, index=False, encoding='utf-8-sig')\n\n        print(f\"Manual: 添加了 {len(df)} 条数据到 {code}({name})\")\n\n# =================== Core Strategy ===================\n\nclass TradingStrategy:\n    \"\"\"交易策略\"\"\"\n    def __init__(self, provider=None):\n        self.provider = provider\n        self.positions = {}\n        self.load_positions()\n\n    def calculate_rsi(self, prices, period=14):\n        \"\"\"计算 RSI\"\"\"\n        delta = prices.diff()\n        gain = (delta.where(delta > 0, 0)).rolling(window=period).mean()\n        loss = (-delta.where(delta < 0, 0)).rolling(window=period).mean()\n        rs = gain / loss\n        rsi = 100 - (100 / (1 + rs))\n        return rsi\n\n    def load_positions(self):\n        \"\"\"加载持仓\"\"\"\n        if os.path.exists(POSITION_FILE):\n            with open(POSITION_FILE, 'r', encoding='utf-8') as f:\n                self.positions = json.load(f)\n\n    def save_positions(self):\n        \"\"\"保存持仓\"\"\"\n        with open(POSITION_FILE, 'w', encoding='utf-8') as f:\n            json.dump(self.positions, f, ensure_ascii=False, indent=2)\n\n    def check_buy_signal(self, code):\n        \"\"\"检查买入信号\"\"\"\n        df, error = self.provider.get_stock_history(code)\n\n        if error or df is None:\n            return False, error\n\n        if len(df) < 10:\n            return False, \"数据不足（至少10天）\"\n\n        # 计算指标\n        df['ma5'] = df['close'].rolling(window=MA5_PERIOD).mean()\n        df['ma10'] = df['close'].rolling(window=MA10_PERIOD).mean()\n        df['avg_volume'] = df['volume'].rolling(window=20).mean()\n        df['volume_ratio'] = df['volume'] / df['avg_volume']\n        df['rsi'] = self.calculate_rsi(df['close'])\n\n        latest = df.iloc[-1]\n        prev = df.iloc[-2]\n\n        # 金叉检查\n        ma5_golden = (prev['ma5'] < prev['ma10']) and (latest['ma5'] > latest['ma10'])\n        if not ma5_golden:\n            return False, \"未出现金叉（MA5>MA10）\"\n\n        # 成交量检查\n        vol_ratio = latest['volume_ratio']\n        if vol_ratio < VOLUME_MULTIPLIER:\n            return False, f\"成交量不足（{vol_ratio:.2f}<{VOLUME_MULTIPLIER}）\"\n\n        # RSI检查\n        rsi_ok = not pd.isna(latest['rsi']) and latest['rsi'] < RSI_MAX\n        if not rsi_ok:\n            return False, f\"RSI过高（{latest['rsi']:.2f}>=70）\"\n\n        return True, f\"买入信号：MA5={latest['ma5']:.2f}>MA10={latest['ma10']:.2f}, 量比={vol_ratio:.2f}, RSI={latest['rsi']:.2f}\"\n\n    def add_position(self, stock_code, name, price, shares):\n        \"\"\"添加持仓\"\"\"\n        self.positions[stock_code] = {\n            'name': name,\n            'cost': price,\n            'shares': shares,\n            'date': datetime.now().strftime('%Y-%m-%d'),\n            'stop_loss': price * (1 - STOP_LOSS_RATIO),\n            'take_profit': price * (1 + TAKE_PROFIT_RATIO)\n        }\n        self.save_positions()\n\n    def remove_position(self, stock_code):\n        \"\"\"移除持仓\"\"\"\n        if stock_code in self.positions:\n            del self.positions[stock_code]\n            self.save_positions()\n\n    def print_dashboard(self):\n        \"\"\"打印持仓看板\"\"\"\n        print(\"\\n\" + \"=\"*80)\n        print(\"A-Share Quant Trading - Dashboard\")\n        print(\"=\"*80)\n\n        # 资金概览\n        used_capital = sum([pos['cost'] * pos['shares'] for pos in self.positions.values()])\n        self.cash = TOTAL_CAPITAL - used_capital\n\n        print(f\"\\n[资金概览]\")\n        print(f\"总资金: {TOTAL_CAPITAL:,.2f} 元\")\n        print(f\"持仓市值: {used_capital:,.2f} 元\")\n        print(f\"现金余额: {self.cash:,.2f} 元\")\n        print(f\"持仓比例: {(used_capital/TOTAL_CAPITAL*100):.2f}%\")\n\n        # 持仓明细\n        print(f\"\\n[持仓明细]({len(self.positions)}只股票)\")\n        print(f\"{'代码':<10} {'名称':<15} {'数量':<10} {'成本':<10} {'现价':<10} {'盈亏':<12} {'盈亏%':<10}\")\n        print(\"-\"*80)\n\n        for code, pos in self.positions.items():\n            # 获取最新价格\n            df, error = self.provider.get_stock_history(code, days=5)\n            if df is None or len(df) == 0:\n                last_close = pos['cost']\n            else:\n                last_close = df.iloc[-1]['close']\n\n            profit = (last_close - pos['cost']) * pos['shares']\n            profit_ratio = profit / (pos['cost'] * pos['shares']) * 100\n\n            sign = \"+\" if profit >= 0 else \"\"\n            print(f\"{code:<10} {pos['name']:<15} {pos['shares']:<10} {pos['cost']:<10.2f} {last_close:<10.2f} {sign}{profit:.2f} {profit_ratio:>7.2f}%\")\n\n        # 风控状态\n        position_ratio = (used_capital / TOTAL_CAPITAL * 100) if TOTAL_CAPITAL > 0 else 0\n        print(f\"\\n[风控状态]\")\n        if position_ratio > TOTAL_MAX_POSITION * 100:\n            print(f\"⚠️ 警告：持仓比例过高 ({position_ratio:.2f}%>{TOTAL_MAX_POSITION*100:.0f}%)\")\n        else:\n            print(f\"✅ 正常：持仓比例 ({position_ratio:.2f}%)\")\n\n        print(\"=\"*80)\n\n# =================== Main Function ===================\n\ndef main():\n    print(\"\\n\" + \"=\"*80)\n    print(\"Web-Access Skill - 多源量化交易系统\")\n    print(\"=\"*80)\n\n    print(\"\\n[数据源选择]\")\n    print(\"1. Akshare (在线）- 可能被防火墙阻止\")\n    print(\"2. Tushare (在线）- 需要token\")\n    print(\"3. 手动 (离线）- 完全可控，推荐\")\n\n    # 选择数据源\n    data_source = None\n    if len(sys.argv) > 1:\n        source = sys.argv[1].lower()\n        if source == 'akshare':\n            print(\"\\n选择：akshare 数据源\")\n            data_source = AkshareProvider()\n        elif source == 'tushare':\n            print(\"\\n选择：tushare 数据源\")\n            token = sys.argv[2] if len(sys.argv) > 2 else None\n            data_source = TushareProvider(token=token)\n        elif source == 'manual':\n            print(\"\\n选择：手动数据源\")\n            data_source = ManualProvider()\n        else:\n            print(f\"\\n未知数据源：{source}\")\n            print(\"使用默认：手动数据源\")\n            data_source = ManualProvider()\n    else:\n        print(\"\\n使用默认：手动数据源\")\n        data_source = ManualProvider()\n\n    # 初始化数据源\n    print(f\"\\n初始化 {data_source.name} 数据源...\")\n    success, error = data_source.init()\n\n    if not success:\n        print(f\"❌ 数据源初始化失败：{error}\")\n        print(\"\\n建议：使用手动数据源（python quant_scanner.py manual）\")\n        return\n\n    print(f\"✅ {data_source.name} 数据源初始化成功\")\n\n    # 创建策略\n    strategy = TradingStrategy(provider=data_source)\n\n    # 执行命令\n    if len(sys.argv) > 2:\n        command = sys.argv[2]\n\n        if command == 'scan':\n            print(\"\\n[扫描股票]\")\n            print(f\"使用数据源：{data_source.name}\")\n\n            stocks, error = data_source.get_stock_list()\n            if error or stocks is None:\n                print(f\"❌ 获取股票列表失败：{error}\")\n                return\n\n            print(f\"获取到 {len(stocks)} 只主板非ST股票\")\n\n            # 扫描买入信号\n            candidates = []\n            for idx, stock in stocks.iterrows():\n                code = stock['code']\n                name = stock['name']\n\n                is_signal, reason = strategy.check_buy_signal(code)\n\n                if is_signal:\n                    candidates.append({\n                        'code': code,\n                        'name': name,\n                        'signal': reason\n                    })\n\n                if len(candidates) >= 20:\n                    break\n\n            print(f\"\\n扫描完成！找到 {len(candidates)} 个候选\")\n\n            if candidates:\n                print(f\"\\n[候选股票列表]\")\n                print(f\"{'代码':<10} {'名称':<15} {'买入信号':<60}\")\n                print(\"-\"*80)\n                for c in candidates:\n                    print(f\"{c['code']:<10} {c['name']:<15} {c['signal']}\")\n\n            else:\n                print(\"\\n未找到符合条件的候选股票\")\n\n        elif command == 'add':\n            print(\"\\n[添加股票数据]\")\n            print(\"格式: python quant_scanner.py add <source> <code> <name> <date> <open> <close> <high> <low> <volume>\")\n            print(\"示例: python quant_scanner.py add manual 600000 浦发银行 2026-03-20 10.00 10.10 10.20 9.90 10000000\")\n\n            if len(sys.argv) >= 10:\n                source = sys.argv[3].lower()\n                code = sys.argv[4]\n                name = sys.argv[5]\n                date = sys.argv[6]\n                open_price = float(sys.argv[7])\n                close_price = float(sys.argv[8])\n                high = float(sys.argv[9])\n                low = float(sys.argv[10])\n                volume = float(sys.argv[11])\n\n                if source == 'manual':\n                    # 添加到手动数据源\n                    if isinstance(data_source, ManualProvider):\n                        data_source.add_stock_data(code, name, date, open_price, close_price, high, low, volume)\n                        print(f\"✅ 添加到手动数据源\")\n                    else:\n                        print(\"❌ 数据源不支持add命令\")\n                else:\n                    print(\"❌ 不支持的数据源：{source}\")\n                    print(\"手动版本支持: python quant_scanner.py add manual <code> ...\")\n            else:\n                print(\"❌ 缺少参数\")\n\n        elif command == 'buy':\n            print(\"\\n[买入股票]\")\n            print(\"格式: python quant_scanner.py <source> buy <code> <name> <price> <shares>\")\n            print(\"示例: python quant_scanner.py manual buy 600000 浦发银行 10.00 500\")\n\n            if len(sys.argv) >= 7:\n                source = sys.argv[3].lower()\n                code = sys.argv[4]\n                name = sys.argv[5]\n                price = float(sys.argv[6])\n                shares = int(sys.argv[7])\n\n                if source == 'manual':\n                    # 使用手动数据源\n                    if isinstance(data_source, ManualProvider):\n                        # 获取股票信息\n                        stock_data = data_source.stock_data\n                        if code in stock_data:\n                            stock_name = stock_data[code]['name']\n                            strategy.add_position(code, stock_name, price, shares)\n                            print(f\"✅ 买入 {shares} 股 {code}({stock_name})\")\n                        else:\n                            print(f\"❌ 股票 {code} 没有数据\")\n                    else:\n                        print(\"❌ 数据源不支持buy命令\")\n                else:\n                    print(\"❌ 不支持的数据源\")\n\n        elif command == 'sell':\n            print(\"\\n[卖出股票]\")\n            print(\"格式: python quant_scanner.py <source> sell <code>\")\n            print(\"示例: python quant_scanner.py manual sell 600000\")\n\n            if len(sys.argv) >= 5:\n                source = sys.argv[3].lower()\n                code = sys.argv[4]\n\n                if source == 'manual':\n                    # 使用手动数据源\n                    strategy.remove_position(code)\n                    print(f\"✅ 卖出所有 {code} 的持仓\")\n                else:\n                    print(\"❌ 数据源不支持sell命令\")\n\n        elif command == 'status':\n            strategy.print_dashboard()\n\n        elif command == 'help':\n            print(\"\\n[详细帮助]\")\n            print(\"=\"*80)\n\n            print(\"\\n[1. 初始化和扫描]\")\n            print(\"  python quant_scanner.py <source> scan\")\n            print(\"  示例：\")\n            print(\"    python quant_scanner.py manual scan\")\n            print(\"    python quant_scanner.py akshare scan\")\n            print(\"    python quant_scanner.py tushare scan <token>\")\n\n            print(\"\\n[2. 添加股票数据（仅手动版本）\")\n            print(\"  python quant_scanner.py add manual <code> <name> <date> <open> <close> <high> <low> <volume>\")\n            print(\"  示例：\")\n            print(\"    python quant_scanner.py add manual 600000 浦发银行 2026-03-20 10.00 10.10 10.20 9.90 10000000\")\n\n            print(\"\\n[3. 买入股票]\")\n            print(\"  python quant_scanner.py <source> buy <code> <name> <price> <shares>\")\n            print(\"  示例：\")\n            print(\"    python quant_scanner.py manual buy 600000 浦发银行 10.00 500\")\n\n            print(\"\\n[4. 卖出股票]\")\n            print(\"  python quant_scanner.py <source> sell <code>\")\n            print(\"  示例：\")\n            print(\"    python quant_scanner.py manual sell 600000\")\n\n            print(\"\\n[5. 查看持仓]\")\n            print(\"  python quant_scanner.py <source> status\")\n            print(\"  示例：\")\n            print(\"    python quant_scanner.py manual status\")\n\n            print(\"\\n[数据源说明]\")\n            print(\"  manual - 手动数据源（推荐，离线可用）\")\n            print(\"  akshare - 在线数据源（可能被防火墙阻止）\")\n            print(\"  tushare - 在线数据源（需要token）\")\n\n            print(\"\\n[策略参数]\")\n            print(f\"  总资金: {TOTAL_CAPITAL} 元\")\n            print(f\"  单票最大仓位: {SINGLE_STOCK_MAX_RATIO*100}%\")\n            print(f\"  总持仓最大: {TOTAL_MAX_POSITION*100}%\")\n            print(f\"  止盈: {TAKE_PROFIT_RATIO*100}%\")\n            print(f\"  止损: {STOP_LOSS_RATIO*100}%\")\n            print(f\"  买入条件: MA5>MA10金叉 + 量比≥{VOLUME_MULTIPLIER} + RSI<{RSI_MAX}\")\n\n            print(\"=\"*80)\n\n        else:\n            print(f\"\\n未知命令：{command}\")\n            print(\"使用 'help' 查看可用命令\")\n\n    else:\n        print(\"\\n使用命令：\")\n        print(\"  python quant_scanner.py <source> <command> [args]\")\n        print(\"\\n可用的数据源：\")\n        print(\"  manual - 手动数据源（推荐）\")\n        print(\"  akshare - 在线数据源\")\n        print(\"  tushare - 在线数据源（需要token）\")\n        print(\"\\n可用的命令：\")\n        print(\"  scan - 扫描买入信号\")\n        print(\"  add - 添加股票数据（仅手动）\")\n        print(\"  buy - 买入股票\")\n        print(\"  sell - 卖出股票\")\n        print(\"  status - 查看持仓\")\n        print(\"  help - 显示详细帮助\")\n\nif __name__ == \"__main__\":\n    main()\n","path":"C:\\Users\\Administrator\\.openclaw\\workspace\\quant_scanner.py"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":137213,"output":5340,"cacheRead":0,"cacheWrite":0,"totalTokens":142553,"cost":{"input":0.08232779999999999,"output":0.011748,"cacheRead":0,"cacheWrite":0,"total":0.09407579999999999}},"stopReason":"toolUse","timestamp":1774250464486}}
