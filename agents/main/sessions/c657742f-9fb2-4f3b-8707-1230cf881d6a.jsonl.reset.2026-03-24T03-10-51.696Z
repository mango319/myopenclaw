{"type":"message","id":"00d3460a","parentId":"8ad7091c","timestamp":"2026-03-23T02:10:24.606Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"用户确认了：\n1. 资金总量：5W\n2. 改用QQ推送（而非微信）\n3. 需要搭建本地监控程序\n\n现在我需要：\n1. 创建一个Python量化监控脚本\n2. 实现策略逻辑：\n   - 5日均线上穿10日均线（金叉）\n   - 成交量放大≥1.5倍\n   - RSI<70\n   - 排除ST股、仅主板（60/00开头）\n3. 仓位管理：\n   - 单票≤10%（5W*10%=5000元）\n   - 总持仓≤50%（5W*50%=2.5W）\n4. 风控：\n   - 盈利15%止盈\n   - 亏损5%止损\n\n关于QQ推送：\n- 我可以使用QQbot的message工具来发送消息给用户\n- 需要知道用户的chat_id（从上下文中可以看到：qqbot:c2c:DB0D276754D361B0256C70255C178BD8）\n\n让我创建一个Python脚本框架。由于我没有实时的股票数据API，我需要：\n1. 创建脚本框架\n2. 说明需要接入的数据源（如akshare、tushare等）\n3. 说明如何通过QQ推送信号\n\n让我开始编写脚本。","thinkingSignature":"reasoning_content"},{"type":"text","text":"好的！我来为你搭建量化监控程序。首先创建Python脚本框架："},{"type":"toolCall","id":"call_92a22470bd684f0c8665d2a8","name":"write","arguments":{"path":"C:\\Users\\Administrator\\.openclaw\\workspace\\quant_monitor.py","content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\nA股量化交易监控程序\n策略：5日线上穿10日均线 + 成交量放大1.5倍 + RSI<70\n风控：单票≤10%，总持仓≤50%，盈利15%止盈，亏损5%止损\n推送：QQ消息\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime, time\nimport json\nimport os\n\n# ============== 配置区域 ==============\nTOTAL_CAPITAL = 50000  # 总资金 5W\nSINGLE_STOCK_MAX_RATIO = 0.10  # 单票最大仓位 10%\nTOTAL_MAX_POSITION = 0.50  # 总持仓最大 50%\nTAKE_PROFIT_RATIO = 0.15  # 止盈 15%\nSTOP_LOSS_RATIO = 0.05  # 止损 5%\nMA5_PERIOD = 5\nMA10_PERIOD = 10\nVOLUME_MULTIPLIER = 1.5\nRSI_MAX = 70\n\n# QQ推送配置（需要通过QQbot接口实现）\nQQ_CHAT_ID = \"qqbot:c2c:DB0D276754D361B0256C70255C178BD8\"\n\n# 数据源配置（需要安装：pip install akshare）\n# 使用 akshare 免费数据源\nDATA_SOURCE = \"akshare\"  # 可选: akshare, tushare\n\n# ============== 日志配置 ==============\nLOG_FILE = \"quant_trading_log.txt\"\nPOSITION_FILE = \"quant_positions.json\"\n\nclass QuantStrategy:\n    \"\"\"量化交易策略类\"\"\"\n\n    def __init__(self):\n        self.positions = {}  # 持仓 {股票代码: {'cost': 成本, 'shares': 数量, 'date': 日期}}\n        self.cash = TOTAL_CAPITAL\n        self.load_positions()\n\n    def calculate_ma(self, prices, period):\n        \"\"\"计算移动平均线\"\"\"\n        return prices.rolling(window=period).mean()\n\n    def calculate_rsi(self, prices, period=14):\n        \"\"\"计算RSI指标\"\"\"\n        delta = prices.diff()\n        gain = (delta.where(delta > 0, 0)).rolling(window=period).mean()\n        loss = (-delta.where(delta < 0, 0)).rolling(window=period).mean()\n        rs = gain / loss\n        rsi = 100 - (100 / (1 + rs))\n        return rsi\n\n    def check_buy_signal(self, df):\n        \"\"\"检查买入信号\"\"\"\n        latest = df.iloc[-1]\n\n        # 1. 检查是否为主板股票（60/00开头）\n        stock_code = latest['股票代码']\n        if not (stock_code.startswith('60') or stock_code.startswith('00')):\n            return False, \"非主板股票\"\n\n        # 2. 检查是否为ST股\n        name = latest['股票简称']\n        if 'ST' in name or '*ST' in name:\n            return False, \"ST股票\"\n\n        # 3. 计算5日、10日均线\n        ma5 = self.calculate_ma(df['收盘'], MA5_PERIOD).iloc[-1]\n        ma10 = self.calculate_ma(df['收盘'], MA10_PERIOD).iloc[-1]\n        prev_ma5 = self.calculate_ma(df['收盘'], MA5_PERIOD).iloc[-2]\n        prev_ma10 = self.calculate_ma(df['收盘'], MA10_PERIOD).iloc[-2]\n\n        # 4. 检查金叉：5日均线上穿10日均线\n        if not (prev_ma5 < prev_ma10 and ma5 > ma10):\n            return False, \"未出现金叉\"\n\n        # 5. 检查RSI<70\n        rsi = self.calculate_rsi(df['收盘']).iloc[-1]\n        if rsi >= RSI_MAX:\n            return False, f\"RSI过高({rsi:.2f}>=70)\"\n\n        # 6. 检查成交量放大≥1.5倍\n        avg_volume = df['成交量'].iloc[-20:-1].mean()  # 近20日平均成交量\n        latest_volume = df['成交量'].iloc[-1]\n        if latest_volume < avg_volume * VOLUME_MULTIPLIER:\n            return False, f\"成交量未达1.5倍({latest_volume/avg_volume:.2f})\"\n\n        return True, f\"满足所有条件: MA5={ma5:.2f}>MA10={ma10:.2f}, RSI={rsi:.2f}, 量比={latest_volume/avg_volume:.2f}\"\n\n    def check_sell_signal(self, stock_code, current_price):\n        \"\"\"检查卖出信号\"\"\"\n        if stock_code not in self.positions:\n            return False, None\n\n        position = self.positions[stock_code]\n        cost_price = position['cost']\n        shares = position['shares']\n\n        # 计算盈亏比例\n        profit_ratio = (current_price - cost_price) / cost_price\n\n        # 止盈\n        if profit_ratio >= TAKE_PROFIT_RATIO:\n            return True, f\"止盈: 盈利{profit_ratio*100:.2f}%\"\n\n        # 止损\n        if profit_ratio <= -STOP_LOSS_RATIO:\n            return True, f\"止损: 亏损{abs(profit_ratio)*100:.2f}%\"\n\n        return False, None\n\n    def get_available_cash(self):\n        \"\"\"获取可用资金\"\"\"\n        used_capital = sum([pos['cost'] * pos['shares'] for pos in self.positions.values()])\n        return TOTAL_CAPITAL - used_capital\n\n    def calculate_position_size(self, price):\n        \"\"\"计算可买入数量\"\"\"\n        cash = self.get_available_cash()\n        max_position_value = TOTAL_CAPITAL * TOTAL_MAX_POSITION\n        single_stock_max = TOTAL_CAPITAL * SINGLE_STOCK_MAX_RATIO\n\n        # 不能超过单票最大仓位\n        if cash > single_stock_max:\n            return int(single_stock_max / price)\n\n        # 不能超过总持仓最大仓位\n        if cash > max_position_value:\n            return int(max_position_value / price)\n\n        return int(cash / price)\n\n    def add_position(self, stock_code, name, price, shares):\n        \"\"\"添加持仓\"\"\"\n        self.positions[stock_code] = {\n            'name': name,\n            'cost': price,\n            'shares': shares,\n            'date': datetime.now().strftime('%Y-%m-%d'),\n            'stop_loss': price * (1 - STOP_LOSS_RATIO),\n            'take_profit': price * (1 + TAKE_PROFIT_RATIO)\n        }\n        self.save_positions()\n\n    def remove_position(self, stock_code):\n        \"\"\"移除持仓\"\"\"\n        if stock_code in self.positions:\n            del self.positions[stock_code]\n            self.save_positions()\n\n    def save_positions(self):\n        \"\"\"保存持仓到文件\"\"\"\n        with open(POSITION_FILE, 'w', encoding='utf-8') as f:\n            json.dump(self.positions, f, ensure_ascii=False, indent=2)\n\n    def load_positions(self):\n        \"\"\"从文件加载持仓\"\"\"\n        if os.path.exists(POSITION_FILE):\n            with open(POSITION_FILE, 'r', encoding='utf-8') as f:\n                self.positions = json.load(f)\n\n    def get_positions_summary(self):\n        \"\"\"获取持仓汇总\"\"\"\n        if not self.positions:\n            return \"空仓\"\n\n        summary = []\n        for code, pos in self.positions.items():\n            summary.append(f\"{code} {pos['name']}: {pos['shares']}股@{pos['cost']:.2f}\")\n        return \"\\n\".join(summary)\n\n\nclass QQPusher:\n    \"\"\"QQ消息推送类（需要通过message工具实现）\"\"\"\n\n    @staticmethod\n    def format_message(msg_type, content):\n        \"\"\"格式化QQ消息\"\"\"\n        timestamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n        header = {\n            'signal': f\"📊【交易信号】{timestamp}\",\n            'position': f\"💰【持仓变动】{timestamp}\",\n            'risk': f\"⚠️【风控提醒】{timestamp}\",\n            'daily': f\"📋【日报】{timestamp}\"\n        }\n        return f\"{header.get(msg_type, '')}\\n{content}\"\n\n    @staticmethod\n    def send_via_command(msg):\n        \"\"\"生成QQ推送命令（需要在命令行执行）\"\"\"\n        # 这里需要根据实际QQbot配置调整\n        # 示例：使用 message tool 发送\n        print(f\"[QQ推送] {msg}\")\n        # 实际推送需要在支持QQbot的环境下执行:\n        # message action=send channel=qqbot to={QQ_CHAT_ID} message=\"{msg}\"\n\n\ndef main():\n    \"\"\"主函数\"\"\"\n    strategy = QuantStrategy()\n\n    print(\"=\" * 60)\n    print(\"A股量化交易监控程序\")\n    print(f\"总资金: {TOTAL_CAPITAL:,.0f} 元\")\n    print(f\"策略: MA{MA5_PERIOD}>MA{MA10_PERIOD} 金叉 + 量比≥{VOLUME_MULTIPLIER} + RSI<{RSI_MAX}\")\n    print(f\"风控: 止盈{TAKE_PROFIT_RATIO*100:.0f}% / 止损{STOP_LOSS_RATIO*100:.0f}%\")\n    print(f\"仓位: 单票≤{SINGLE_STOCK_MAX_RATIO*100:.0f}% / 总持仓≤{TOTAL_MAX_POSITION*100:.0f}%\")\n    print(\"=\" * 60)\n\n    # 打印当前持仓\n    print(f\"\\n当前持仓:\\n{strategy.get_positions_summary()}\")\n    print(f\"\\n可用资金: {strategy.get_available_cash():,.0f} 元\")\n\n    # 模拟扫描股票（实际需要接入数据源）\n    print(\"\\n提示：需要接入股票数据源\")\n    print(\"推荐数据源：\")\n    print(\"1. akshare (免费): pip install akshare\")\n    print(\"2. tushare (需要token): pip install tushare\")\n    print(\"\\n脚本已准备就绪，等待数据源接入后启动扫描...\")\n\n    # 生成QQ推送测试消息\n    test_msg = QQPusher.format_message('daily',\n        f\"监控程序已启动\\n\"\n        f\"总资金: {TOTAL_CAPITAL:,.0f}元\\n\"\n        f\"当前持仓: {strategy.get_positions_summary()}\")\n    )\n    QQPusher.send_via_command(test_msg)\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":1985,"output":2842,"cacheRead":121689,"cacheWrite":0,"totalTokens":126516,"cost":{"input":0.001191,"output":0.0062524,"cacheRead":0.01338579,"cacheWrite":0,"total":0.02082919}},"stopReason":"toolUse","timestamp":1774231730212}}
