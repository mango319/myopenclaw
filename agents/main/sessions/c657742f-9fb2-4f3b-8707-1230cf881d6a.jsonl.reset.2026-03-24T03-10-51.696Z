{"type":"message","id":"d2ef589d","parentId":"ed2f730f","timestamp":"2026-03-23T05:33:11.663Z","message":{"role":"toolResult","toolCallId":"call_b9466863f20c49e88ec0999d","toolName":"read","content":[{"type":"text","text":"\"\"\"\n禁用代理的 akshare 测试\n\"\"\"\nimport os\n\n# 清除所有代理环境变量\nprint(\"禁用代理设置...\")\n\nos.environ['HTTP_PROXY'] = ''\nos.environ['HTTPS_PROXY'] = ''\nos.environ['http_proxy'] = ''\nos.environ['https_proxy'] = ''\nos.environ['NO_PROXY'] = '*'\n\nprint(\"代理设置已禁用\")\n\nimport akshare as ak\nimport pandas as pd\nfrom datetime import datetime, timedelta\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"测试 akshare 数据源（无代理）\")\nprint(\"=\"*60)\n\ntry:\n    # 获取主板股票\n    print(\"\\n[1] 获取主板非ST股票...\")\n    stocks = ak.stock_info_a_code_name()\n    main_board = stocks[\n        (stocks['code'].str.startswith('60') | stocks['code'].str.startswith('00'))\n    ]\n    non_st = main_board[\n        ~main_board['name'].str.contains('ST')\n    ]\n    print(f\"主板非ST股票：{len(non_st)}\")\n\n    # 获取历史数据测试（最近30天）\n    if len(non_st) > 0:\n        test_code = non_st.iloc[0]['code']\n        test_name = non_st.iloc[0]['name']\n\n        print(f\"\\n[2] 测试获取 {test_code}({test_name}) 历史数据...\")\n\n        end_date = datetime.now().strftime('%Y%m%d')\n        start_date = (datetime.now() - timedelta(days=30)).strftime('%Y%m%d')\n\n        print(f\"日期范围: {start_date} ~ {end_date}\")\n\n        df = ak.stock_zh_a_hist(\n            symbol=test_code,\n\n[84 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1774243991653}}
