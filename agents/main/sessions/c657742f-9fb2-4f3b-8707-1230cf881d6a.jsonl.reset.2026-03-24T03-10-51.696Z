{"type":"message","id":"fefb869a","parentId":"bc06b356","timestamp":"2026-03-23T02:56:54.243Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"用户要求\"放宽条件快速测试\"。我应该修改扫描脚本，放宽筛选条件，以便更容易找到候选股票。\n\n放宽的建议：\n1. 降低成交量要求：从1.5倍降到1.2倍或1.0倍\n2. 提高RSI上限：从70提高到75或80\n3. 或者只看金叉，不限制成交量\n4. 或者只看金叉+放量，不限制RSI\n\n让我创建一个快速测试版本。","thinkingSignature":"reasoning_content"},{"type":"text","text":"好的！我来创建放宽条件的快速测试版本："},{"type":"toolCall","id":"call_da0c7093e9664c7984c6ce3d","name":"write","arguments":{"content":"import akshare as ak\nimport pandas as pd\nfrom datetime import datetime, timedelta\n\nprint(\"放宽条件快速测试...\")\n\n# 放宽后的策略参数\nVOLUME_MULTIPLIER_RELAXED = 1.0  # 降低到1.0倍（原1.5倍）\nRSI_MAX_RELAXED = 85  # 提高到85（原70）\nMAX_STOCKS = 100  # 增加扫描股票数量\n\ntry:\n    # 获取主板股票列表\n    stocks = ak.stock_info_a_code_name()\n    print(f\"Total stocks: {len(stocks)}\")\n\n    # 筛选主板非ST\n    main_board = []\n    for idx, row in stocks.iterrows():\n        code = row['code']\n        name = row['name']\n        if code.startswith('60') or code.startswith('00'):\n            if 'ST' in name or '*ST' in name:\n                continue\n            main_board.append({'code': code, 'name': name})\n\n    print(f\"Main board non-ST stocks: {len(main_board)}\")\n\n    # 扫描前100只股票测试\n    candidates = []\n    scanned_count = 0\n\n    for i, stock in enumerate(main_board[:MAX_STOCKS]):\n        code = stock['code']\n        name = stock['name']\n\n        scanned_count += 1\n        if scanned_count % 10 == 0:\n            print(f\"已扫描 {scanned_count}/{MAX_STOCKS} 只股票，找到 {len(candidates)} 个候选\")\n\n        try:\n            # 获取历史数据\n            end_date = datetime.now().strftime('%Y%m%d')\n            start_date = (datetime.now() - timedelta(days=120)).strftime('%Y%m%d')\n\n            df = ak.stock_zh_a_hist(symbol=code, period=\"daily\",\n                                       start_date=start_date, end_date=end_date,\n                                       adjust=\"qfq\")\n\n            if len(df) < 20:\n                continue\n\n            # 计算指标\n            df['MA5'] = df['close'].rolling(window=5).mean()\n            df['MA10'] = df['close'].rolling(window=10).mean()\n            df['AvgVolume'] = df['volume'].rolling(window=20).mean()\n            df['VolumeRatio'] = df['volume'] / df['AvgVolume']\n\n            latest = df.iloc[-1]\n            prev = df.iloc[-2]\n\n            # 金叉检查\n            ma5_golden = (prev['MA5'] < prev['MA10']) and (latest['MA5'] > latest['MA10'])\n\n            # 成交量检查（放宽）\n            vol_ok = latest['VolumeRatio'] >= VOLUME_MULTIPLIER_RELAXED\n\n            # RSI计算（放宽）\n            delta = df['close'].diff()\n            gain = (delta.where(delta > 0, 0)).rolling(window=14).mean()\n            loss = (-delta.where(delta < 0, 0)).rolling(window=14).mean()\n            rs = gain / loss\n            rsi = 100 - (100 / (1 + rs))\n            rsi_ok = not pd.isna(rsi.iloc[-1]) and rsi.iloc[-1] < RSI_MAX_RELAXED\n\n            # 记录所有结果\n            candidates.append({\n                'code': code,\n                'name': name,\n                'close': latest['close'],\n                'change': latest.get('pct_chg', 0) * 100,\n                'ma5': latest['MA5'],\n                'ma10': latest['MA10'],\n                'volume_ratio': latest['VolumeRatio'],\n                'rsi': rsi.iloc[-1],\n                'ma5_golden': ma5_golden,\n                'vol_ok': vol_ok,\n                'rsi_ok': rsi_ok\n            })\n\n        except Exception as e:\n            continue\n\n    print(f\"\\n扫描完成！共扫描 {scanned_count} 只股票\")\n\n    # 保存完整结果\n    df = pd.DataFrame(candidates)\n    df.to_csv('test_results_relaxed.csv', index=False, encoding='utf-8-sig')\n    print(f\"完整结果已保存到：test_results_relaxed.csv\")\n\n    # 统计放宽后的候选\n    relaxed_candidates = df[df['ma5_golden'] & df['vol_ok'] & df['rsi_ok']]\n    print(f\"\\n【放宽条件后候选】(满足金叉+量比≥{VOLUME_MULTIPLIER_RELAXED}+RSI<{RSI_MAX_RELAXED})\")\n    print(f\"候选数量: {len(relaxed_candidates)}\")\n\n    if len(relaxed_candidates) > 0:\n        print(f\"\\n{'代码':<10} {'名称':<15} {'现价':<10} {'涨跌幅':<10} {'量比':<10} {'RSI':<10}\")\n        print(\"-\"*80)\n        for idx, row in relaxed_candidates.iterrows():\n            print(f\"{row['code']:<10} {row['name']:<15} {row['close']:<10.2f} {row['change']:>8.2f}% {row['volume_ratio']:.2f} {row['rsi']:.1f}\")\n\n    # 显示不同条件的候选数量\n    print(f\"\\n【条件统计】\")\n    print(f\"出现金叉的股票：{len(df[df['ma5_golden']])}\")\n    print(f\"量比≥{VOLUME_MULTIPLIER_RELAXED}的股票：{len(df[df['vol_ok']])}\")\n    print(f\"RSI<{RSI_MAX_RELAXED}的股票：{len(df[df['rsi_ok']])}\")\n    print(f\"同时满足三条件的股票：{len(relaxed_candidates)}\")\n\n    # 尝试更宽松条件\n    very_relaxed = df[df['ma5_golden']]  # 只看金叉\n    print(f\"\\n【最宽松条件】(仅看金叉)\")\n    print(f\"候选数量: {len(very_relaxed)}\")\n\n    if len(very_relaxed) > 0:\n        print(f\"\\n{'代码':<10} {'名称':<15} {'现价':<10} {'涨跌幅':<10}\")\n        print(\"-\"*80)\n        for idx, row in very_relaxed.head(10).iterrows():\n            print(f\"{row['code']:<10} {row['name']:<15} {row['close']:<10.2f} {row['change']:>8.2f}%\")\n\n    # 保存放宽后的候选\n    relaxed_candidates.to_csv('candidates_relaxed.csv', index=False, encoding='utf-8-sig')\n    print(f\"\\n放宽后的候选已保存到：candidates_relaxed.csv\")\n\n    very_relaxed.to_csv('candidates_golden_only.csv', index=False, encoding='utf-8-sig')\n    print(f\"仅金叉的候选已保存到：candidates_golden_only.csv\")\n\nexcept Exception as e:\n    print(f\"测试失败：{e}\")\n","path":"C:\\Users\\Administrator\\.openclaw\\workspace\\test_relaxed.py"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":137213,"output":1730,"cacheRead":0,"cacheWrite":0,"totalTokens":138943,"cost":{"input":0.08232779999999999,"output":0.0038060000000000004,"cacheRead":0,"cacheWrite":0,"total":0.0861338}},"stopReason":"toolUse","timestamp":1774234569273}}
