{"type":"message","id":"23b6b821","parentId":"9fa58022","timestamp":"2026-03-23T06:13:11.400Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好，我看到了 save_stock_data 的定义。它不接受任何参数，直接保存当前的所有股票数据到 CSV。但是在 add_stock_data 方法中调用时，传入的是列名字符串，这不对。让我修复 add_stock_data 方法。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_b7b7c55d04ff4f709dccbf08","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\n完全手动版的量化交易监控（不依赖网络数据源）\n用户手动输入股票代码、价格、数量，系统计算买卖信号\n\"\"\"\n\nimport pandas as pd\nfrom datetime import datetime, timedelta\nimport json\nimport sys\nimport os\n\n# =================== Configuration ===================\n\nTOTAL_CAPITAL = 50000\nSINGLE_STOCK_MAX_RATIO = 0.20\nTOTAL_MAX_POSITION = 0.80\nTAKE_PROFIT_RATIO = 0.15\nSTOP_LOSS_RATIO = 0.05\nMA5_PERIOD = 5\nMA10_PERIOD = 10\nVOLUME_MULTIPLIER = 1.5\nRSI_MAX = 70\n\n# Position file\nPOSITION_FILE = \"quant_positions_manual.json\"\nDATA_FILE = \"stock_data_manual.csv\"\n\n# =================== Core Classes ===================\n\nclass ManualStrategy:\n    \"\"\"Manual data input strategy\"\"\"\n\n    def __init__(self):\n        self.positions = {}\n        self.stock_data = {}\n        self.load_positions()\n        self.load_stock_data()\n\n    def calculate_rsi(self, prices, period=14):\n        \"\"\"Calculate RSI\"\"\"\n        delta = prices.diff()\n        gain = (delta.where(delta > 0, 0)).rolling(window=period).mean()\n        loss = (-delta.where(delta < 0, 0)).rolling(window=period).mean()\n        rs = gain / loss\n        rsi = 100 - (100 / (1 + rs))\n        return rsi\n\n    def load_positions(self):\n        \"\"\"Load positions\"\"\"\n        if os.path.exists(POSITION_FILE):\n            with open(POSITION_FILE, 'r', encoding='utf-8') as f:\n                self.positions = json.load(f)\n\n    def save_positions(self):\n        \"\"\"Save positions\"\"\"\n        with open(POSITION_FILE, 'w', encoding='utf-8') as f:\n            json.dump(self.positions, f, ensure_ascii=False, indent=2)\n\n    def load_stock_data(self):\n        \"\"\"Load stock data\"\"\"\n        if os.path.exists(DATA_FILE):\n            df = pd.read_csv(DATA_FILE, encoding='utf-8-sig')\n\n            # Group by code and keep data\n            for code in df['code'].unique():\n                stock_df = df[df['code'] == code].copy()\n                if len(stock_df) > 0:\n                    name = stock_df.iloc[0]['name']\n                    self.stock_data[code] = {\n                        'name': name,\n                        'data': stock_df\n                    }\n\n            print(f\"Loaded {len(self.stock_data)} stocks from {DATA_FILE}\")\n            return df\n        return pd.DataFrame(columns=['code', 'name', 'date', 'open', 'close', 'high', 'low', 'volume'])\n\n    def save_stock_data(self, df):\n        \"\"\"Save all stock data\"\"\"\n        df.to_csv(DATA_FILE, index=False, encoding='utf-8-sig')\n        print(f\"Stock data saved to: {DATA_FILE}\")\n\n    def add_stock_data(self, code, name, date, open_price, close_price, high, low, volume):\n        \"\"\"Add stock data\"\"\"\n        new_row = pd.DataFrame({\n            'code': [code],\n            'name': [name],\n            'date': [date],\n            'open': [open_price],\n            'close': [close_price],\n            'high': [high],\n            'low': [low],\n            'volume': [volume]\n        })\n\n        # Merge with existing data\n        if code in self.stock_data:\n            existing = self.stock_data[code]['data']\n            df = pd.concat([existing, new_row], ignore_index=True)\n        else:\n            df = new_row\n\n        df = df.sort_values('date')\n\n        self.stock_data[code] = {\n            'name': name,\n            'data': df\n        }\n\n        df.to_csv(DATA_FILE, index=False, encoding='utf-8-sig')\n        print(f\"Added data for {code} ({name}), now {len(df)} data points\")\n        self.save_stock_data(df)\n\n    def check_buy_signal(self, code):\n        \"\"\"Check buy conditions for manual data\"\"\"\n        if code not in self.stock_data:\n            return False, \"No data available\"\n\n        df = self.stock_data[code]['data']\n\n        if len(df) < 10:\n            return False, \"Not enough data (need at least 10 days)\"\n\n        df['ma5'] = df['close'].rolling(window=MA5_PERIOD).mean()\n        df['ma10'] = df['close'].rolling(window=MA10_PERIOD).mean()\n        df['avg_volume'] = df['volume'].rolling(window=20).mean()\n        df['volume_ratio'] = df['volume'] / df['avg_volume']\n        df['rsi'] = self.calculate_rsi(df['close'])\n\n        latest = df.iloc[-1]\n        prev = df.iloc[-2]\n\n        # 1. Golden cross check: MA5 crosses above MA10\n        ma5_golden = (prev['ma5'] < prev['ma10']) and (latest['ma5'] > latest['ma10'])\n\n        if not ma5_golden:\n            return False, \"No golden cross (MA5 > MA10)\"\n\n        # 2. Volume check: Volume >= 1.5x of 20-day average\n        vol_ratio = latest['volume_ratio']\n        if vol_ratio < VOLUME_MULTIPLIER:\n            return False, f\"Volume too low ({vol_ratio:.2f} < {VOLUME_MULTIPLIER})\"\n\n        # 3. RSI check: RSI < 70\n        rsi = latest['rsi']\n        if pd.isna(rsi) or rsi >= RSI_MAX:\n            return False, f\"RSI too high ({rsi:.2f} >= {RSI_MAX})\"\n\n        return True, f\"BUY SIGNAL: MA5={latest['ma5']:.2f} > MA10={latest['ma10']:.2f}, VolumeRatio={vol_ratio:.2f}, RSI={rsi:.2f}\"\n\n    def add_position(self, stock_code, name, price, shares):\n        \"\"\"Add position\"\"\"\n        self.positions[stock_code] = {\n            'name': name,\n            'cost': price,\n            'shares': shares,\n            'date': datetime.now().strftime('%Y-%m-%d'),\n            'stop_loss': price * (1 - STOP_LOSS_RATIO),\n            'take_profit': price * (1 + TAKE_PROFIT_RATIO)\n        }\n        self.save_positions()\n\n    def remove_position(self, stock_code):\n        \"\"\"Remove position\"\"\"\n        if stock_code in self.positions:\n            del self.positions[stock_code]\n            self.save_positions()\n\n    def check_sell_signals(self):\n        \"\"\"Check all positions for sell signals\"\"\"\n        signals = []\n\n        for code, pos in self.positions.items():\n            if code not in self.stock_data:\n                continue\n\n            df = self.stock_data[code]['data']\n\n            if len(df) == 0:\n                continue\n\n            latest = df.iloc[-1]['close']\n            cost = pos['cost']\n\n            profit = (latest - cost) * pos['shares']\n            profit_ratio = profit / (cost * pos['shares']) * 100\n\n            # Check take profit\n            if profit >= TAKE_PROFIT_RATIO * cost * pos['shares']:\n                signals.append({\n                    'code': code,\n                    'name': pos['name'],\n                    'action': 'SELL',\n                    'signal_type': 'TAKE_PROFIT',\n                    'reason': f\"Take profit: +{profit_ratio:.2f}%\",\n                    'current_price': latest,\n                    'cost_price': cost,\n                    'shares': pos['shares'],\n                    'value': latest * pos['shares'],\n                    'profit': profit,\n                    'time': datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n                })\n\n            # Check stop loss\n            elif profit <= -STOP_LOSS_RATIO * cost * pos['shares']:\n                signals.append({\n                    'code': code,\n                    'name': pos['name'],\n                    'action': 'SELL',\n                    'signal_type': 'STOP_LOSS',\n                    'reason': f\"Stop loss: {abs(profit_ratio):.2f}%\",\n                    'current_price': latest,\n                    'cost_price': cost,\n                    'shares': pos['shares'],\n                    'value': latest * pos['shares'],\n                    'profit': profit,\n                    'time': datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n                })\n\n        return signals\n\n    def print_dashboard(self):\n        \"\"\"Print dashboard\"\"\"\n        print(\"\\n\" + \"=\"*80)\n        print(\"A-Share Quant Trading - Manual Data Version\")\n        print(\"=\"*80)\n\n        # Capital overview\n        used_capital = sum([pos['cost'] * pos['shares'] for pos in self.positions.values()])\n        self.cash = TOTAL_CAPITAL - used_capital\n\n        print(f\"\\n[Capital Overview]\")\n        print(f\"Total Capital: {TOTAL_CAPITAL:,.2f} Yuan\")\n        print(f\"Position Value: {used_capital:,.2f} Yuan\")\n        print(f\"Cash Balance: {self.cash:,.2f} Yuan\")\n        print(f\"Position Ratio: {(used_capital/TOTAL_CAPITAL*100):.2f}%\")\n\n        # Position details\n        print(f\"\\n[Position Details]({len(self.positions)} stocks)\")\n        print(f\"{'Code':<10} {'Name':<15} {'Shares':<10} {'Cost':<10} {'Price':<10} {'Profit':<12} {'Profit%':<10}\")\n        print(\"-\"*80)\n\n        for code, pos in self.positions.items():\n            if code in self.stock_data and len(self.stock_data[code]['data']) > 0:\n                last_close = self.stock_data[code]['data'].iloc[-1]['close']\n                profit = (last_close - pos['cost']) * pos['shares']\n                profit_ratio = profit / (pos['cost'] * pos['shares']) * 100\n\n                sign = \"+\" if profit >= 0 else \"\"\n                print(f\"{code:<10} {pos['name']:<15} {pos['shares']:<10} {pos['cost']:<10.2f} {last_close:<10.2f} {sign}{profit:.2f} {profit_ratio:>7.2f}%\")\n            else:\n                print(f\"{code:<10} {pos['name']:<15} {pos['shares']:<10} {pos['cost']:<10.2f} N/A N/A N/A N/A\")\n\n        # Risk control\n        position_ratio = (used_capital / TOTAL_CAPITAL * 100) if TOTAL_CAPITAL > 0 else 0\n        print(f\"\\n[Risk Control]\")\n        if position_ratio > TOTAL_MAX_POSITION * 100:\n            print(f\"WARNING: Position ratio too high ({position_ratio:.2f}% > {TOTAL_MAX_POSITION*100:.0f}%)\")\n        else:\n            print(f\"OK: Position ratio normal ({position_ratio:.2f}%)\")\n\n        print(\"=\"*80)\n\n# =================== Main Function ===================\n\ndef main():\n    \"\"\"Main function\"\"\"\n    strategy = ManualStrategy()\n\n    print(\"\\n\" + \"=\"*60)\n    print(\"A-Share Quant Trading - Manual Data Version\")\n    print(\"=\"*60)\n\n    command = sys.argv[1] if len(sys.argv) > 1 else 'status'\n\n    if command == 'add':\n        print(\"\\n[Add Stock Data]\")\n        print(\"Format: python quant_scanner_manual.py add <code> <name> <date> <open> <close> <high> <low> <volume>\")\n        print(\"Example: python quant_scanner_manual.py add 600000 浦发银行 2026-03-20 10.00 10.10 10.15 9.90 1000000\")\n\n        if len(sys.argv) >= 10:\n            code = sys.argv[2]\n            name = sys.argv[3]\n            date = sys.argv[4]\n            open_price = float(sys.argv[5])\n            close_price = float(sys.argv[6])\n            high = float(sys.argv[7])\n            low = float(sys.argv[8])\n            volume = float(sys.argv[9])\n\n            strategy.add_stock_data(code, name, date, open_price, close_price, high, low, volume)\n            print(f\"\\nAdded data for {code} ({name})\")\n        else:\n            print(\"Error: Missing parameters\")\n\n    elif command == 'signal':\n        print(\"\\n[Check Buy Signals]\")\n        print(\"Format: python quant_scanner_manual.py signal <stock_code>\")\n        print(\"Example: python quant_scanner_manual.py signal 600000\")\n\n        if len(sys.argv) >= 3:\n            code = sys.argv[2]\n            is_signal, reason = strategy.check_buy_signal(code)\n\n            if is_signal:\n                print(f\"\\n>>> BUY SIGNAL: {code}\")\n                print(f\"Reason: {reason}\")\n            else:\n                print(f\"\\n>>> NO SIGNAL: {code}\")\n                print(f\"Reason: {reason}\")\n        else:\n            print(\"Error: Missing stock code\")\n\n    elif command == 'buy':\n        print(\"\\n[Buy Stock & Add Position]\")\n        print(\"Format: python quant_scanner_manual.py buy <code> <name> <price> <shares>\")\n\n        if len(sys.argv) >= 6:\n            code = sys.argv[2]\n            name = sys.argv[3]\n            price = float(sys.argv[4])\n            shares = int(sys.argv[5])\n\n            strategy.add_position(code, name, price, shares)\n            print(f\"\\nBought {shares} shares of {code} ({name}) at {price:.2f}\")\n            print(f\"Total cost: {price * shares:.2f}\")\n        else:\n            print(\"Error: Missing parameters\")\n\n    elif command == 'sell':\n        print(\"\\n[Sell Position]\")\n        print(\"Format: python quant_scanner_manual.py sell <code>\")\n        print(\"Example: python quant_scanner_manual.py sell 600000\")\n\n        if len(sys.argv) >= 3:\n            code = sys.argv[2]\n            strategy.remove_position(code)\n            print(f\"\\nSold all shares of {code}\")\n        else:\n            print(\"Error: Missing stock code\")\n\n    elif command == 'status':\n        strategy.print_dashboard()\n\n        # Check sell signals\n        sell_signals = strategy.check_sell_signals()\n\n        if sell_signals:\n            print(f\"\\n[Sell Signals]({len(sell_signals)})\")\n            print(f\"{'Code':<10} {'Name':<15} {'Action':<10} {'Reason':<30}\")\n            print(\"-\"*80)\n            for signal in sell_signals:\n                print(f\"{signal['code']:<10} {signal['name']:<15} {'SELL':<10} {signal['reason']}\")\n        else:\n            print(\"\\nNo sell signals\")\n\n    elif command == 'help':\n        print(\"\\n[Detailed Help]\")\n\n        print(\"\\n[1. Add Stock Data]\")\n        print(\"   Command: add\")\n        print(\"   Purpose: Manually add historical price/volume data\")\n        print(\"   Format: python quant_scanner_manual.py add <code> <name> <date> <open> <close> <high> <low> <volume>\")\n        print(\"   Example: python quant_scanner_manual.py add 600000 浦发银行 2026-03-20 10.00 10.10 10.15 9.90 1000000\")\n        print(\"   Note: Add multiple days by running add command multiple times\")\n        print(\"         Make sure dates are in chronological order!\")\n\n        print(\"\\n[2. Check Buy Signal]\")\n        print(\"   Command: signal\")\n        print(\"   Purpose: Check if stock meets buy criteria (MA5>MA10, Volume>=1.5x, RSI<70)\")\n        print(\"   Format: python quant_scanner_manual.py signal <stock_code>\")\n        print(\"   Example: python quant_scanner_manual.py signal 600000\")\n\n        print(\"\\n[3. Buy Stock (Add Position)]\")\n        print(\"   Command: buy\")\n        print(\"   Purpose: Buy stock and add to positions\")\n        print(\"   Format: python quant_scanner_manual.py buy <code> <name> <price> <shares>\")\n        print(\"   Example: python quant_scanner_manual.py buy 600000 浦发银行 10.00 500\")\n\n        print(\"\\n[4. Sell Position]\")\n        print(\"   Command: sell\")\n        print(\"   Purpose: Sell stock and remove from positions\")\n        print(\"   Format: python quant_scanner_manual.py sell <stock_code>\")\n        print(\"   Example: python quant_scanner_manual.py sell 600000\")\n\n        print(\"\\n[5. Status Dashboard]\")\n        print(\"   Command: status\")\n        print(\"   Purpose: Show current positions, capital, and sell signals\")\n        print(\"   Format: python quant_scanner_manual.py status\")\n\n        print(\"\\n[Manual Data Workflow]\")\n        print(\"   Since akshare/tushare are unavailable, use this manual workflow:\")\n        print(\"   1. Get stock data from browser (tushare.pro, eastmoney.com)\")\n        print(\"   2. Add 30-60 days of data using 'add' command\")\n        print(\"   3. Check signals using 'signal' command\")\n        print(\"   4. If BUY signal, buy stock using 'buy' command\")\n        print(\"   5. Monitor positions using 'status' command\")\n\n    else:\n        print(\"\\nUnknown command. Use 'help' to see available commands.\")\n        print(\"\\nAvailable commands: add, signal, buy, sell, status, help\")\n\nif __name__ == \"__main__\":\n    main()\n","path":"C:\\Users\\Administrator\\.openclaw\\workspace\\quant_scanner_manual.py"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":137213,"output":3905,"cacheRead":0,"cacheWrite":0,"totalTokens":141118,"cost":{"input":0.08232779999999999,"output":0.008591,"cacheRead":0,"cacheWrite":0,"total":0.0909188}},"stopReason":"toolUse","timestamp":1774246305441}}
