{"type":"message","id":"3bd83039","parentId":"fa020e16","timestamp":"2026-03-23T04:33:02.994Z","message":{"role":"toolResult","toolCallId":"call_8cac82832ca14aa2a5f96252","toolName":"read","content":[{"type":"text","text":"\"\"\"\n简化版akshare测试 - 直接显示输出\n\"\"\"\nimport akshare as ak\n\nprint(\"=\"*60)\nprint(\"akshare数据源连接测试\")\nprint(\"=\"*60)\n\ntry:\n    # 1. 测试获取股票列表\n    print(\"\\n[步骤1] 获取主板非ST股票列表...\")\n    stocks = ak.stock_info_a_code_name()\n    print(f\"总股票数: {len(stocks)}\")\n\n    # 筛选主板\n    main_board = stocks[\n        (stocks['code'].str.startswith('60') | stocks['code'].str.startswith('00'))\n    ]\n    print(f\"主板股票数: {len(main_board)}\")\n\n    # 排除ST\n    non_st = main_board[\n        (~main_board['name'].str.contains('ST'))\n    ]\n    print(f\"主板非ST股票数: {len(non_st)}\")\n\n    # 显示前10只\n    print(\"\\n前10只主板非ST股票:\")\n    print(non_st.head(10)[['code', 'name']])\n\n    # 2. 测试获取历史数据（第1只）\n    if len(non_st) > 0:\n        test_code = non_st.iloc[0]['code']\n        test_name = non_st.iloc[0]['name']\n\n        print(f\"\\n[步骤2] 测试获取 {test_code}({test_name}) 历史数据...\")\n\n        from datetime import datetime, timedelta\n        end_date = datetime.now().strftime('%Y%m%d')\n        start_date = (datetime.now() - timedelta(days=60)).strftime('%Y%m%d')\n\n        print(f\"数据范围: {start_date} ~ {end_date}\")\n\n        df = ak.stock_zh_a_hist(\n            symbol=test_code,\n            period=\"daily\",\n            start_date=start_date,\n            end_date=end_date,\n            adjust=\"qfq\"\n        )\n\n        print(f\"数据点数: {len(df)}\")\n        print(f\"数据列: {list(df.columns)}\")\n\n        # 显示最后5行\n        print(\"\\n最后5个交易日数据:\")\n        print(df[['日期', '收盘', '成交量']].tail())\n\n        # 3. 测试技术指标计算\n        print(\"\\n[步骤3] 计算技术指标...\")\n\n        df['MA5'] = df['收盘'].rolling(window=5).mean()\n        df['MA10'] = df['收盘'].rolling(window=10).mean()\n        df['AvgVolume'] = df['成交量'].rolling(window=20).mean()\n        df['VolumeRatio'] = df['成交量'] / df['AvgVolume']\n\n        latest = df.iloc[-1]\n        prev = df.iloc[-2]\n\n        # 金叉\n        ma5_golden = (prev['MA5'] < prev['MA10']) and (latest['MA5'] > latest['MA10'])\n\n        # 成交量\n        vol_ratio = latest['VolumeRatio']\n\n        # RSI\n        delta = df['收盘'].diff()\n        gain = (delta.where(delta > 0, 0)).rolling(window=14).mean()\n        loss = (-delta.where(delta < 0, 0)).rolling(window=14).mean()\n        rs = gain / loss\n        rsi = 100 - (100 / (1 + rs))\n        latest_rsi = rsi.iloc[-1]\n\n        print(f\"MA5: {latest['MA5']:.2f}, MA10: {latest['MA10']:.2f}\")\n        print(f\"金叉: {'是' if ma5_golden else '否'}\")\n        print(f\"成交量比: {vol_ratio:.2f}\")\n        print(f\"RSI: {latest_rsi:.2f}\")\n\n        # 判断是否满足条件\n        print(\"\\n[步骤4] 检查买入条件...\")\n\n        golden_ok = ma5_golden\n        vol_ok = vol_ratio >= 1.5\n        rsi_ok = not pd.isna(latest_rsi) and latest_rsi < 70\n\n        print(f\"金叉条件: {'✅' if golden_ok else '❌'}\")\n        print(f\"成交量条件(≥1.5倍): {'✅' if vol_ok else '❌'} ({vol_ratio:.2f})\")\n        print(f\"RSI条件(<70): {'✅' if rsi_ok else '❌'} ({latest_rsi:.2f})\")\n\n        all_ok = golden_ok and vol_ok and rsi_ok\n\n        print(f\"\\n是否满足全部条件: {'✅ 是' if all_ok else '❌ 否'}\")\n\n        if all_ok:\n            print(f\"\\n🎯 找到候选股票：{test_code} {test_name}\")\n            print(f\"现价: {latest['收盘']:.2f}\")\n            print(f\"信号: MA5({latest['MA5']:.2f}) > MA10({latest['MA10']:.2f}) 金叉 + 放量({vol_ratio:.2f}倍) + RSI({latest_rsi:.2f})\")\n        else:\n            print(f\"\\n❌ 不满足条件\")\n\n    print(\"\\n\" + \"=\"*60)\n    print(\"测试完成！\")\n\nexcept Exception as e:\n    print(f\"\\n❌ 错误: {e}\")\n    import traceback\n    traceback.print_exc()\n"}],"isError":false,"timestamp":1774240382981}}
{"type":"message","id":"e28c5e13","parentId":"3bd83039","timestamp":"2026-03-23T04:35:24.352Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，我读取了simple_akshare_test.py文件。现在让我创建一个超简化版本，只测试akshare连接并保存输出到文件。","thinkingSignature":"reasoning_content"},{"type":"text","text":"让我创建一个保存输出到文件的测试脚本："},{"type":"toolCall","id":"call_060ed27e49804b2894abe255","name":"write","arguments":{"content":"\"\"\"\nakshare测试 - 保存输出到文件\n\"\"\"\nimport sys\nimport akshare as ak\n\n# 重定向输出到文件\noutput_file = open('akshare_test_output.txt', 'w', encoding='utf-8')\n\ndef log(msg):\n    print(msg)  # 同时输出到控制台\n    output_file.write(msg + '\\n')  # 输出到文件\n    output_file.flush()\n\ntry:\n    log(\"=\"*60)\n    log(\"akshare数据源测试\")\n    log(\"=\"*60)\n\n    # 1. 获取股票列表\n    log(\"\\n[步骤1] 获取股票列表...\")\n    stocks = ak.stock_info_a_code_name()\n    log(f\"总股票数: {len(stocks)}\")\n\n    # 2. 筛选主板\n    log(\"\\n[步骤2] 筛选主板股票...\")\n    main_board = stocks[\n        (stocks['code'].str.startswith('60') | stocks['code'].str.startswith('00'))\n    ]\n    log(f\"主板股票数: {len(main_board)}\")\n\n    # 3. 排除ST\n    log(\"\\n[步骤3] 排除ST股票...\")\n    non_st = main_board[\n        (~main_board['name'].str.contains('ST'))\n    ]\n    log(f\"主板非ST股票数: {len(non_st)}\")\n\n    # 4. 获取历史数据测试\n    if len(non_st) > 0:\n        test_code = non_st.iloc[0]['code']\n        test_name = non_st.iloc[0]['name']\n\n        log(f\"\\n[步骤4] 测试获取历史数据...\")\n        log(f\"测试股票: {test_code} ({test_name})\")\n\n        from datetime import datetime, timedelta\n\n        # 使用历史日期（3月20日）\n        end_date = \"20260320\"\n        start_date = \"20260101\"\n\n        log(f\"数据日期范围: {start_date} ~ {end_date}\")\n\n        df = ak.stock_zh_a_hist(\n            symbol=test_code,\n            period=\"daily\",\n            start_date=start_date,\n            end_date=end_date,\n            adjust=\"qfq\"\n        )\n\n        log(f\"数据点数: {len(df)}\")\n        log(f\"数据列: {list(df.columns)}\")\n\n        # 显示最后5行\n        log(\"\\n最后5个交易日数据:\")\n        for idx, row in df.tail(5).iterrows():\n            log(f\"日期: {row['日期']}, 收盘: {row['收盘']}, 成交量: {row['成交量']}\")\n\n        # 计算技术指标\n        log(\"\\n[步骤5] 计算技术指标...\")\n        df['MA5'] = df['收盘'].rolling(window=5).mean()\n        df['MA10'] = df['收盘'].rolling(window=10).mean()\n        df['AvgVolume'] = df['成交量'].rolling(window=20).mean()\n        df['VolumeRatio'] = df['成交量'] / df['AvgVolume']\n\n        latest = df.iloc[-1]\n        prev = df.iloc[-2]\n\n        ma5 = latest['MA5']\n        ma10 = latest['MA10']\n        vol_ratio = latest['VolumeRatio']\n\n        # 计算RSI\n        delta = df['收盘'].diff()\n        gain = (delta.where(delta > 0, 0)).rolling(window=14).mean()\n        loss = (-delta.where(delta < 0, 0)).rolling(window=14).mean()\n        rs = gain / loss\n        rsi = 100 - (100 / (1 + rs))\n        latest_rsi = rsi.iloc[-1]\n\n        log(f\"MA5: {ma5:.2f}, MA10: {ma10:.2f}\")\n        log(f\"成交量比: {vol_ratio:.2f}\")\n        log(f\"RSI: {latest_rsi:.2f}\")\n\n        # 检查买入条件\n        log(\"\\n[步骤6] 检查买入条件...\")\n\n        golden_cross = (prev['MA5'] < prev['MA10']) and (ma5 > ma10)\n        vol_ok = vol_ratio >= 1.5\n        rsi_ok = not pd.isna(latest_rsi) and latest_rsi < 70\n\n        log(f\"金叉条件(MA5>MA10): {'✅' if golden_cross else '❌'}\")\n        log(f\"成交量条件(≥1.5倍): {'✅' if vol_ok else '❌'} ({vol_ratio:.2f}倍)\")\n        log(f\"RSI条件(<70): {'✅' if rsi_ok else '❌'} ({latest_rsi:.2f})\")\n\n        all_ok = golden_cross and vol_ok and rsi_ok\n\n        log(f\"\\n是否满足全部条件: {'✅ 是' if all_ok else '❌ 否'}\")\n\n        if all_ok:\n            log(f\"\\n🎯 找到候选股票：{test_code} {test_name}\")\n            log(f\"现价: {latest['收盘']:.2f}\")\n            log(f\"买入信号: MA5金叉 + 放量 + RSI低\")\n        else:\n            log(f\"\\n❌ 不满足全部买入条件\")\n\n    log(\"\\n\" + \"=\"*60)\n    log(\"测试完成！\")\n    log(\"=\"*60)\n\nexcept Exception as e:\n    log(f\"\\n❌ 错误: {e}\")\n    import traceback\n    traceback.print_exc()\nfinally:\n    output_file.close()\n    log(\"\\n测试结果已保存到：akshare_test_output.txt\")\n","path":"C:\\Users\\Administrator\\.openclaw\\workspace\\akshare_test_with_log.py"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":115350,"output":1299,"cacheRead":5912,"cacheWrite":0,"totalTokens":122561,"cost":{"input":0.06921,"output":0.0028578,"cacheRead":0.00065032,"cacheWrite":0,"total":0.07271811999999998}},"stopReason":"toolUse","timestamp":1774240382995}}
