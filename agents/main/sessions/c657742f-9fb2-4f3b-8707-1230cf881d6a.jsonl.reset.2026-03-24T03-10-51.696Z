{"type":"message","id":"d1703b82","parentId":"abe4177a","timestamp":"2026-03-23T05:38:25.288Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"进程完成了，但可能没有输出到控制台。让我创建一个使用tushare的备用扫描脚本，这样即使akshare有代理问题，系统也能工作。\n\n我需要：\n1. 创建tushare版本的扫描脚本\n2. 提供tushare安装说明\n3. 提供获取token的指导\n\n这样用户就有了可靠的替代数据源。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_1d613c526a924746b60176cf","name":"write","arguments":{"content":"\"\"\"\ntushare版本的量化扫描脚本（备用数据源）\n优点：不需要代理，数据质量高\n\"\"\"\n\nimport tushare as ts\nimport pandas as pd\nfrom datetime import datetime, timedelta\n\n# =================== 配置 ===================\n\n# 策略参数\nTOTAL_CAPITAL = 50000\nSINGLE_STOCK_MAX_RATIO = 0.20\nTOTAL_MAX_POSITION = 0.80\nTAKE_PROFIT_RATIO = 0.15\nSTOP_LOSS_RATIO = 0.05\nMA5_PERIOD = 5\nMA10_PERIOD = 10\nVOLUME_MULTIPLIER = 1.5\nRSI_MAX = 70\n\n# =================== tushare配置 ===================\n\n# 重要：需要到 https://tushare.pro 注册并获取免费token\n# 或者使用：pro_api = ts.pro_api()\nTUSHARE_TOKEN = \"你的token_here\"  # 替换为你的实际token\n\n# 持仓文件\nPOSITION_FILE = \"quant_positions_tushare.json\"\nSCAN_RESULT_FILE = \"scan_results_tushare.csv\"\n\n# =================== 核心类 ===================\n\nclass TushareStrategy:\n    \"\"\"tushare量化策略类\"\"\"\n\n    def __init__(self):\n        # 初始化tushare token\n        self.pro_api = ts.pro_api(token=TUSHARE_TOKEN) if TUSHARE_TOKEN else ts.pro_api()\n        self.positions = {}\n        self.load_positions()\n\n    def calculate_rsi(self, prices, period=14):\n        \"\"\"计算RSI指标\"\"\"\n        delta = prices.diff()\n        gain = (delta.where(delta > 0, 0)).rolling(window=period).mean()\n        loss = (-delta.where(delta < 0, 0)).rolling(window=period).mean()\n        rs = gain / loss\n        rsi = 100 - (100 / (1 + rs))\n        return rsi\n\n    def check_buy_signal(self, df):\n        \"\"\"检查买入条件\"\"\"\n        if df is None or len(df) < 10:\n            return False, \"数据不足\"\n\n        latest = df.iloc[-1]\n        prev = df.iloc[-2]\n\n        # 1. 金叉检查：MA5上穿MA10\n        ma5_golden = (prev['ma5'] < prev['ma10']) and (latest['ma5'] > latest['ma10'])\n\n        if not ma5_golden:\n            return False, \"未出现金叉\"\n\n        # 2. 成交量放大检查：成交量 >= 近20日均量的1.5倍\n        vol_ratio = latest['volume'] / latest['avg_volume']\n        if vol_ratio < VOLUME_MULTIPLIER:\n            return False, f\"成交量不足（{vol_ratio:.2f}<{VOLUME_MULTIPLIER}）\"\n\n        # 3. RSI检查：RSI < 70\n        rsi_ok = latest['rsi'] < RSI_MAX\n        if not rsi_ok:\n            return False, f\"RSI过高（{latest['rsi']:.2f}>=70）\"\n\n        return True, f\"满足所有条件: MA5={latest['ma5']:.2f}>MA10={latest['ma10']:.2f}, RSI={latest['rsi']:.2f}, 量比={vol_ratio:.2f}\"\n\n    def get_stock_list(self):\n        \"\"\"获取主板非ST股票列表\"\"\"\n        print(\"\\n[1] 获取A股股票列表...\")\n\n        # 获取所有A股基本信息\n        stock_info = self.pro_api.stock_basic(\n            ts_code='',\n            fields=['code', 'name', 'list_date']\n        )\n\n        # 筛选主板股票（60、00开头）\n        stock_info = stock_info[\n            (stock_info['code'].str.startswith('60') | stock_info['code'].str.startswith('00'))\n        ]\n\n        print(f\"主板股票总数: {len(stock_info)}\")\n\n        # 排除ST股票\n        stock_info = stock_info[\n            ~stock_info['name'].str.contains('ST')\n        ]\n\n        print(f\"主板非ST股票: {len(stock_info)}\")\n\n        return stock_info\n\n    def scan_stocks(self, max_results=20):\n        \"\"\"扫描股票寻找买入信号\"\"\"\n        print(\"\\n[2] 开始扫描股票...\")\n        print(f\"最多扫描 {max_results} 只股票\")\n\n        stock_list = self.get_stock_list()\n        candidates = []\n        scanned_count = 0\n\n        for idx, stock in stock_list.iterrows():\n            code = stock['code']\n            name = stock['name']\n\n            scanned_count += 1\n            if scanned_count % 10 == 0:\n                print(f\"已扫描 {scanned_count}/{len(stock_list)} 只股票，找到 {len(candidates)} 个候选\")\n\n            try:\n                # 获取历史数据（最近120天）\n                end_date = datetime.now()\n                start_date = end_date - timedelta(days=120)\n\n                df = ts.get_hist(\n                    code=code,\n                    start_date=start_date.strftime('%Y%m%d'),\n                    end_date=end_date.strftime('%Y%m%d'),\n                    ktype='D',\n                    adjust='qfq'\n                )\n\n                if df is None or len(df) < 20:\n                    continue\n\n                # 计算技术指标\n                df['ma5'] = df['close'].rolling(window=MA5_PERIOD).mean()\n                df['ma10'] = df['close'].rolling(window=MA10_PERIOD).mean()\n                df['avg_volume'] = df['volume'].rolling(window=20).mean()\n                df['volume_ratio'] = df['volume'] / df['avg_volume']\n                df['rsi'] = self.calculate_rsi(df['close'])\n\n                # 检查买入条件\n                is_signal, reason = self.check_buy_signal(df)\n\n                if is_signal:\n                    latest = df.iloc[-1]\n                    candidates.append({\n                        'code': code,\n                        'name': name,\n                        'close': latest['close'],\n                        'change': (latest['close'] - latest['open']) / latest['open'] * 100,\n                        'ma5': latest['ma5'],\n                        'ma10': latest['ma10'],\n                        'volume_ratio': latest['volume_ratio'],\n                        'rsi': latest['rsi'],\n                        'signal_reason': reason,\n                        'scan_time': datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n                    })\n\n                if len(candidates) >= max_results:\n                    print(f\"\\n已找到{max_results}个候选，停止扫描\")\n                    break\n\n            except Exception as e:\n                # 跳过错误继续\n                continue\n\n        print(f\"\\n扫描完成！共扫描 {scanned_count} 只股票，找到 {len(candidates)} 个候选\")\n\n        return candidates\n\n    def save_scan_results(self, candidates):\n        \"\"\"保存扫描结果\"\"\"\n        df = pd.DataFrame(candidates)\n        df.to_csv(SCAN_RESULT_FILE, index=False, encoding='utf-8-sig')\n        print(f\"\\n扫描结果已保存到：{SCAN_RESULT_FILE}\")\n\n        # 同时保存JSON格式\n        import json\n        with open('scan_results_tushare.json', 'w', encoding='utf-8') as f:\n            json.dump(candidates, f, ensure_ascii=False, indent=2)\n\n        return df\n\n    def load_positions(self):\n        \"\"\"加载持仓\"\"\"\n        import json\n        import os\n        if os.path.exists(POSITION_FILE):\n            with open(POSITION_FILE, 'r', encoding='utf-8') as f:\n                self.positions = json.load(f)\n\n    def save_positions(self):\n        \"\"\"保存持仓\"\"\"\n        import json\n        with open(POSITION_FILE, 'w', encoding='utf-8') as f:\n            json.dump(self.positions, f, ensure_ascii=False, indent=2)\n\n    def add_position(self, stock_code, name, price, shares):\n        \"\"\"添加持仓\"\"\"\n        self.positions[stock_code] = {\n            'name': name,\n            'cost': price,\n            'shares': shares,\n            'date': datetime.now().strftime('%Y-%m-%d'),\n            'stop_loss': price * (1 - STOP_LOSS_RATIO),\n            'take_profit': price * (1 + TAKE_PROFIT_RATIO)\n        }\n        self.save_positions()\n\n    def print_dashboard(self):\n        \"\"\"打印持仓监控界面\"\"\"\n        print(\"\\n\" + \"=\"*80)\n        print(\"A股量化交易 - 持仓监控界面（tushare版本）\")\n        print(\"=\"*80)\n\n        # 计算可用资金\n        used_capital = sum([pos['cost'] * pos['shares'] for pos in self.positions.values()])\n        self.cash = TOTAL_CAPITAL - used_capital\n\n        # 资金概览\n        print(f\"\\n【资金概览】\")\n        print(f\"总资金: {TOTAL_CAPITAL:,.2f} 元\")\n        print(f\"持仓市值: {used_capital:,.2f} 元\")\n        print(f\"现金余额: {self.cash:,.2f} 元\")\n        print(f\"总持仓比例: {(used_capital/TOTAL_CAPITAL*100):.2f}%\")\n\n        # 持仓明细\n        print(f\"\\n【持仓明细】({len(self.positions)}只)\")\n        print(f\"{'代码':<10} {'名称':<15} {'持仓数':<10} {'成本价':<10} {'现价':<10} {'盈亏':<12} {'盈亏%':<10}\")\n        print(\"-\"*80)\n\n        for code, pos in self.positions.items():\n            try:\n                # 获取最新价格\n                end_date = datetime.now()\n                start_date = end_date - timedelta(days=5)\n\n                df = ts.get_hist(\n                    code=code,\n                    start_date=start_date.strftime('%Y%m%d'),\n                    end_date=end_date.strftime('%Y%m%d'),\n                    ktype='D',\n                    adjust='qfq'\n                )\n\n                if df is None or len(df) == 0:\n                    current_price = pos['cost']\n                else:\n                    current_price = df.iloc[-1]['close']\n\n                profit = (current_price - pos['cost']) * pos['shares']\n                profit_ratio = profit / (pos['cost'] * pos['shares']) * 100\n\n                sign = \"+\" if profit >= 0 else \"\"\n                print(f\"{code:<10} {pos['name']:<15} {pos['shares']:<10} {pos['cost']:<10.2f} {current_price:<10.2f} {sign}{profit:.2f} {profit_ratio:>7.2f}%\")\n\n            except Exception as e:\n                print(f\"{code:<10} {pos['name']:<15} {pos['shares']:<10} {pos['cost']:<10.2f} 错误\")\n\n        # 风控状态\n        position_ratio = (used_capital / TOTAL_CAPITAL * 100) if TOTAL_CAPITAL > 0 else 0\n        print(f\"\\n【风控状态】\")\n        if position_ratio > TOTAL_MAX_POSITION * 100:\n            print(f\"⚠ 总持仓比例超标 ({position_ratio:.2f}% > {TOTAL_MAX_POSITION*100:.0f}%)\")\n        else:\n            print(f\"✅ 总持仓比例正常 ({position_ratio:.2f}%)\")\n\n        print(\"=\"*80)\n\n# =================== 主函数 ===================\n\ndef main():\n    \"\"\"主函数\"\"\"\n    print(\"\\n\" + \"=\"*60)\n    print(\"A股量化交易 - tushare版本\")\n    print(\"=\"*60)\n\n    # 检查token\n    if TUSHARE_TOKEN == \"你的token_here\":\n        print(\"\\n⚠️ 重要：需要配置 tushare token\")\n        print(\"\\n请按以下步骤操作：\")\n        print(\"1. 访问：https://tushare.pro/register\")\n        print(\"2. 注册免费账号\")\n        print(\"3. 登录获取 API Token\")\n        print(\"4. 将 token 填入到脚本中的 TUSHARE_TOKEN 变量\")\n        print(\"\\n配置完成后，重新运行脚本即可开始扫描\")\n        return\n\n    strategy = TushareStrategy()\n\n    # 显示持仓监控界面\n    strategy.print_dashboard()\n\n    # 如果命令行参数是 'scan'，则执行扫描\n    import sys\n    if len(sys.argv) > 1 and sys.argv[1] == 'scan':\n        print(\"\\n开始执行股票扫描...\")\n        candidates = strategy.scan_stocks(max_results=20)\n        strategy.save_scan_results(candidates)\n\n        # 显示候选股票\n        if candidates:\n            print(\"\\n【候选股票列表】\")\n            print(f\"{'代码':<10} {'名称':<15} {'现价':<10} {'涨跌幅':<10} {'量比':<10} {'RSI':<10} {'信号原因':<30}\")\n            print(\"-\"*100)\n            for stock in candidates:\n                print(f\"{stock['code']:<10} {stock['name']:<15} {stock['close']:<10.2f} {stock['change']:>8.2f}% {stock['volume_ratio']:.2f} {stock['rsi']:.1f} {stock['signal_reason']}\")\n    else:\n        print(\"\\n未找到符合条件的候选股票\")\n\nif __name__ == \"__main__\":\n    main()\n","path":"C:\\Users\\Administrator\\.openclaw\\workspace\\quant_scanner_tushare.py"}}],"api":"openai-completions","provider":"zai","model":"glm-4.7","usage":{"input":137213,"output":3036,"cacheRead":0,"cacheWrite":0,"totalTokens":140249,"cost":{"input":0.08232779999999999,"output":0.006679200000000001,"cacheRead":0,"cacheWrite":0,"total":0.08900699999999999}},"stopReason":"toolUse","timestamp":1774244227168}}
